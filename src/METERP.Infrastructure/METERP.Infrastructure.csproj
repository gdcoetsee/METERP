<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ProjectGuid>{C5DF3360-989A-4F87-9F98-24B102DD8807}</ProjectGuid>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\METERP.Application\METERP.Application.csproj" />
    <ProjectReference Include="..\METERP.Common\METERP.Common.csproj" />
    <ProjectReference Include="..\METERP.Domain\METERP.Domain.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- EF Core + Identity + PostgreSQL for foundation (chosen for lower cost/scalability in a sellable product) -->
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="9.0.*" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="9.0.*" />
    <PackageReference Include="Microsoft.AspNetCore.Identity.EntityFrameworkCore" Version="9.0.*" />
    <!-- For migrations and design time -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.*">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <!-- For CurrentUserService (HttpContext) - acceptable for foundation; in larger systems this impl would live in Web -->
    <PackageReference Include="Microsoft.AspNetCore.Http.Abstractions" Version="2.3.11" />
    <!-- AI assistant uses typed/named HttpClient -->
    <PackageReference Include="Microsoft.Extensions.Http" Version="9.0.*" />
    <PackageReference Include="MailKit" Version="4.17.0" />
    <PackageReference Include="Microsoft.Extensions.Caching.Memory" Version="9.0.*" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="9.0.*" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="9.0.*" />
    <PackageReference Include="Microsoft.AspNetCore.DataProtection" Version="9.0.*" />
    <PackageReference Include="System.Text.Encodings.Web" Version="9.0.*" />
  </ItemGroup>

</Project>
