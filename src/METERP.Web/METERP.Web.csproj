<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ProjectGuid>{D984DDDB-7AEE-437C-97EA-8B48271EB87B}</ProjectGuid>
    <UserSecretsId>bdc12c8f-c53c-46c8-b25d-60bb7c4c91f9</UserSecretsId>
    <!-- Plain `dotnet run` uses Development + localhost:8080 (required for local Postgres / E2E). -->
    <DefaultLaunchProfile>local-8080</DefaultLaunchProfile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\METERP.Application\METERP.Application.csproj" />
    <ProjectReference Include="..\METERP.Common\METERP.Common.csproj" />
    <ProjectReference Include="..\METERP.Domain\METERP.Domain.csproj" />
    <ProjectReference Include="..\METERP.Infrastructure\METERP.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Blazor Server and EF/Identity for foundation -->
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.Server" Version="9.0.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Tools" Version="9.0.0">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>

    <!-- Professional PDF generation for AI reports, quote/job closeouts, and branded exports. Community license is sufficient. -->
    <PackageReference Include="QuestPDF" Version="2024.12.0" />

    <!-- Rate limiting is provided by the ASP.NET Core framework (no extra package needed for .NET 9 web apps). See AddRateLimiter + UseRateLimiter in Program.cs. -->
    <!-- Direct Npgsql for the dev DB reset helper in seeder (transitive from EF provider but explicit for compile of Npgsql* types in Program.cs) -->
    <PackageReference Include="Npgsql" Version="9.0.0" />

    <!-- Serilog for structured logging (production hardening per AGENTS.md + COMPLETION_PLAN handoff).
         Console for dev, File for basic prod. Add Seq/Splunk sink + env config later for live deployment. -->
    <PackageReference Include="Serilog.AspNetCore" Version="8.0.2" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.0.0" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.0.0" />
    <PackageReference Include="Serilog.Sinks.Seq" Version="8.0.0" />

    <!-- Health checks for live deployment (DB, basic liveness). Expose /health and /health/ready.
         Per COMPLETION_PLAN handoff for production readiness. -->
    <PackageReference Include="AspNetCore.HealthChecks.UI.Client" Version="8.0.1" />
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks.EntityFrameworkCore" Version="9.0.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" Version="9.0.0" />
  </ItemGroup>

</Project>
