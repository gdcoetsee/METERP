{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=METERP;Username=postgres;Password=CHANGE_ME;Port=5432"
  },
  // === AI Assistant (optional but powerful for estimating & learning) ===
  // Set ApiKey to enable ✨ AI features in Quotes and Jobs.
  // Works with any OpenAI-compatible endpoint (OpenAI, xAI/Grok, Groq, Ollama, Azure OpenAI, etc.)
  // Recommended free testing: Google AI Studio — BaseUrl .../v1beta/openai, Model gemini-flash-latest, key AIza...
  "Ai": {
    "Enabled": true,
    "ApiKey": "",
    "BaseUrl": "https://generativelanguage.googleapis.com/v1beta/openai",
    "Model": "gemini-flash-latest",
    "TimeoutSeconds": 60
  },
  // === Seeding control (see DatabaseSeeder in Program.cs) ===
  // Default behavior is now safe/non-destructive for normal development and docker runs.
  // Set ForceResetOnStart to true (or use METERP_SEED_RESET=true env var) only when you need a full DB wipe after model changes.
  "Seed": {
    "ForceResetOnStart": false,
    "LargeDataset": false,
    "LargeDatasetCustomers": 50,
    "LargeDatasetQuotes": 200,
    "LargeDatasetJobs": 120,
    "LargeDatasetInvoices": 80
  },
  "Seq": {
    "ServerUrl": ""
  },
  "Billing": {
    "WebhookSecret": "",
    "StripeSecretKey": "",
    "CustomerPortalBaseUrl": "https://billing.stripe.com/p/login/demo_meterp",
    "CustomerPortalReturnUrl": "http://localhost:8080/tenants",
    "WebhookEventRetentionDays": 90
  },
  "Email": {
    "SmtpHost": "",
    "SmtpPort": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@meterp.local",
    "FromName": "METERP",
    "DefaultNotificationTo": ""
  }
}
