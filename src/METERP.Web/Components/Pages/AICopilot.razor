    private async Task CreateProjectPlanFromAiText(string? aiText)
    {
        var text = string.IsNullOrWhiteSpace(aiText) ? lastResponse : aiText;
        if (string.IsNullOrWhiteSpace(text)) return;

        try
        {
            var newQuote = new Quote
            {
                QuoteDate = DateTime.UtcNow,
                ValidUntil = DateTime.UtcNow.AddDays(30),
                TaxRate = 0.15m,
                Notes = "AI Project Plan - Quote: " + text,
                CustomerId = availableCustomers.FirstOrDefault()?.Id ?? Guid.Empty
            };
            var quoteId = await QuoteService.CreateAsync(newQuote);
            lastCreatedQuote = await QuoteService.GetByIdAsync(quoteId);

            var newJob = new Job
            {
                Title = "AI Project Plan - Job",
                Description = "Linked to AI generated plan",
                Notes = "AI Generated Project Plan: " + text + "\n\nLinked Quote created.",
                Status = JobStatus.Scheduled,
                QuotedTotal = 0
            };
            var jobId = await JobService.CreateAsync(newJob);
            lastCreatedJob = await JobService.GetByIdAsync(jobId);

            lastAiTextForPdf = text;

            ToastService.ShowSuccess("Full Project Plan created (Quote + Job) from this response. Check /quotes and /jobs.");
            Navigation.NavigateTo("/ai-copilot");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Failed to create Project Plan from AI: " + ex.Message);
        }
    }

