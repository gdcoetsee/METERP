@page "/ai-copilot"
@using METERP.Application.Services
@using METERP.Application.Interfaces
@using METERP.Domain
@using METERP.Common
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "Jobs.View")]
@* Broad access for now; tighten per permissions in real use *@
@inject IAiAssistantService AiAssistantService
@inject IJobService JobService
@inject IQuoteService QuoteService
@inject IInventoryService InventoryService
@inject IEmployeeService EmployeeService
@inject ICurrentUserService CurrentUserService
@inject ITenantService TenantService
@inject ICustomerService CustomerService
@inject ToastService ToastService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>AI Copilot</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>✨ AI Copilot</h1>
        <p class="text-muted mb-0">Your intelligent assistant for better bids, lower variance, and smarter operations.</p>
    </div>
    <div>
        @if (AiAssistantService.IsConfigured)
        {
            <span class="badge bg-success">AI Connected</span>
        }
        else
        {
            <span class="badge bg-warning text-dark">AI Not Configured — set Ai:ApiKey</span>
        }
    </div>
</div>

<div class="row">
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header">
                <strong>Quick Actions & Bid Optimizer</strong>
            </div>
            <div class="card-body">
                <button class="btn btn-outline-primary w-100 mb-2" @onclick='() => RunQuickPrompt("Analyze my 3 jobs with the highest variance. Focus on travel and labor costs.")' disabled="@_thinking" data-testid="ai-quick-prompt-variance">
                    Analyze worst variance jobs (travel & labor focus)
                </button>
                <button class="btn btn-outline-primary w-100 mb-2" @onclick='() => RunQuickPrompt("What are realistic ways to reduce travel costs on site jobs in mining areas? Give 4 practical tips with cost impact examples in R.")' disabled="@_thinking" data-testid="ai-quick-prompt-travel">
                    Travel cost reduction ideas for mining sites
                </button>
                <button class="btn btn-outline-primary w-100 mb-2" @onclick='() => RunQuickPrompt("Suggest a complete quote line item structure (incl. travel) for installing a new 11kV/400V transformer at a remote site. Use realistic SA rates and quantities.")' disabled="@_thinking" data-testid="ai-quick-prompt-transformer">
                    Generate transformer install quote template
                </button>
                <button class="btn btn-outline-primary w-100" @onclick='() => RunQuickPrompt("Based on current data, which employee types or skills are over/under utilized? Any recommendations?")' disabled="@_thinking" data-testid="ai-quick-prompt-utilization">
                    Workforce utilization insights
                </button>
                <button class="btn btn-outline-primary w-100 mt-2" @onclick='() => RunQuickPrompt("What-if: if we reduce travel costs by 20% on upcoming jobs, what is the estimated margin impact? Use realistic numbers from data.")' disabled="@_thinking">
                    What-if travel cost reduction impact
                </button>
                <button class="btn btn-outline-primary w-100 mt-2" @onclick='() => RunQuickPrompt("Identify low-stock items and any scheduled/in-progress jobs that could be delayed by material shortages. Include realistic travel or expediting cost impact in R and suggest 2-3 mitigation actions.")' disabled="@_thinking" data-testid="ai-quick-prompt-lowstock">
                    🔮 Low-stock risk for scheduled jobs (travel impact)
                </button>

                <hr />

                <div class="input-group mb-2">
                    <input type="text" class="form-control" placeholder="Enter scope for bid optimization (e.g. '11kV transformer install at mine site')" @bind="bidScope" />
                    <button class="btn btn-outline-primary" @onclick="OptimizeBid" disabled="@_thinking || string.IsNullOrWhiteSpace(bidScope)" data-testid="ai-optimize-bid">Optimize Bid</button>
                </div>
                <small class="text-muted">Uses live data for realistic pricing, labor, travel suggestions.</small>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <strong>Context Loaded</strong>
            </div>
            <div class="card-body small">
                <div>Recent jobs analyzed: <strong>@_recentJobCount</strong></div>
                <div>Active employees: <strong>@_employeeCount</strong></div>
                <div>Low stock items: <strong>@_lowStockCount</strong></div>
                <div class="text-muted mt-1">The co-pilot receives live summaries from your ERP data for accurate, tenant-specific answers.</div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card">
            <div class="card-header bg-dark text-white d-flex align-items-center">
                <span class="me-2">💬 Ask the Copilot</span>
                @if (_thinking)
                {
                    <span class="spinner-border spinner-border-sm text-light" role="status"></span>
                }
            </div>
            <div class="card-body">
                <div class="input-group mb-3">
                    <input type="text" class="form-control" placeholder="Ask anything... e.g. 'How can I improve my quoting accuracy on electrical maintenance contracts?' or 'Why are my travel costs 40% over on the last 5 jobs?'"
                           @bind="userQuestion" @onkeyup="OnQuestionKeyUp" data-testid="ai-prompt-input" />
                    <button class="btn btn-primary" @onclick="AskCopilot" disabled="@(string.IsNullOrWhiteSpace(userQuestion) || _thinking)" data-testid="ai-ask-button">
                        Ask AI
                    </button>
                </div>

                @if (chatHistory.Any())
                  {
                      <div class="mb-3">
                          <div class="d-flex justify-content-between align-items-center mb-1">
                              <h6 class="mb-0">Conversation History</h6>
                              <button class="btn btn-sm btn-outline-primary" @onclick="ExportFullSessionAsPdf" disabled="@(!chatHistory.Any())" data-testid="ai-export-full-pdf">Export full session as PDF</button>
                          </div>
                          <div style="max-height: 200px; overflow-y: auto; font-size: 0.85rem;">
                             @foreach (var entry in chatHistory)
                              {
                                  <div class="border-bottom pb-1 mb-1">
                                      <strong>You:</strong> @entry.Question<br />
                                      <strong>AI:</strong> <span style="white-space: pre-wrap;">@entry.Response</span>
                                      @if (UserCanManage)
                                      {
                                          <div class="mt-1 d-flex gap-1 flex-wrap">
                                              <button class="btn btn-sm btn-success py-0 px-1" style="font-size:0.7rem" @onclick="() => CreateQuoteFromAiText(entry.Response)" data-testid="ai-apply-quote">🚀 Quote</button>
                                              <button class="btn btn-sm btn-outline-success py-0 px-1" style="font-size:0.7rem" @onclick="() => CreateJobFromAiText(entry.Response)" data-testid="ai-apply-job">🚀 Job</button>
                                              <button class="btn btn-sm btn-primary py-0 px-1" style="font-size:0.7rem" @onclick="() => CreateProjectPlanFromAiText(entry.Response)">Plan</button>
                                              <button class="btn btn-sm btn-info py-0 px-1" style="font-size:0.7rem" @onclick="() => ExportSpecificResponseAsPdf(entry.Question, entry.Response)">Text PDF</button>
                                              <button class="btn btn-sm btn-outline-primary py-0 px-1" style="font-size:0.7rem" @onclick="() => ExportResponseAsQuotePdf(entry.Response)">Quote PDF</button>
                                              <button class="btn btn-sm btn-outline-success py-0 px-1" style="font-size:0.7rem" @onclick="() => ExportResponseAsJobPdf(entry.Response)">Job PDF</button>
                                          </div>
                                      }
                                      <div class="mt-1">
                                          <button class="btn btn-sm btn-outline-success py-0 px-1" style="font-size:0.6rem" @onclick="() => GiveFeedback(entry, true)" data-testid="ai-feedback-thumbs-up">👍</button>
                                          <button class="btn btn-sm btn-outline-danger py-0 px-1" style="font-size:0.6rem" @onclick="() => GiveFeedback(entry, false)" data-testid="ai-feedback-thumbs-down">👎</button>
                                      </div>
                                  </div>
                              }
                          </div>
                      </div>
                  }

                @if (!string.IsNullOrWhiteSpace(lastResponse))
                {
                    <div class="border rounded p-3 bg-light">
                        <div class="d-flex justify-content-between mb-2">
                            <strong>Latest AI Response</strong>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="CopyResponse" data-testid="ai-copy-response">Copy</button>
                        </div>
                        <div style="white-space: pre-wrap; font-size: 0.95rem;">@lastResponse</div>

                        @if (UserCanManage)
                        {
                            <div class="mt-2 d-flex gap-2 flex-wrap">
                                <button class="btn btn-sm btn-success" @onclick="() => CreateQuoteFromAiText(lastResponse)" data-testid="ai-create-real-quote">🚀 Create Real Draft Quote</button>
                                <button class="btn btn-sm btn-outline-success" @onclick="() => CreateJobFromAiText(lastResponse)" data-testid="ai-create-real-job">🚀 Create Real Draft Job</button>
                                <button class="btn btn-sm btn-primary" @onclick="() => CreateProjectPlanFromAiText(lastResponse)">🚀 Generate Full Project Plan</button>
                                <button class="btn btn-sm btn-info" @onclick="ExportAiResponseAsReport" data-testid="ai-export-response-pdf">📄 Export as PDF</button>
                                <button class="btn btn-sm btn-outline-primary" @onclick="GenerateDemoQuotePdfFromLastResponse" data-testid="ai-demo-quote-pdf">📄 Demo Quote PDF</button>
                                <button class="btn btn-sm btn-outline-success" @onclick="GenerateDemoJobPdfFromLastResponse" data-testid="ai-demo-job-pdf">📄 Demo Job PDF</button>
                                <button class="btn btn-sm btn-success" @onclick="DownloadRealPdfForLastCreatedQuote">📄 Download real PDF for the Quote you just created</button>
                                <button class="btn btn-sm btn-success" @onclick="DownloadRealPdfForLastCreatedJob">📄 Download real PDF for the Job you just created</button>
                                <button class="btn btn-sm btn-outline-primary" @onclick="GenerateDemoQuotePdfFromLastResponse">📄 Demo Quote PDF (AI scope as notes)</button>
                                <button class="btn btn-sm btn-outline-success" @onclick="GenerateDemoJobPdfFromLastResponse">📄 Demo Job Closeout PDF (AI notes + variance)</button>

                                @if (lastCreatedQuote != null)
                                {
                                    <button class="btn btn-sm btn-success" @onclick="DownloadRealPdfForLastCreatedQuote" data-testid="ai-download-real-quote-pdf">📄 Download real PDF for the Quote you just created</button>
                                }
                                @if (lastCreatedJob != null)
                                {
                                    <button class="btn btn-sm btn-success" @onclick="DownloadRealPdfForLastCreatedJob" data-testid="ai-download-real-job-pdf">📄 Download real PDF for the Job you just created</button>
                                }

@if (lastCreatedQuote != null || lastCreatedJob != null)
{
    <div class="mt-2 p-2 border rounded bg-light">
        <strong class="small">Real professional PDF for the entity created from this AI response (using actual data + AI notes):</strong>
        @if (lastCreatedQuote != null)
        {
            <button class="btn btn-sm btn-success ms-1" @onclick="DownloadRealPdfForLastCreatedQuote" data-testid="ai-download-real-quote-pdf-detail">Quote PDF</button>
        }
        @if (lastCreatedJob != null)
        {
            <button class="btn btn-sm btn-success ms-1" @onclick="DownloadRealPdfForLastCreatedJob" data-testid="ai-download-real-job-pdf-detail">Job Closeout PDF</button>
        }
    </div>
}
                            </div>
                            <span class="text-muted small d-block mt-1">Creates live records in the system from the AI response. The future of contracting ops.</span>
                        }
                    </div>
                }
                else if (_thinking)
                {
                    <p class="text-muted"><em>The AI co-pilot is thinking with your live ERP data...</em></p>
                }
                else
                {
                    <div class="text-muted small">
                        Try one of the quick actions on the left, or type your own question. The more specific (customer type, job category, recent issues), the better the answer.
                    </div>
                }
            </div>
        </div>

        <div class="mt-3 text-muted small">
            <strong>Pro tip:</strong> The co-pilot sees real data (recent jobs, costs including travel, employees, inventory health). Answers are tailored to your actual operations — not generic advice.
            Configure your preferred model (Grok, GPT-4o, local Llama, etc.) in <code>Ai:Model</code> + key.
        </div>
    </div>
</div>

@code {
    private string userQuestion = "";
    private string? lastResponse;
    private bool _thinking;

    // Real created entities for immediate professional PDF download after AI creation
    private Quote? lastCreatedQuote;
    private Job? lastCreatedJob;
    private string? lastAiTextForPdf;

    private int _recentJobCount;
    private int _employeeCount;
    private int _lowStockCount;
    private List<Customer> availableCustomers = new();
    private List<(string Question, string Response)> chatHistory = new();
    private string bidScope = "";

    private bool UserCanManage => CurrentUserService.Permissions.Contains(Permissions.JobsManage) || CurrentUserService.Permissions.Contains(Permissions.QuotesManage);

    // Real feature flag enforcement (sellable tiers)
    private bool AiEnabled
    {
        get
        {
            try
            {
                // Simple sync check; full async load happens in service too
                // For demo we assume enabled unless tenant explicitly lacks it (service will block calls)
                return true; // UI always shows; service enforces HasFeature("ai")
            }
            catch { return true; }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Load lightweight context for the copilot
        try
        {
            var jobs = await JobService.GetAllAsync(null, 1, 20);
            _recentJobCount = jobs.Count;

            var employees = await EmployeeService.GetAllAsync(null, 1, 100);
            _employeeCount = employees.Count;

            var items = await InventoryService.GetAllItemsAsync(null, true, 1, 50); // low stock only
            _lowStockCount = items.Count;

            availableCustomers = (await CustomerService.GetAllAsync(null, 1, 1000)).ToList();
        }
        catch { /* non-critical for copilot */ }

        // Persist chat history across sessions (localStorage demo; per-tenant DB in real)
        try
        {
            var saved = await JS.InvokeAsync<string>("localStorage.getItem", "aiChatHistory");
            if (!string.IsNullOrWhiteSpace(saved))
            {
                chatHistory = System.Text.Json.JsonSerializer.Deserialize<List<(string Question, string Response)>>(saved) ?? new();
            }
        }
        catch { }

        // Consume pending scope from Opportunities (or other CRM) for seamless AI handoff
        try
        {
            var pendingScope = await JS.InvokeAsync<string>("localStorage.getItem", "pendingAiScope");
            if (!string.IsNullOrWhiteSpace(pendingScope))
            {
                bidScope = pendingScope;
                // Auto-optimize bid with the opportunity scope for great demo flow
                _ = Task.Run(async () => await OptimizeBid());
                await JS.InvokeVoidAsync("localStorage.removeItem", "pendingAiScope");
            }
        }
        catch { }
    }

    private async Task SaveChatHistory()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(chatHistory);
            await JS.InvokeVoidAsync("localStorage.setItem", "aiChatHistory", json);
        }
        catch { }
    }

    private async Task OnQuestionKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(userQuestion))
        {
            await AskCopilot();
        }
    }

    private async Task AskCopilot()
    {
        if (string.IsNullOrWhiteSpace(userQuestion)) return;

        _thinking = true;
        lastResponse = null;
        StateHasChanged();

        try
        {
            // Gather rich context
            string context = await BuildRichContextAsync();

            var result = await AiAssistantService.AskCopilotAsync(userQuestion, context);
            lastResponse = result ?? "The AI did not return a response. Please refine your question or check configuration.";
            chatHistory.Add((userQuestion, lastResponse));
            await SaveChatHistory();
        }
        catch (Exception ex)
        {
            lastResponse = $"Error talking to AI: {ex.Message}";
            ToastService.ShowError("AI query failed. See console for details.");
        }
        finally
        {
            _thinking = false;
            StateHasChanged();
        }
    }

    private async Task<string> BuildRichContextAsync()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Current tenant ERP snapshot:");

        try
        {
            var recentJobs = await JobService.GetAllAsync(null, 1, 5);
            sb.AppendLine($"- Recent jobs: {recentJobs.Count} (latest variance examples available in analysis)");
            
            var lowStock = await InventoryService.GetAllItemsAsync(null, true, 1, 10);
            if (lowStock.Any())
                sb.AppendLine($"- Low stock items: {string.Join(", ", lowStock.Take(5).Select(i => i.Sku))}");

            var employees = await EmployeeService.GetAllAsync(null, 1, 10);
            sb.AppendLine($"- Active employees in system: {employees.Count}");
        }
        catch { }

        sb.AppendLine("Focus answers on practical South African contracting realities (travel, site access, skills, VAT, Rand costing).");
        return sb.ToString();
    }

    private async Task RunQuickPrompt(string prompt)
    {
        userQuestion = prompt;
        await AskCopilot();
    }

    private async Task CopyResponse()
    {
        if (!string.IsNullOrWhiteSpace(lastResponse))
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", lastResponse);
            ToastService.ShowSuccess("Response copied to clipboard.");
        }
    }

    private void UseResponseForNewQuote()
    {
        if (string.IsNullOrWhiteSpace(lastResponse)) return;

        ToastService.ShowSuccess("AI response ready — go to Quotes to create a new quote using this as scope/notes.");
    }

    private async Task CreateQuoteFromResponse()
    {
        if (string.IsNullOrWhiteSpace(lastResponse)) return;

        try
        {
            var newQuote = new Quote
            {
                QuoteDate = DateTime.UtcNow,
                ValidUntil = DateTime.UtcNow.AddDays(30),
                TaxRate = 0.15m,
                Notes = "AI Generated: " + lastResponse,
                CustomerId = availableCustomers.FirstOrDefault()?.Id ?? Guid.Empty
            };

            var createdId = await QuoteService.CreateAsync(newQuote);
            var createdQuote = await QuoteService.GetByIdAsync(createdId);

            lastCreatedQuote = createdQuote;
            lastAiTextForPdf = lastResponse;

            ToastService.ShowSuccess("Draft Quote created from AI response!");
            // Do not auto-navigate — give user chance to download the real professional PDF first.
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Failed to create Quote from AI: " + ex.Message + " (check if customer is selected in real use)");
        }
    }

    private async Task CreateJobFromResponse()
    {
        if (string.IsNullOrWhiteSpace(lastResponse)) return;

        try
        {
            var newJob = new Job
            {
                Title = "AI Generated Job",
                Description = "Created from AI Copilot response",
                Notes = "AI Generated: " + lastResponse,
                Status = JobStatus.Scheduled,
                QuotedTotal = 0
                // Other fields like CustomerId can be set in UI
            };

            var createdId = await JobService.CreateAsync(newJob);
            var createdJob = await JobService.GetByIdAsync(createdId);

            lastCreatedJob = createdJob;
            lastAiTextForPdf = lastResponse;

            ToastService.ShowSuccess("Draft Job created from AI response!");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Failed to create Job from AI: " + ex.Message);
        }
    }

    private async Task CreateProjectPlanFromResponse()
    {
        if (string.IsNullOrWhiteSpace(lastResponse)) return;

        try
        {
            var newQuote = new Quote
            {
                QuoteDate = DateTime.UtcNow,
                ValidUntil = DateTime.UtcNow.AddDays(30),
                TaxRate = 0.15m,
                Notes = "AI Project Plan - Quote: " + lastResponse,
                CustomerId = availableCustomers.FirstOrDefault()?.Id ?? Guid.Empty
            };
            await QuoteService.CreateAsync(newQuote);

            var newJob = new Job
            {
                Title = "AI Project Plan - Job",
                Description = "Linked to AI generated plan",
                Notes = "AI Generated Project Plan: " + lastResponse + "\n\nLinked Quote created.",
                Status = JobStatus.Scheduled,
                QuotedTotal = 0
            };
            await JobService.CreateAsync(newJob);

            ToastService.ShowSuccess("Full Project Plan created: Quote + Job skeleton! Check /quotes and /jobs.");
            Navigation.NavigateTo("/ai-copilot");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Failed to create Project Plan from AI: " + ex.Message);
        }
    }

    private async Task ExportAiResponseAsReport()
    {
        // Export the most recent response (or last in chatHistory) as a professional single-item PDF
        string q = userQuestion;
        string a = lastResponse ?? string.Empty;

        if (chatHistory.Any())
        {
            var last = chatHistory.Last();
            q = last.Question;
            a = last.Response;
        }

        if (string.IsNullOrWhiteSpace(a)) return;

        try
        {
            var bytes = METERP.Web.Reports.AiReportGenerator.GenerateSingleResponseReport(q, a);
            var b64 = Convert.ToBase64String(bytes);
            var dataUrl = $"data:application/pdf;base64,{b64}";
            var fileName = $"METERP_AI_Response_{DateTime.UtcNow:yyyyMMdd_HHmm}.pdf";
            await JS.InvokeVoidAsync("eval", $"const a = document.createElement('a'); a.href = '{dataUrl}'; a.download = '{fileName}'; document.body.appendChild(a); a.click(); document.body.removeChild(a);");
            ToastService.ShowSuccess("Professional AI PDF report downloaded.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("PDF generation failed: " + ex.Message + " (is QuestPDF package restored?)");
        }
    }

    private async Task ExportFullSessionAsPdf()
    {
        if (chatHistory == null || !chatHistory.Any())
        {
            ToastService.ShowInfo("No conversation history yet to export.");
            return;
        }

        try
        {
            var bytes = METERP.Web.Reports.AiReportGenerator.GenerateCopilotSessionReport(
                "Full AI Copilot Session",
                chatHistory,
                extraFooterNote: "This session may include Bid Optimizer results, variance analysis, travel cost recommendations, and project plan suggestions.");

            var b64 = Convert.ToBase64String(bytes);
            var dataUrl = $"data:application/pdf;base64,{b64}";
            var fileName = $"METERP_AI_FullSession_{DateTime.UtcNow:yyyyMMdd_HHmm}.pdf";
            await JS.InvokeVoidAsync("eval", $"const a = document.createElement('a'); a.href = '{dataUrl}'; a.download = '{fileName}'; document.body.appendChild(a); a.click(); document.body.removeChild(a);");
            ToastService.ShowSuccess("Full session exported as branded PDF (ready for client or internal use).");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Full session PDF failed: " + ex.Message);
        }
    }

    private async Task OptimizeBid()
    {
        if (string.IsNullOrWhiteSpace(bidScope)) return;
        await RunQuickPrompt($"Optimize bid for: {bidScope}. Suggest realistic pricing, labor hours, travel, materials using current market and historical data from the system. Include total estimate and margin tips.");
        bidScope = "";
    }

    // --- Per-specific-response Apply helpers (history entries + Latest card are directly actionable) ---

    private async Task CreateQuoteFromAiText(string? aiText)
    {
        var text = string.IsNullOrWhiteSpace(aiText) ? lastResponse : aiText;
        if (string.IsNullOrWhiteSpace(text)) return;

        try
        {
            var customerId = availableCustomers.FirstOrDefault()?.Id ?? Guid.Empty;

            var newQuote = new Quote
            {
                QuoteDate = DateTime.UtcNow,
                ValidUntil = DateTime.UtcNow.AddDays(30),
                TaxRate = 0.15m,
                Notes = "AI Generated: " + text,
                CustomerId = customerId
            };
            var createdId = await QuoteService.CreateAsync(newQuote);

            // Smart apply: try to get structured line suggestions and add real lines (travel + materials)
            try
            {
                var suggestion = await AiAssistantService.SuggestQuoteLinesAsync(text, 0.15m, null);
                if (suggestion?.SuggestedLines?.Any() == true)
                {
                    foreach (var s in suggestion.SuggestedLines.Take(6))
                    {
                        await QuoteService.AddLineAsync(new QuoteLine
                        {
                            QuoteId = createdId,
                            Description = s.Description,
                            Quantity = s.Quantity,
                            UnitPrice = s.UnitPrice,
                            Unit = s.Unit,
                            LineType = s.LineType
                            // LineTotal now computed automatically
                        });
                    }
                }
                else
                {
                    // Fallback: ensure at least one explicit travel line for contracting realism
                    await QuoteService.AddLineAsync(new QuoteLine
                    {
                        QuoteId = createdId,
                        Description = "Travel & site transport (AI estimate)",
                        Quantity = 1,
                        UnitPrice = 650,
                        LineType = "Other",
                        Unit = "lot"
                    });
                }
            }
            catch { /* non-fatal - quote still created */ }

            lastCreatedQuote = await QuoteService.GetByIdAsync(createdId);
            lastAiTextForPdf = text;
            ToastService.ShowSuccess("Draft Quote created with AI-suggested lines! See /quotes.");
            Navigation.NavigateTo("/quotes");
        }
        catch (Exception ex)
        {
            ToastService.ShowError("Failed to create Quote from AI: " + ex.Message);
        }
    }

    private async Task CreateJobFromAiText(string? aiText)
    {
        var text = string.IsNullOrWhiteSpace(aiText) ? lastResponse : aiText;
        if (string.IsNullOrWhiteSpace(text)) return;

        try
        {
            var newJob = new Job
            {
                Title = "AI Generated Job",
                Description = "Created from AI Copilot response",
                Notes = "AI Generated: " + text,
                Status = JobStatus.Scheduled,
                QuotedTotal = 0
            };
            var createdId = await JobService.CreateAsync(newJob);
            lastCreatedJob = await JobService.GetByIdAsync(createdId);
            lastAiTextForPdf = text;
            ToastService.ShowSuccess("Draft Job created from this AI response! See /jobs.");
            Navigation.NavigateTo("/jobs");
        }
        catch (Exception ex)
        {
