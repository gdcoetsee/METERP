@page "/opportunities"
@using METERP.Application.Services
@using METERP.Domain
@using METERP.Common
@using Microsoft.AspNetCore.Authorization
@using METERP.Application.Interfaces
@inject IOpportunityService OpportunityService
@inject ICustomerService CustomerService
@inject ICurrentUserService CurrentUserService
@inject ToastService ToastService
@inject NavigationManager Nav
@inject IJSRuntime JS
@attribute [Authorize(Policy = "Opportunities.View")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Opportunities (CRM)</PageTitle>

@if (_ready)
{
    <span data-testid="opportunities-ready" class="visually-hidden">ready</span>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Opportunities <span class="badge bg-info">CRM Pipeline</span></h1>
        <p class="text-muted mb-0">Track leads, convert to AI-powered quotes. Full tenant-isolated CRM.</p>
    </div>
    @if (CanManage)
    {
        <button class="btn btn-primary" data-testid="opportunity-create-button" @onclick="ShowCreate">+ New Opportunity</button>
    }
</div>

<div class="mb-3" style="max-width: 420px;">
    <div class="input-group">
        <input type="search" class="form-control" placeholder="Search opportunity..."
               data-testid="opportunity-search" value="@searchTerm" @oninput="OnSearch" />
        @if (!string.IsNullOrEmpty(searchTerm))
        {
            <button class="btn btn-outline-secondary" @onclick="ClearSearch">Clear</button>
        }
    </div>
</div>

@if (_loading)
{
    <p data-testid="opportunities-loading"><em>Loading opportunities...</em></p>
}
else
{
<div class="row g-3 mb-4" data-testid="opportunities-pipeline">
    @foreach (var stage in stages)
    {
        <div class="col-md-4 col-lg-2">
            <div class="card h-100">
                <div class="card-header bg-light py-2">
                    <strong class="small">@StageLabel(stage)</strong>
                    <span class="badge bg-secondary">@GetCount(stage)</span>
                </div>
                <div class="card-body p-2">
                    @foreach (var opp in GetByStage(stage))
                    {
                        <div class="card mb-2 shadow-sm" style="cursor:pointer;"
                             data-testid="@(opp.CustomerId.HasValue && opp.CustomerId != Guid.Empty ? "opportunity-card-with-customer" : "opportunity-card")"
                             @onclick="() => ViewOpp(opp)">
                            <div class="card-body p-2 small">
                                <strong>@opp.Title</strong><br />
                                <span class="text-muted">@DisplayCustomer(opp)</span><br />
                                <span class="text-success">R @opp.Value.ToString("N0")</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>
}

@if (showCreate && CanManage)
{
    <div class="card mb-4 border-primary" data-testid="opportunity-create-form">
        <div class="card-header bg-primary text-white">New Opportunity</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Title</label>
                    <input class="form-control" data-testid="opportunity-title" @bind="newOpp.Title" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Customer</label>
                    <select class="form-select" @bind="selectedCustomerId">
                        <option value="">— New / unlinked —</option>
                        @foreach (var c in customers)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
                @if (selectedCustomerId == Guid.Empty)
                {
                    <div class="col-md-6">
                        <label class="form-label">Customer name (if not linked)</label>
                        <input class="form-control" @bind="newOpp.CustomerName" />
                    </div>
                }
                <div class="col-md-4">
                    <label class="form-label">Value (R)</label>
                    <input type="number" class="form-control" @bind="newOpp.Value" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Stage</label>
                    <select class="form-select" @bind="newOpp.Stage">
                        @foreach (var s in stages) { <option value="@s">@StageLabel(s)</option> }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Expected Close</label>
                    <input type="date" class="form-control" @bind="newOpp.ExpectedClose" />
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-success" data-testid="opportunity-save" @onclick="CreateOpp">Create</button>
                <button class="btn btn-secondary ms-2" @onclick="CancelCreate">Cancel</button>
            </div>
        </div>
    </div>
}

@if (selectedOpp != null)
{
    <div class="card mt-4 border-primary" data-testid="opportunity-detail">
        <div class="card-header bg-primary text-white d-flex justify-content-between">
            <h5 class="mb-0">@selectedOpp.Title</h5>
            <button class="btn btn-sm btn-light" @onclick="CloseView">Close</button>
        </div>
        <div class="card-body">
            <p><strong>Customer:</strong> @DisplayCustomer(selectedOpp)</p>
            <p><strong>Value:</strong> R @selectedOpp.Value.ToString("N0")</p>
            <p data-testid="opportunity-stage"><strong>Stage:</strong> @StageLabel(selectedOpp.Stage)</p>
            <p><strong>Expected Close:</strong> @selectedOpp.ExpectedClose.ToString("yyyy-MM-dd")</p>
            <div class="mt-3">
                <button class="btn btn-primary btn-sm me-2" data-testid="opportunity-convert-manual"
                        @onclick="ConvertToManualQuote">Create Manual Quote</button>
                <button class="btn btn-outline-success btn-sm me-2" data-testid="opportunity-convert-ai"
                        @onclick="ConvertToQuote">Create with AI Copilot</button>
                @if (CanManage)
                {
                    <button class="btn btn-outline-secondary btn-sm" data-testid="opportunity-advance-stage"
                            @onclick="UpdateStage">Advance Stage</button>
                }
            </div>
        </div>
    </div>
}

@code {
    private List<Opportunity> opportunities = new();
    private List<Opportunity> filtered = new();
    private List<Customer> customers = new();
    private string searchTerm = "";
    private Opportunity? selectedOpp;
    private bool showCreate;
    private Opportunity newOpp = new();
    private Guid selectedCustomerId = Guid.Empty;

    private bool _ready;
    private bool _loading = true;
    private readonly ComponentAsyncGate _dataGate = new();
    private bool CanManage => CurrentUserService.Permissions.Contains(Permissions.OpportunitiesManage);

    private static readonly OpportunityStage[] stages =
    {
        OpportunityStage.Lead,
        OpportunityStage.Qualified,
        OpportunityStage.Proposal,
        OpportunityStage.Negotiation,
        OpportunityStage.ClosedWon,
        OpportunityStage.ClosedLost
    };

    protected override async Task OnInitializedAsync() => await _dataGate.RunAsync(async () =>
    {
        _loading = true;
        try
        {
            opportunities = (await OpportunityService.GetAllAsync()).ToList();
            customers = (await CustomerService.GetAllAsync(pageSize: 200)).ToList();
            filtered = opportunities;
            _ready = true;
        }
        finally
        {
            _loading = false;
        }
    });

    private static string StageLabel(OpportunityStage stage) => stage switch
    {
        OpportunityStage.Lead => "Lead",
        OpportunityStage.Qualified => "Qualified",
        OpportunityStage.Proposal => "Proposal",
        OpportunityStage.Negotiation => "Negotiation",
        OpportunityStage.ClosedWon => "Closed Won",
        OpportunityStage.ClosedLost => "Closed Lost",
        _ => stage.ToString()
    };

    private string DisplayCustomer(Opportunity opp) =>
        opp.Customer?.Name ?? opp.CustomerName ?? "—";

    private int GetCount(OpportunityStage stage) => opportunities.Count(o => o.Stage == stage);

    private List<Opportunity> GetByStage(OpportunityStage stage) =>
        filtered.Where(o => o.Stage == stage).ToList();

    private void OnSearch(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        Filter();
    }

    private void ClearSearch()
    {
        searchTerm = "";
        Filter();
    }

    private void Filter()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
            filtered = opportunities;
        else
        {
            var t = searchTerm.ToLower();
            filtered = opportunities.Where(o =>
                o.Title.ToLower().Contains(t) ||
                (o.CustomerName != null && o.CustomerName.ToLower().Contains(t)) ||
                (o.Customer != null && o.Customer.Name.ToLower().Contains(t))).ToList();
        }
    }

    private void ShowCreate()
    {
        newOpp = new Opportunity { Stage = OpportunityStage.Lead, ExpectedClose = DateTime.UtcNow.AddDays(30) };
        selectedCustomerId = Guid.Empty;
        showCreate = true;
        selectedOpp = null;
    }

    private async Task CreateOpp()
    {
        if (string.IsNullOrWhiteSpace(newOpp.Title)) return;
        if (selectedCustomerId != Guid.Empty)
            newOpp.CustomerId = selectedCustomerId;

        await OpportunityService.CreateAsync(newOpp);
        await _dataGate.RunAsync(async () =>
        {
            opportunities = (await OpportunityService.GetAllAsync()).ToList();
            Filter();
        });
        showCreate = false;
        ToastService.ShowSuccess("Opportunity created.");
    }

    private void CancelCreate() => showCreate = false;

    private void ViewOpp(Opportunity o)
    {
        selectedOpp = o;
        showCreate = false;
    }

    private void CloseView() => selectedOpp = null;

    private void ConvertToManualQuote()
    {
        if (selectedOpp == null) return;
        var scope = OpportunityService.BuildAiScopeText(selectedOpp);
        var notes = Uri.EscapeDataString(scope);
        ToastService.ShowSuccess($"Opening quote form for {selectedOpp.Title}.");
        // forceLoad ensures Quotes OnInitializedAsync re-runs and HandleCreateQuery opens the editor.
        Nav.NavigateTo($"/quotes?create=1&customerId={selectedOpp.CustomerId}&notes={notes}", forceLoad: true);
    }

    private async Task ConvertToQuote()
    {
        if (selectedOpp == null) return;
        var scope = OpportunityService.BuildAiScopeText(selectedOpp);
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "pendingAiScope", scope);
            await JS.InvokeVoidAsync("localStorage.setItem", "pendingOpportunityId", selectedOpp.Id.ToString());
        }
        catch { }

        ToastService.ShowSuccess($"Opening AI Copilot with scope for {selectedOpp.Title}.");
        Nav.NavigateTo("/ai-copilot");
    }

    private async Task UpdateStage()
    {
        if (selectedOpp == null) return;
        await OpportunityService.AdvanceStageAsync(selectedOpp.Id);
        selectedOpp = await OpportunityService.GetByIdAsync(selectedOpp.Id);
        opportunities = (await OpportunityService.GetAllAsync()).ToList();
        Filter();
        ToastService.ShowSuccess($"Stage advanced to {StageLabel(selectedOpp!.Stage)}.");
    }
}