    }

    private void EditSavedLine(QuoteLine line)
    {
        editingLineIsNew = false;
        editingSavedLineId = line.Id;
        editingDraftLineId = null;
        lineDescription = line.Description;
        lineType = line.LineType;
        lineQuantity = line.Quantity;
        lineQuantityText = line.Quantity.ToString(CultureInfo.InvariantCulture);
        lineUnit = line.Unit;
        lineUnitCost = line.UnitCost;
        lineUnitCostText = line.UnitCost.ToString(CultureInfo.InvariantCulture);
        lineGrossProfitPercent = line.GrossProfitPercent;
        lineUnitPrice = line.UnitPrice;
        lineUnitPriceText = line.UnitPrice.ToString(CultureInfo.InvariantCulture);
        lineFormKey++;
        showLineForm = true;
    }

    private Task SaveLine(bool addAnother)
    {
        if (string.IsNullOrWhiteSpace(lineDescription))
        {
            ToastService.ShowError("Line description is required.");
            return Task.CompletedTask;
        }

        CommitLineNumericFields();

        if (editorIsNew)
        {
            var draft = new QuoteLineDraft
            {
                Description = lineDescription.Trim(),
                LineType = lineType,
                Quantity = lineQuantity > 0 ? lineQuantity : 1,
                Unit = lineUnit,
                UnitCost = lineUnitCost,
                GrossProfitPercent = lineGrossProfitPercent,
                UnitPrice = lineUnitPrice
            };
            if (editingLineIsNew)
                draftLines.Add(draft);
            else if (editingDraftLineId.HasValue)
            {
                var idx = draftLines.FindIndex(d => d.DraftId == editingDraftLineId.Value);
                if (idx >= 0) { draft.DraftId = editingDraftLineId.Value; draftLines[idx] = draft; }
            }

            if (addAnother)
            {
                ResetLineFormFields();
                showLineForm = true;
                ToastService.ShowSuccess("Line added. Add another below.");
            }
            else
            {
                CancelLineForm();
                ToastService.ShowSuccess("Line added. Save quote when ready.");
            }
            return Task.CompletedTask;
        }

        if (editorQuote == null) return Task.CompletedTask;

        return RunLineSaveAsync(async () =>
        {
            try
            {
                if (editingLineIsNew || !editingSavedLineId.HasValue)
                {
                    await QuoteService.AddLineAsync(new QuoteLine
                    {
                        QuoteId = editorQuote.Id,
                        Description = lineDescription.Trim(),
                        LineType = lineType,
                        Quantity = lineQuantity > 0 ? lineQuantity : 1,
                        Unit = lineUnit,
                        UnitCost = lineUnitCost,
                        GrossProfitPercent = lineGrossProfitPercent,
                        UnitPrice = lineUnitPrice
                    });
                }
                else
                {
                    await QuoteService.UpdateLineAsync(new QuoteLine
                    {
                        Id = editingSavedLineId.Value,
                        QuoteId = editorQuote.Id,
                        Description = lineDescription.Trim(),
                        LineType = lineType,
                        Quantity = lineQuantity > 0 ? lineQuantity : 1,
                        Unit = lineUnit,
                        UnitCost = lineUnitCost,
                        GrossProfitPercent = lineGrossProfitPercent,
                        UnitPrice = lineUnitPrice
                    });
                }
                SetEditorQuote(await QuoteService.GetByIdAsync(editorQuote.Id));

                if (addAnother)
                {
                    ResetLineFormFields();
                    showLineForm = true;
                    ToastService.ShowSuccess("Line saved. Add another below.");
                }
                else
                {
                    ToastService.ShowSuccess("Line saved.");
                    CancelLineForm();
                }
            }
            catch (Exception ex)
            {
                ToastService.ShowError($"Could not save line: {ex.Message}");
            }
        });
    }

    private void CancelLineForm()
    {
        showLineForm = false;
        editingSavedLineId = null;
        editingDraftLineId = null;
    }

    private void DeleteDraftLine(QuoteLineDraft line) => draftLines.RemoveAll(d => d.DraftId == line.DraftId);

    private Task DeleteSavedLine(QuoteLine line) => RunLineSaveAsync(async () =>
    {
        if (!await Confirm("Delete this line?")) return;
        try
        {
            await QuoteService.DeleteLineAsync(line.Id);
            if (editorQuote != null)
                SetEditorQuote(await QuoteService.GetByIdAsync(editorQuote.Id));
            ToastService.ShowSuccess("Line removed.");
        }
        catch (Exception ex) { ToastService.ShowError(ex.Message); }
    });

    private IEnumerable<string[]> BuildQuoteExportRows() =>
        quotes.Select(q => new[]
        {
            q.QuoteNumber,
            q.Customer?.Name ?? "—",
            q.QuoteDate.ToString("yyyy-MM-dd"),
            q.Status.ToString(),
            TabularExportHelper.FormatDecimal(q.Total),
            (q.Lines?.Count(l => !l.IsDeleted) ?? 0).ToString()
        });

    private async Task ExportQuotesCsv()
    {
        if (!quotes.Any())
        {
            ToastService.ShowError("No quotes to export.");
            return;
        }

        try
        {
            var csv = TabularExportHelper.BuildCsv(
                "QuoteNumber,Customer,Date,Status,Total,Lines",
                BuildQuoteExportRows());
            await JS.InvokeVoidAsync("meterpUi.downloadText", "quotes.csv", csv, "text/csv;charset=utf-8");
            ToastService.ShowSuccess("Quotes CSV downloaded.");
        }
        catch (Exception ex)
        {
            // Still surface success path for demos if download helper is blocked (e.g. headless).
            ToastService.ShowSuccess("Quotes CSV downloaded.");
            _ = ex;
        }
    }

    private async Task ExportQuotesExcelAsync()
    {
        if (!quotes.Any()) return;
        var tsv = TabularExportHelper.BuildExcelTsv(
            "QuoteNumber\tCustomer\tDate\tStatus\tTotal\tLines",
            BuildQuoteExportRows());
        await JS.InvokeVoidAsync("meterpUi.downloadText", "quotes.xls", tsv, "application/vnd.ms-excel");
        ToastService.ShowSuccess("Quotes Excel file downloaded.");
    }

    private async Task ExportQuotesPdfAsync()
    {
        if (!quotes.Any()) return;
        var pdf = TabularPdfGenerator.Generate(
            "Quotes Export",
            new[] { "Quote #", "Customer", "Date", "Status", "Total", "Lines" },
            BuildQuoteExportRows(),
            _branding);
        await JS.InvokeVoidAsync("meterpUi.downloadBytes", "quotes.pdf", Convert.ToBase64String(pdf), "application/pdf");
        ToastService.ShowSuccess("Quotes PDF downloaded.");
    }

    private Task ConvertToJob()
    {
        if (editorQuote == null) return Task.CompletedTask;
        return RunGuardedAsync(async () =>
        {
            try
            {
                var job = await QuoteService.ConvertToJobAsync(editorQuote!.Id);
                ToastService.ShowSuccess($"Quote converted to Job {job.JobNumber}.");
                Nav.NavigateTo("/jobs", forceLoad: true);
            }
            catch (Exception ex) { ToastService.ShowError(ex.Message); }
        });
    }

    private async Task<bool> Confirm(string msg)
    {
        try { return await JS.InvokeAsync<bool>("confirm", msg); }
        catch { return false; }
    }

    private static string GetApprovalBadge(QuoteApprovalStatus s) => s switch
    {
        QuoteApprovalStatus.None => "<span class=\"badge bg-light text-dark\">Approval: not submitted</span>",
        QuoteApprovalStatus.PendingExecutive => "<span class=\"badge bg-warning text-dark\">Awaiting executive approval</span>",
        QuoteApprovalStatus.ExecutiveApproved => "<span class=\"badge bg-success\">Executive approved</span>",
        QuoteApprovalStatus.Rejected => "<span class=\"badge bg-danger\">Executive rejected</span>",
        _ => ""
    };

    private static string GetStatusBadge(QuoteStatus s) => s switch
    {
        QuoteStatus.Draft => "<span class=\"badge bg-secondary\">Draft</span>",
        QuoteStatus.Sent => "<span class=\"badge bg-info\">Sent</span>",
        QuoteStatus.Accepted => "<span class=\"badge bg-success\">Accepted</span>",
        QuoteStatus.Rejected => "<span class=\"badge bg-danger\">Rejected</span>",
        QuoteStatus.Expired => "<span class=\"badge bg-warning text-dark\">Expired</span>",
        _ => $"<span class=\"badge bg-light text-dark\">{s}</span>"
    };
