@page "/quotes"
@using METERP.Application.Services
@using METERP.Application.Interfaces
@using METERP.Domain
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@attribute [Authorize(Policy = "Quotes.View")]
@inject IQuoteService QuoteService
@inject IJobService JobService
@inject ICurrentUserService CurrentUserService
@inject ToastService ToastService
@inject NavigationManager Nav
@inject IJSRuntime JS
@using METERP.Common

<PageTitle>Quotes</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Quotes <span class="badge bg-primary ai-badge">AI-Powered</span></h1>
        <p class="text-muted mb-0">Professional quotes with labor, materials, explicit travel. 15% SA VAT.</p>
    </div>
    <a href="/ai-copilot" class="btn btn-success" data-testid="create-with-ai-copilot">✨ Create with AI Copilot</a>
</div>

<div class="mb-3" style="max-width: 480px;">
    <div class="input-group">
        <input type="search" class="form-control" placeholder="Search quote #, customer or notes..."
               value="@searchTerm" @oninput="OnSearchInput" />
        @if (!string.IsNullOrEmpty(searchTerm))
        {
            <button class="btn btn-outline-secondary" @onclick="ClearSearch">Clear</button>
        }
    </div>
</div>

<QuoteList
    Quotes="quotes"
    SelectedQuote="selectedQuote"
    CanManage="UserCanManage"
    CurrentPage="currentPage"
    DisablePrevious="@(currentPage <= 1)"
    DisableNext="@(quotes != null && quotes.Count < PageSize)"
    OnView="ViewQuote"
    OnDelete="DeleteQuote"
    OnPrevious="PreviousPage"
    OnNext="NextPage"
    OnExportCsv="ExportQuotesCsv"
    OnConvert="ConvertToJob"
    OnCloseView="CloseQuoteView" />

@code {
    private List<Quote> quotes = new();
    private Quote? selectedQuote;
    private string searchTerm = string.Empty;
    private int currentPage = 1;
    private const int PageSize = 10;

    private bool UserCanManage => CurrentUserService.Permissions.Contains(Permissions.QuotesManage);

    protected override async Task OnInitializedAsync()
    {
        await LoadQuotes();
    }

    private async Task LoadQuotes()
    {
        quotes = (await QuoteService.GetAllAsync(
            string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm,
            currentPage,
            PageSize)).ToList();
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        currentPage = 1;
        await LoadQuotes();
    }

    private async Task ClearSearch()
    {
        searchTerm = string.Empty;
        currentPage = 1;
        await LoadQuotes();
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadQuotes();
        }
    }

    private async Task NextPage()
    {
        currentPage++;
        await LoadQuotes();
    }

    private async Task ViewQuote(Quote q)
    {
        selectedQuote = await QuoteService.GetByIdAsync(q.Id);
    }

    private void CloseQuoteView() => selectedQuote = null;

    private async Task DeleteQuote(Quote q)
    {
        bool ok;
        try { ok = await JS.InvokeAsync<bool>("confirm", $"Delete quote {q.QuoteNumber}?"); } catch { ok = false; }
        if (!ok) return;
        await QuoteService.DeleteAsync(q.Id);
        if (selectedQuote?.Id == q.Id) selectedQuote = null;
        await LoadQuotes();
        ToastService.ShowSuccess("Quote deleted.");
    }

    private async Task ExportQuotesCsv()
    {
        if (quotes == null || !quotes.Any()) return;
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("QuoteNumber,Customer,Status,Total,Lines");
        foreach (var q in quotes)
        {
            sb.AppendLine($"{q.QuoteNumber},\"{q.Customer?.Name}\",{q.Status},{q.Total},{q.Lines?.Count(l => !l.IsDeleted) ?? 0}");
        }
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", sb.ToString());
        ToastService.ShowSuccess("Quotes CSV copied to clipboard.");
    }

    private async Task ConvertToJob(Quote q)
    {
        try
        {
            var job = await QuoteService.ConvertToJobAsync(q.Id);
            ToastService.ShowSuccess($"Quote converted to Job {job.JobNumber}.");
            Nav.NavigateTo("/jobs");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Conversion failed: {ex.Message}");
        }
    }
}