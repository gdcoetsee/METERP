@page "/jobs"
@using METERP.Application.Models
@using METERP.Application.Services
@using METERP.Application.Interfaces
@using METERP.Domain
@using METERP.Common
@using METERP.Web.Reports
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "Jobs.View")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IJobService JobService
@inject IInvoiceService InvoiceService
@inject ICustomerService CustomerService
@inject ITenantService TenantService
@inject ICurrentUserService CurrentUserService
@inject ToastService ToastService
@inject IAiAssistantService AiAssistantService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Jobs</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1>Jobs</h1>
        <p class="text-muted mb-0">Operations hub: open a job command center for P&amp;L, requisitions, invoicing (while open), costs, labor, and executive close.</p>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <ExportToolbar TestId="jobs-export" OnExportCsv="ExportJobsCsvAsync" OnExportExcel="ExportJobsExcelAsync" OnExportPdf="ExportJobsPdfAsync" />
        @if (UserCanManage)
        {
            <button type="button" class="btn btn-danger" data-testid="jobs-emergency-create" @onclick="OpenEmergencyModal">+ Emergency job</button>
        }
    </div>
</div>

<div class="mb-3" style="max-width: 420px;">
    <div class="input-group">
        <input type="search" class="form-control" placeholder="Search job #, customer, or notes..."
               @bind="searchTerm" @bind:event="oninput" @bind:after="OnSearchChangedAsync" data-testid="jobs-search" />
        @if (!string.IsNullOrEmpty(searchTerm))
        {
            <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch" title="Clear search">Clear</button>
        }
    </div>
</div>

@if (_initialLoadComplete)
{
    <span data-testid="jobs-ready" class="visually-hidden">ready</span>
}

<h6>Recent / Live Jobs (powered by services)</h6>
@if (!_initialLoadComplete)
{
    <p data-testid="jobs-loading"><em>Loading jobs...</em></p>
}
else
{
<JobList
    Jobs="demoJobs"
    SelectedJob="selectedJob"
    CommandCenter="commandCenter"
    Milestones="jobMilestones"
    Snags="jobSnags"
    SafetyIncidents="jobSafetyIncidents"
    CanManage="UserCanManage"
    CurrentPage="currentPage"
    DisablePrevious="@(currentPage <= 1)"
    DisableNext="@(demoJobs != null && demoJobs.Count < PageSize)"
    OnView="ViewJob"
    OnDelete="DeleteJob"
    OnPrevious="PreviousPage"
    OnNext="NextPage"
    OnExportCsv="ExportJobsCsvAsync"
    OnAiAnalyze="AnalyzeWithAi"
    OnCreateInvoice="CreateInvoiceFromJob"
    OnSignOff="SignOffJobAsync"
    OnAddMilestone="AddMilestoneAsync"
    OnAddSnag="AddSnagAsync"
    OnResolveSnag="ResolveSnagAsync"
    OnAddSafetyIncident="AddSafetyIncidentAsync"
    OnCloseSafetyIncident="CloseSafetyIncidentAsync"
    OnCloseView="CloseJobView" />
}

@if (_showEmergencyModal)
{
    <FormModal IsOpen="true" Title="Emergency / callout job" TestId="jobs-emergency-modal" OnClose="CloseEmergencyModal">
        <p class="small text-muted">Create a job without a quote (job-first). Use for callouts and urgent work — bill deposit from the Command Center.</p>
        <div class="mb-3">
            <label class="form-label">Customer *</label>
            <select class="form-select" @bind="_emergencyCustomerId" data-testid="jobs-emergency-customer">
                <option value="@Guid.Empty">— Select —</option>
                @foreach (var c in _customers)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Title *</label>
            <input class="form-control" @bind="_emergencyTitle" data-testid="jobs-emergency-title" placeholder="e.g. After-hours cable fault" />
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea class="form-control" rows="2" @bind="_emergencyDescription" data-testid="jobs-emergency-description"></textarea>
        </div>
        <div class="row g-2">
            <div class="col-md-4">
                <label class="form-label">Estimate (R)</label>
                <input type="number" min="0" step="0.01" class="form-control" @bind="_emergencyQuoted" data-testid="jobs-emergency-quoted" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Deposit %</label>
                <input type="number" min="0" max="100" step="1" class="form-control" @bind="_emergencyDeposit" data-testid="jobs-emergency-deposit" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Retention %</label>
                <input type="number" min="0" max="100" step="1" class="form-control" @bind="_emergencyRetention" data-testid="jobs-emergency-retention" />
            </div>
        </div>
        <div class="d-flex gap-2 justify-content-end mt-3">
            <button type="button" class="btn btn-secondary" @onclick="CloseEmergencyModal">Cancel</button>
            <button type="button" class="btn btn-danger" data-testid="jobs-emergency-save" @onclick="SaveEmergencyAsync">Create job</button>
        </div>
    </FormModal>
}

@code {
    private List<Job> demoJobs = new();
    private bool _initialLoadComplete;
    private TenantBranding _branding = TenantBranding.Default;
    private Job? selectedJob;
    private JobCommandCenterSummary? commandCenter;
    private List<JobMilestone> jobMilestones = new();
    private List<JobSnagItem> jobSnags = new();
    private List<JobSafetyIncident> jobSafetyIncidents = new();
    private string searchTerm = string.Empty;
    private int currentPage = 1;
    private const int PageSize = 10;
    private readonly ComponentAsyncGate _dataGate = new();

    private bool _showEmergencyModal;
    private List<Customer> _customers = new();
    private Guid _emergencyCustomerId;
    private string _emergencyTitle = "";
    private string _emergencyDescription = "";
    private decimal _emergencyQuoted;
    private decimal _emergencyDeposit = 50m;
    private decimal _emergencyRetention = 0m;

    private bool UserCanManage => CurrentUserService.Permissions.Contains(Permissions.JobsManage);

    [SupplyParameterFromQuery(Name = "job")]
    public Guid? OpenJobId { get; set; }

    /// <summary>Open list detail panel for this job id (stable for E2E deep links).</summary>
    [SupplyParameterFromQuery(Name = "panel")]
    public Guid? PanelJobId { get; set; }

    protected override Task OnInitializedAsync() => _dataGate.RunAsync(async () =>
    {
        if (CurrentUserService.TenantId != Guid.Empty)
        {
            var tenant = await TenantService.GetByIdAsync(CurrentUserService.TenantId);
            _branding = TenantBranding.From(tenant);
        }

        _customers = (await CustomerService.GetAllAsync(pageSize: 200)).ToList();
        await LoadJobsCore();
        _initialLoadComplete = true;

        if (PanelJobId is { } panelId && panelId != Guid.Empty)
        {
            await OpenJobCore(panelId);
            return;
        }

        if (OpenJobId is { } jobId && jobId != Guid.Empty)
            Nav.NavigateTo($"/jobs/{jobId}");
    });

    private void OpenEmergencyModal()
    {
        _emergencyCustomerId = _customers.FirstOrDefault()?.Id ?? Guid.Empty;
        _emergencyTitle = "";
        _emergencyDescription = "";
        _emergencyQuoted = 0;
        _emergencyDeposit = 50m;
        _emergencyRetention = 0m;
        _showEmergencyModal = true;
    }

    private void CloseEmergencyModal() => _showEmergencyModal = false;

    private async Task SaveEmergencyAsync()
    {
        try
        {
            var jobId = await JobService.CreateEmergencyAsync(
                _emergencyCustomerId,
                _emergencyTitle,
                _emergencyDescription,
                _emergencyQuoted,
                _emergencyDeposit,
                _emergencyRetention);
            ToastService.ShowSuccess("Emergency job created — open Command Center to mobilise and bill deposit.");
            CloseEmergencyModal();
            Nav.NavigateTo($"/jobs/{jobId}");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

    private async Task LoadJobs() => await LoadJobsCore();

    private async Task LoadJobsCore()
    {
        var term = string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm.Trim();
        demoJobs = (await JobService.GetAllAsync(term, currentPage, PageSize)).ToList();
    }

    private Task OnSearchChangedAsync() => _dataGate.RunAsync(async () =>
    {
        currentPage = 1;
        await LoadJobsCore();
    });

    private Task ClearSearch() => _dataGate.RunAsync(async () =>
    {
        searchTerm = string.Empty;
        currentPage = 1;
        await LoadJobsCore();
    });

    private Task PreviousPage() => _dataGate.RunAsync(async () =>
    {
        if (currentPage > 1) { currentPage--; await LoadJobsCore(); }
    });

    private Task NextPage() => _dataGate.RunAsync(async () =>
    {
        currentPage++; await LoadJobsCore();
    });

    private async Task ViewJob(Job j)
    {
        // Do not use _dataGate here — list refreshes must not block opening the detail panel (E2E/UX).
        try
        {
            await OpenJobCore(j.Id);
            if (selectedJob == null)
                ToastService.ShowError("Job could not be loaded.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to open job: {ex.Message}");
        }
    }

    private Task OpenJobAsync(Guid jobId) => _dataGate.RunAsync(() => OpenJobCore(jobId));

    private async Task OpenJobCore(Guid jobId)
    {
        selectedJob = await JobService.GetByIdAsync(jobId);
        commandCenter = selectedJob != null
            ? await JobService.GetCommandCenterSummaryAsync(jobId)
            : null;
        if (selectedJob != null)
        {
            jobMilestones = (await JobService.GetMilestonesAsync(jobId)).ToList();
            jobSnags = (await JobService.GetSnagsAsync(jobId)).ToList();
            jobSafetyIncidents = (await JobService.GetSafetyIncidentsAsync(jobId)).ToList();
        }
        else
        {
            jobMilestones.Clear();
            jobSnags.Clear();
            jobSafetyIncidents.Clear();
        }
    }

    private void CloseJobView()
    {
        selectedJob = null;
        commandCenter = null;
        jobMilestones.Clear();
        jobSnags.Clear();
        jobSafetyIncidents.Clear();
    }

    private Task DeleteJob(Job j) => _dataGate.RunAsync(async () =>
    {
        bool ok;
        try { ok = await JS.InvokeAsync<bool>("confirm", $"Delete job {j.JobNumber}?"); } catch { ok = false; }
        if (!ok) return;
        await JobService.DeleteAsync(j.Id);
        if (selectedJob?.Id == j.Id) selectedJob = null;
        await LoadJobsCore();
    });

    private IEnumerable<string[]> BuildJobExportRows()
    {
        foreach (var j in demoJobs)
        {
            var act = j.ActualCost + ((j.Labors?.Where(l => !l.IsDeleted).Sum(l => l.TotalCost)) ?? 0);
            yield return new[]
            {
                j.JobNumber,
                j.Title,
                j.Customer?.Name ?? "",
                j.Status.ToString(),
                TabularExportHelper.FormatDecimal(j.QuotedTotal),
                TabularExportHelper.FormatDecimal(act),
                TabularExportHelper.FormatDecimal(act - j.QuotedTotal)
            };
        }
    }

    private async Task ExportJobsCsvAsync()
    {
        if (!demoJobs.Any())
        {
            ToastService.ShowError("No jobs to export.");
            return;
        }

        try
        {
            var csv = TabularExportHelper.BuildCsv(
                "JobNumber,Title,Customer,Status,Quoted,Actual,Variance",
                BuildJobExportRows().Select(r => r.AsEnumerable()));
            await JS.InvokeVoidAsync("meterpUi.downloadText", "jobs.csv", csv, "text/csv;charset=utf-8");
        }
        catch
        {
            /* download helper may be blocked in headless browsers */
        }

        ToastService.ShowSuccess("Jobs CSV downloaded.");
    }

    private async Task ExportJobsExcelAsync()
    {
        if (!demoJobs.Any()) return;
        var tsv = TabularExportHelper.BuildExcelTsv(
            "JobNumber\tTitle\tCustomer\tStatus\tQuoted\tActual\tVariance",
            BuildJobExportRows().Select(r => r.AsEnumerable()));
        await JS.InvokeVoidAsync("meterpUi.downloadText", "jobs.xls", tsv, "application/vnd.ms-excel");
        ToastService.ShowSuccess("Jobs Excel file downloaded.");
    }

    private async Task ExportJobsPdfAsync()
    {
        if (!demoJobs.Any()) return;
        var pdf = TabularPdfGenerator.Generate(
            "Jobs Export",
            new[] { "Job #", "Title", "Customer", "Status", "Quoted", "Actual", "Variance" },
            BuildJobExportRows(),
            _branding);
        await JS.InvokeVoidAsync("meterpUi.downloadBytes", "jobs.pdf", Convert.ToBase64String(pdf), "application/pdf");
        ToastService.ShowSuccess("Jobs PDF downloaded.");
    }

    private async Task AddMilestoneAsync((string Title, DateTime? DueDate) input)
    {
        if (selectedJob == null || string.IsNullOrWhiteSpace(input.Title)) return;
        try
        {
            await JobService.AddMilestoneAsync(new JobMilestone
            {
                JobId = selectedJob.Id,
                Title = input.Title,
                DueDate = input.DueDate,
                SortOrder = jobMilestones.Count,
                Status = JobMilestoneStatus.Pending
            });
            jobMilestones = (await JobService.GetMilestonesAsync(selectedJob.Id)).ToList();
            ToastService.ShowSuccess("Milestone added.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

    private async Task AddSnagAsync(string description)
    {
        if (selectedJob == null || string.IsNullOrWhiteSpace(description)) return;
        if (CurrentUserService.UserId is not { } userId) return;
        try
        {
            await JobService.AddSnagAsync(new JobSnagItem
            {
                JobId = selectedJob.Id,
                Description = description,
                ReportedByUserId = userId
            });
            jobSnags = (await JobService.GetSnagsAsync(selectedJob.Id)).ToList();
            ToastService.ShowSuccess("Snag recorded.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

    private async Task ResolveSnagAsync(JobSnagItem snag)
    {
        if (selectedJob == null || CurrentUserService.UserId is not { } userId) return;
        try
        {
            await JobService.ResolveSnagAsync(snag.Id, userId);
            jobSnags = (await JobService.GetSnagsAsync(selectedJob.Id)).ToList();
            ToastService.ShowSuccess("Snag resolved.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

    private async Task AddSafetyIncidentAsync((string Description, SafetyIncidentSeverity Severity) input)
    {
        if (selectedJob == null || string.IsNullOrWhiteSpace(input.Description)) return;
        if (CurrentUserService.UserId is not { } userId) return;
        try
        {
            await JobService.AddSafetyIncidentAsync(new JobSafetyIncident
            {
                JobId = selectedJob.Id,
                Description = input.Description,
                Severity = input.Severity,
                ReportedByUserId = userId
            });
            jobSafetyIncidents = (await JobService.GetSafetyIncidentsAsync(selectedJob.Id)).ToList();
            ToastService.ShowSuccess("Safety incident recorded.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

    private async Task CloseSafetyIncidentAsync(JobSafetyIncident incident)
    {
        if (selectedJob == null || CurrentUserService.UserId is not { } userId) return;
        try
        {
            await JobService.CloseSafetyIncidentAsync(incident.Id, userId, "Corrective action documented.");
            jobSafetyIncidents = (await JobService.GetSafetyIncidentsAsync(selectedJob.Id)).ToList();
            ToastService.ShowSuccess("Safety incident closed.");
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

    private async Task AnalyzeWithAi(Job j)
    {
        try
        {
            var analysis = await AiAssistantService.AnalyzeJobVarianceAsync(j);
            if (analysis != null)
            {
                ToastService.ShowSuccess("AI: " + analysis.Summary);
                if (!string.IsNullOrWhiteSpace(analysis.SuggestedMarginNote))
                {
                    j.Notes = (j.Notes ?? "") + "\n[AI] " + analysis.SuggestedMarginNote;
                    await JobService.UpdateAsync(j);
                    ToastService.ShowInfo("AI note appended.");
                }
            }
        }
        catch { ToastService.ShowInfo("AI analysis (configure key)."); }
    }

    private void GoToCopilot() => Nav.NavigateTo("/ai-copilot");

    private async Task AnalyzeDemo(Job? j = null)
    {
        await Task.CompletedTask;
        var msg = j != null ? $"AI Closeout for {j.JobNumber}: ..." : "AI Closeout demo...";
        ToastService.ShowInfo(msg + " See /ai-copilot.");
    }

    private void ShowTravelNote() => ToastService.ShowInfo("Travel is recorded as JobCost records with CostType 'Travel' (daily allowance or km rate). It is included in every variance calculation and in the AI prompts so recommendations are realistic for Gauteng/mining site work.");

    private Task SignOffJobAsync(Job j) => _dataGate.RunAsync(async () =>
    {
        if (CurrentUserService.UserId is not { } userId) return;
        try
        {
            if (!await JobService.SignOffAsync(j.Id, userId))
            {
                ToastService.ShowError("Could not record sign-off.");
                return;
            }

            ToastService.ShowSuccess($"{j.JobNumber} signed off — ready for final invoicing.");
            await LoadJobsCore();
            selectedJob = demoJobs.FirstOrDefault(x => x.Id == j.Id);
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    });

    private async Task CreateInvoiceFromJob(Job j)
    {
        try
        {
            var inv = await InvoiceService.CreateFromJobAsync(j.Id);
            ToastService.ShowSuccess($"Invoice {inv.InvoiceNumber} created from job {j.JobNumber}.");
            Nav.NavigateTo($"/invoices?open={inv.Id}");
        }
        catch (QuotaExceededException ex)
        {
            ToastService.ShowError(ex.Message);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Failed to create invoice from job: {ex.Message}");
        }
    }
}
