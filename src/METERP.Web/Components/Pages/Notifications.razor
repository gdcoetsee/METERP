@page "/notifications"
@using METERP.Application.Services
@using METERP.Domain
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject ToastService ToastService
@inject ITenantNotificationService NotificationService

<PageTitle>Notifications</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h5 mb-1">Notifications</h1>
        <p class="text-muted small mb-0">Compliance expiry alerts, approvals, and system messages (tenant-scoped).</p>
    </div>
    <button class="btn btn-outline-secondary btn-sm" @onclick="MarkAllRead" data-testid="notifications-mark-all">Mark all read</button>
</div>

<span data-testid="notifications-ready" class="visually-hidden">ready</span>
<div class="list-group" data-testid="notifications-list">
    @foreach (var n in notifications)
    {
        <div class="list-group-item d-flex justify-content-between @(n.IsRead ? "text-muted" : "")"
             style="cursor:pointer;" @onclick="() => MarkRead(n)" data-testid="notification-item">
            <div>
                <strong>@n.Title</strong>
                @if (!string.IsNullOrEmpty(n.Category))
                {
                    <span class="badge bg-light text-dark ms-1">@n.Category</span>
                }
                <br />
                <small>@n.Message</small>
            </div>
            <div class="text-end">
                <small class="text-muted">@n.CreatedDate.ToString("MMM dd")</small>
                @if (!n.IsRead)
                {
                    <span class="badge bg-danger ms-2">New</span>
                }
            </div>
        </div>
    }
</div>

@if (!notifications.Any())
{
    <EmptyState Title="No notifications"
                Description="Compliance scans and approval workflows will appear here."
                Icon="🔔"
                TestId="notifications-empty" />
}

@code {
    private List<TenantNotification> notifications = new();

    protected override async Task OnInitializedAsync()
    {
        notifications = (await NotificationService.GetForCurrentUserAsync()).ToList();
    }

    private async Task MarkRead(TenantNotification n)
    {
        await NotificationService.MarkReadAsync(n.Id);
        notifications = (await NotificationService.GetForCurrentUserAsync()).ToList();
    }

    private async Task MarkAllRead()
    {
        await NotificationService.MarkAllReadAsync();
        notifications = (await NotificationService.GetForCurrentUserAsync()).ToList();
        ToastService.ShowSuccess("All notifications marked read.");
    }
}