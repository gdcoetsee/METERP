@page "/audit"
@using METERP.Application.Services
@using METERP.Common
@using Microsoft.AspNetCore.Authorization
@inject IAuditService AuditService
@inject ToastService ToastService
@inject IJSRuntime JS
@attribute [Authorize(Policy = "Audit.View")]

<PageTitle>Audit Log</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Audit Log <span class="badge bg-dark">Compliance & Trail</span></h1>
        <p class="text-muted mb-0">Tenant-isolated history of quotes, jobs, invoices, and CRM actions.</p>
    </div>
    <button class="btn btn-outline-secondary btn-sm" data-testid="audit-export-csv" @onclick="ExportLog">Export Log (CSV)</button>
</div>

<div class="table-responsive" data-testid="audit-table">
    <table class="table table-sm table-hover">
        <thead>
            <tr>
                <th>Date (UTC)</th>
                <th>User</th>
                <th>Action</th>
                <th>Entity</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in logs)
            {
                <tr data-testid="audit-row">
                    <td>@log.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@log.UserEmail</td>
                    <td><span class="badge bg-info">@log.Action</span></td>
                    <td>@log.EntityType @log.EntityReference</td>
                    <td>@log.Details</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<AuditLogRow> logs = new();

    protected override async Task OnInitializedAsync()
    {
        logs = (await AuditService.GetRecentAsync()).ToList();
    }

    private async Task ExportLog()
    {
        var csv = await AuditService.ExportCsvAsync();
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", csv);
        ToastService.ShowSuccess("Audit log CSV copied to clipboard.");
    }
}