@page "/tenants"
@using METERP.Application.Services
@using METERP.Application.Interfaces
@using METERP.Domain
@using METERP.Common
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@attribute [Authorize(Policy = "Tenants.View")]
@inject ITenantService TenantService
@inject ICurrentUserService CurrentUserService
@inject IJSRuntime JS
@inject ToastService ToastService

<PageTitle>Tenants</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Tenants</h1>
    @if (UserCanManage)
    {
        <button class="btn btn-primary" @onclick="ShowCreateForm">+ New Tenant</button>
    }
</div>

<div class="mb-3" style="max-width: 420px;">
    <div class="input-group">
        <input type="search" class="form-control" placeholder="Search name or subdomain..."
               value="@searchTerm" @oninput="OnSearchInput" />
        @if (!string.IsNullOrEmpty(searchTerm))
        {
            <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch" title="Clear search">Clear</button>
        }
    </div>
</div>

@if (_loading)
{
    <p><em>Loading tenants...</em></p>
}
else if (tenants == null || !tenants.Any())
{
    @if (!string.IsNullOrEmpty(searchTerm))
    {
        <div class="alert alert-warning">No tenants match your search. <button class="btn btn-sm btn-link p-0" @onclick="ClearSearch">Clear search</button></div>
    }
    else
    {
        <div class="alert alert-info">No tenants found. Create the first one using the button above.</div>
    }
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Subdomain</th>
                    <th>Status</th>
                    <th>Jobs</th>
                    <th>Quotes</th>
                    <th>Invoices</th>
                    <th>AI Calls</th>
                    <th>Revenue</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tenant in tenants)
                {
                    <tr>
                        <td><strong>@tenant.Name</strong></td>
                        <td><code>@tenant.Subdomain</code></td>
                        <td>
                            @if (tenant.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td><span class="badge bg-info text-dark">@tenant.TotalJobsCreated</span></td>
                        <td>@tenant.TotalQuotesCreated</td>
                        <td>@tenant.TotalInvoicesIssued</td>
                        <td><span class="badge bg-primary">@tenant.TotalAiCalls</span></td>
                        <td>R @tenant.TotalRevenueBilled.ToString("N0")</td>
                        <td>@tenant.CreatedDate.ToString("yyyy-MM-dd")</td>
                        <td class="text-end">
                            @if (UserCanManage)
                            {
                                <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => EditTenant(tenant)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTenant(tenant)">Delete</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-2">
        <button class="btn btn-sm btn-outline-secondary" @onclick="PreviousPage" disabled="@(currentPage <= 1)">Previous</button>
        <span class="text-muted small">Page @currentPage</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="NextPage" disabled="@(tenants.Count < PageSize)">Next</button>
    </div>
}

@if (showForm)
{
    <div class="card mt-4">
        <div class="card-header">
            <h5>@(isEditing ? "Edit Tenant" : "New Tenant")</h5>
        </div>
        <div class="card-body">
            <EditForm Model="currentTenant" OnValidSubmit="SaveTenant" FormName="TenantForm">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Name *</label>
                        <InputText class="form-control" @bind-Value="currentTenant.Name" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Subdomain *</label>
                        <InputText class="form-control" @bind-Value="currentTenant.Subdomain" required placeholder="e.g. acme" />
                        <div class="form-text">Lowercase, unique identifier (used for tenant routing later).</div>
                    </div>
                </div>

                <div class="mb-3 form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="currentTenant.IsActive" id="isActiveCheck" />
                    <label class="form-check-label" for="isActiveCheck">Active</label>
                </div>

                <div class="mb-3">
                    <label class="form-label">Enabled Features (comma-separated, e.g. ai,usage-tracking,advanced-reports)</label>
                    <InputText class="form-control" @bind-Value="currentTenant.EnabledFeatures" />
                    <div class="form-text">Controls sellable/tiered features like AI Copilot. Changes take effect on next use.</div>
                </div>

                @if (isEditing)
                {
                    <div class="mb-3">
                        <label class="form-label text-muted small">Usage (auto-tracked for commercial / billing)</label>
                        <div class="d-flex flex-wrap gap-2 small">
                            <span class="badge bg-info text-dark">Jobs: @currentTenant.TotalJobsCreated</span>
                            <span class="badge bg-secondary">Quotes: @currentTenant.TotalQuotesCreated</span>
                            <span class="badge bg-success">Invoices: @currentTenant.TotalInvoicesIssued</span>
                            <span class="badge bg-primary">AI Calls: @currentTenant.TotalAiCalls</span>
                            <span class="badge bg-dark">Revenue: R @currentTenant.TotalRevenueBilled.ToString("N0")</span>
                        </div>
                        <div class="form-text mt-1">Counters increment automatically on job/quote/invoice creation and AI use. Last activity: @(currentTenant.LastActivityUtc?.ToString("yyyy-MM-dd HH:mm") ?? "n/a")</div>
                        <div class="mt-1"><small>Features: <code>@currentTenant.EnabledFeatures</code></small></div>
                    </div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">Save Tenant</button>
                    <button type="button" class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<Tenant> tenants = new();
    private Tenant currentTenant = new();
    private bool showForm;
    private bool isEditing;
    private string searchTerm = string.Empty;
    private int currentPage = 1;
    private const int PageSize = 10;
    private bool _loading = true;

    private bool UserCanManage => CurrentUserService.Permissions.Contains(Permissions.TenantsManage);

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            await LoadTenants();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadTenants()
    {
        var term = string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm.Trim();
        var result = await TenantService.GetAllAsync(term, currentPage, PageSize);
        tenants = result.ToList();
    }

    private void ShowCreateForm()
    {
        currentTenant = new Tenant { IsActive = true };
        isEditing = false;
        showForm = true;
    }

    private void EditTenant(Tenant tenant)
    {
        currentTenant = new Tenant
        {
            Id = tenant.Id,
            Name = tenant.Name,
            Subdomain = tenant.Subdomain,
            IsActive = tenant.IsActive,
            TotalJobsCreated = tenant.TotalJobsCreated,
            TotalQuotesCreated = tenant.TotalQuotesCreated,
            TotalInvoicesIssued = tenant.TotalInvoicesIssued,
            TotalAiCalls = tenant.TotalAiCalls,
            TotalRevenueBilled = tenant.TotalRevenueBilled,
            LastActivityUtc = tenant.LastActivityUtc,
            EnabledFeatures = tenant.EnabledFeatures
        };
        isEditing = true;
        showForm = true;
    }

    private async Task SaveTenant()
    {
        if (isEditing)
        {
            await TenantService.UpdateAsync(currentTenant);
        }
        else
        {
            await TenantService.CreateAsync(currentTenant.Name, currentTenant.Subdomain);
        }

        showForm = false;
        ToastService.ShowSuccess("Tenant saved successfully.");
        await LoadTenants();
        currentTenant = new();
    }

    private void CancelForm()
    {
        showForm = false;
        currentTenant = new();
    }

    private async Task DeleteTenant(Tenant tenant)
    {
        if (!await ConfirmDelete($"Delete tenant \"{tenant.Name}\" ({tenant.Subdomain})? This cannot be undone easily.")) return;

        await TenantService.DeleteAsync(tenant.Id);
        ToastService.ShowSuccess("Tenant deleted.");
        await LoadTenants();
    }

    private async Task<bool> ConfirmDelete(string message)
    {
        try
        {
            return await JS.InvokeAsync<bool>("confirm", message);
        }
        catch
        {
            return false;
        }
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        currentPage = 1;
        await LoadTenants();
    }

    private async Task ClearSearch()
    {
        searchTerm = string.Empty;
        currentPage = 1;
        await LoadTenants();
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadTenants();
        }
    }

    private async Task NextPage()
    {
        currentPage++;
        await LoadTenants();
    }
}
