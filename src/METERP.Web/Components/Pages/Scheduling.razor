@page "/scheduling"
@using METERP.Application.Services
@using METERP.Application.Interfaces
@using METERP.Domain
@using METERP.Common
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@inject IJSRuntime JS
@attribute [Authorize(Policy = "Jobs.Manage")]
@inject ISchedulingService SchedulingService
@inject IRecurringJobService RecurringJobService
@inject ICurrentUserService CurrentUserService
@inject IAiAssistantService AiAssistantService
@inject ToastService ToastService

<PageTitle>Scheduling</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
    <div>
        <h1 class="mb-0">Job Scheduling</h1>
        <p class="text-muted mb-0">Calendar and crew assignments for upcoming work.</p>
    </div>
    <ExportToolbar TestId="scheduling-export" ShowPdf="false" ShowExcel="false" OnExportCsv="ExportScheduleCsvAsync" Disabled="@_loading" />
</div>
<div class="mb-3">
    <button class="btn btn-primary btn-sm" data-testid="scheduling-ai-suggest" @onclick="SuggestAssignmentsWithAI">✨ AI Suggest Best Assignments</button>
    <button class="btn btn-outline-primary btn-sm ms-2" data-testid="scheduling-ai-risk" @onclick="RunLowStockRiskForScheduled">🔮 AI: Low-stock + travel risk</button>
    <button class="btn btn-outline-secondary btn-sm ms-2" @onclick="PreviousWeek">← Prev week</button>
    <button class="btn btn-outline-secondary btn-sm ms-1" @onclick="NextWeek">Next week →</button>
</div>

@if (!_loading && _recurringSchedules.Count > 0)
{
    <div class="card mb-3" data-testid="scheduling-recurring">
        <div class="card-header py-2 d-flex justify-content-between align-items-center">
            <span>Recurring jobs</span>
            <button class="btn btn-sm btn-outline-primary" @onclick="ProcessRecurringAsync" data-testid="scheduling-process-recurring">Spawn due jobs</button>
        </div>
        <ul class="list-group list-group-flush small">
            @foreach (var s in _recurringSchedules)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <span><strong>@s.Title</strong> — @(s.Customer?.Name ?? "Customer") every @s.IntervalDays d</span>
                    <span class="text-muted">Next: @s.NextRunDate.ToString("yyyy-MM-dd")</span>
                </li>
            }
        </ul>
    </div>
}

@if (!_loading)
{
    <div class="card mb-3" data-testid="scheduling-calendar">
        <div class="card-header py-2">Week of @_weekStart.ToString("yyyy-MM-dd")</div>
        <div class="card-body p-2">
            <div class="row g-2">
                @for (var day = 0; day < 7; day++)
                {
                    var date = _weekStart.AddDays(day);
                    var dayJobs = _calendarJobs.Where(j => j.ScheduledStart?.Date == date.Date).ToList();
                    <div class="col">
                        <div class="border rounded p-2 h-100 bg-light">
                            <div class="small fw-bold">@date.ToString("ddd dd")</div>
                            @if (!dayJobs.Any())
                            {
                                <div class="small text-muted">—</div>
                            }
                            else
                            {
                                @foreach (var cj in dayJobs)
                                {
                                    <div class="small mt-1">
                                        <button class="btn btn-link btn-sm p-0 text-start" @onclick="() => ViewJob(cj)">@cj.JobNumber</button>
                                        <div class="text-muted">@cj.Title</div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@if (_loading)
{
    <p data-testid="scheduling-loading"><em>Loading schedule...</em></p>
}
else if (jobs == null || !jobs.Any())
{
    <div class="alert alert-info" data-testid="scheduling-empty">No scheduled jobs.</div>
}
else
{
    <div class="table-responsive" data-testid="scheduling-ready">
        <table class="table" data-testid="scheduling-table">
            <thead>
                <tr>
                    <th>Job #</th>
                    <th>Title / Customer</th>
                    <th>Scheduled</th>
                    <th>Status</th>
                    <th>Assigned</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var job in jobs.OrderBy(j => j.ScheduledStart ?? DateTime.MaxValue))
                {
                    <tr data-testid="scheduling-row">
                        <td>@job.JobNumber</td>
                        <td>@job.Title<br /><small>@(job.Customer?.Name)</small></td>
                        <td>@(job.ScheduledStart?.ToString("yyyy-MM-dd") ?? "TBD")</td>
                        <td>@((MarkupString)GetStatusBadge(job.Status))</td>
                        <td data-testid="scheduling-assigned-cell">
                            @if (job.Asset != null) { <span class="badge bg-info" data-testid="scheduling-assigned-asset">@job.Asset.Name</span><br /> }
                            @if (job.AssignedEmployee != null)
                            {
                                <span class="badge bg-success" data-testid="scheduling-assigned-employee">@job.AssignedEmployee.FirstName @job.AssignedEmployee.LastName (lead)</span>
                            }
                            @foreach (var crew in job.GetCrewEmployees().Where(e => e.Id != job.AssignedEmployeeId))
                            {
                                <br /><span class="badge bg-secondary" data-testid="scheduling-crew-badge">@crew.FirstName @crew.LastName</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" data-testid="scheduling-view-assign" @onclick="() => ViewJob(job)">View/Assign</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (selectedJob != null)
{
    <div class="card mt-3" data-testid="scheduling-assign-panel">
        <div class="card-header">Assign for @selectedJob.JobNumber</div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <label>Assign Asset</label>
                    <select class="form-select" data-testid="scheduling-asset-select" @bind="assignAssetId">
                        <option value="">-- None --</option>
                        @foreach (var a in availableAssets)
                        {
                            <option value="@a.Id">@a.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label>Lead Employee</label>
                    <select class="form-select" data-testid="scheduling-employee-select" @bind="assignEmployeeId">
                        <option value="">-- None --</option>
                        @foreach (var e in availableEmployees)
                        {
                            <option value="@e.Id">@e.FirstName @e.LastName</option>
                        }
                    </select>
                </div>
            </div>
            <div class="mt-3" data-testid="scheduling-crew-panel">
                <label class="form-label">Additional crew</label>
                <div class="d-flex flex-wrap gap-3">
                    @foreach (var e in availableEmployees)
                    {
                        var crewChecked = assignCrewEmployeeIds.Contains(e.Id);
                        <label class="form-check form-check-inline mb-0">
                            <input type="checkbox"
                                   class="form-check-input"
                                   data-testid="scheduling-crew-checkbox"
                                   checked="@crewChecked"
                                   @onchange="(ChangeEventArgs args) => ToggleCrewMember(e.Id, args.Value is bool b && b)" />
                            @e.FirstName @e.LastName
                        </label>
                    }
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-md-4">
                    <label class="form-label">Scheduled start</label>
                    <input type="date" class="form-control" data-testid="scheduling-date-input" @bind="assignScheduledDate" />
                </div>
            </div>
            <button class="btn btn-success mt-2" data-testid="scheduling-save-assignments" @onclick="AssignResources">Save Assignments</button>
            <button class="btn btn-secondary mt-2 ms-1" data-testid="scheduling-close-assign" @onclick="CloseAssign">Close</button>

            <hr class="my-3" />
            <div data-testid="scheduling-quick-labor-panel">
                <h6 class="mb-2">Quick-add labor (assigned crew)</h6>
                @if (GetCrewForQuickLabor().Any())
                {
                    <div class="row g-2 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label">Hours</label>
                            <input type="number" class="form-control" min="0.25" step="0.25" data-testid="scheduling-labor-hours" @bind="laborHours" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Work date</label>
                            <input type="date" class="form-control" data-testid="scheduling-labor-date" @bind="laborWorkDate" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Crew to log</label>
                            <div class="d-flex flex-wrap gap-3">
                                @foreach (var e in GetCrewForQuickLabor())
                                {
                                    var laborChecked = laborCrewEmployeeIds.Contains(e.Id);
                                    <label class="form-check form-check-inline mb-0">
                                        <input type="checkbox"
                                               class="form-check-input"
                                               data-testid="scheduling-labor-crew-checkbox"
                                               checked="@laborChecked"
                                               @onchange="(ChangeEventArgs args) => ToggleLaborCrewMember(e.Id, args.Value is bool b && b)" />
                                        @e.FirstName @e.LastName
                                    </label>
                                }
                            </div>
                        </div>
                    </div>
                    <button class="btn btn-outline-success mt-2" data-testid="scheduling-quick-add-labor" @onclick="QuickAddCrewLabor">Log crew hours</button>
                }
                else
                {
                    <p class="text-muted small mb-0">Save crew assignments above to enable one-click JobLabor entry (links to payroll &amp; utilization).</p>
                }
            </div>
        </div>
    </div>
}

@code {
    private List<Job> jobs = new();
    private List<Asset> availableAssets = new();
    private List<Employee> availableEmployees = new();
    private Job? selectedJob;
    private Guid? assignAssetId;
    private Guid? assignEmployeeId;
    private HashSet<Guid> assignCrewEmployeeIds = new();
    private decimal laborHours = 8m;
    private DateTime laborWorkDate = DateTime.UtcNow.Date;
    private HashSet<Guid> laborCrewEmployeeIds = new();
    private bool _loading = true;
    private DateTime _weekStart;
    private List<Job> _calendarJobs = new();
    private List<RecurringJobSchedule> _recurringSchedules = new();
    private DateTime? assignScheduledDate;

    protected override async Task OnInitializedAsync()
    {
        _weekStart = StartOfWeek(DateTime.UtcNow.Date);
        await LoadBoardAsync();
    }

    private static DateTime StartOfWeek(DateTime date)
    {
        var diff = (7 + (date.DayOfWeek - DayOfWeek.Monday)) % 7;
        return date.AddDays(-diff);
    }

    private async Task LoadBoardAsync()
    {
        _loading = true;
        try
        {
            var board = await SchedulingService.GetBoardAsync();
            jobs = board.Jobs.ToList();
            availableAssets = board.Assets.ToList();
            availableEmployees = board.Employees.ToList();
            _calendarJobs = (await SchedulingService.GetCalendarJobsAsync(_weekStart)).ToList();
            _recurringSchedules = (await RecurringJobService.GetAllAsync()).ToList();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task PreviousWeek()
    {
        _weekStart = _weekStart.AddDays(-7);
        await LoadBoardAsync();
    }

    private async Task NextWeek()
    {
        _weekStart = _weekStart.AddDays(7);
        await LoadBoardAsync();
    }

    private void ViewJob(Job job)
    {
        selectedJob = job;
        assignAssetId = job.AssetId;
        assignEmployeeId = job.AssignedEmployeeId;
        assignCrewEmployeeIds = job.GetCrewEmployees()
            .Where(e => e.Id != job.AssignedEmployeeId)
            .Select(e => e.Id)
            .ToHashSet();
        assignScheduledDate = job.ScheduledStart?.Date;
        laborWorkDate = DateTime.UtcNow.Date;
        laborCrewEmployeeIds = GetCrewForQuickLabor().Select(e => e.Id).ToHashSet();
    }

    private IEnumerable<Employee> GetCrewForQuickLabor()
    {
        if (selectedJob == null)
            return Enumerable.Empty<Employee>();

        var crew = selectedJob.GetCrewEmployees().ToList();
        if (selectedJob.AssignedEmployee != null && crew.All(e => e.Id != selectedJob.AssignedEmployeeId))
            crew.Insert(0, selectedJob.AssignedEmployee);

        return crew;
    }

    private void ToggleLaborCrewMember(Guid employeeId, bool isChecked)
    {
        if (isChecked)
            laborCrewEmployeeIds.Add(employeeId);
        else
            laborCrewEmployeeIds.Remove(employeeId);
    }

    private void ToggleCrewMember(Guid employeeId, bool isChecked)
    {
        if (isChecked)
            assignCrewEmployeeIds.Add(employeeId);
        else
            assignCrewEmployeeIds.Remove(employeeId);
    }

    private async Task AssignResources()
    {
        if (selectedJob == null) return;

        await SchedulingService.AssignJobResourcesAsync(
            selectedJob.Id,
            assignAssetId,
            assignEmployeeId,
            assignCrewEmployeeIds.ToList());
        await SchedulingService.UpdateScheduledStartAsync(selectedJob.Id, assignScheduledDate);
        ToastService.ShowSuccess("Assignment saved for job.");
        await LoadBoardAsync();
        selectedJob = null;
    }

    private void CloseAssign()
    {
        selectedJob = null;
    }

    private async Task QuickAddCrewLabor()
    {
        if (selectedJob == null) return;

        if (laborHours <= 0)
        {
            ToastService.ShowError("Enter hours greater than zero.");
            return;
        }

        if (laborCrewEmployeeIds.Count == 0)
        {
            ToastService.ShowError("Select at least one crew member.");
            return;
        }

        try
        {
            var result = await SchedulingService.AddCrewLaborAsync(
                selectedJob.Id,
                laborHours,
                laborWorkDate,
                laborCrewEmployeeIds.ToList());

            ToastService.ShowSuccess($"Logged {result.EntriesAdded} crew labor entr{(result.EntriesAdded == 1 ? "y" : "ies")} for job.");
            await LoadBoardAsync();
            selectedJob = jobs.FirstOrDefault(j => j.Id == selectedJob.Id);
            if (selectedJob != null)
                laborCrewEmployeeIds = GetCrewForQuickLabor().Select(e => e.Id).ToHashSet();
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

    private static string GetStatusBadge(JobStatus status) => status switch
    {
        JobStatus.Scheduled => "<span class=\"badge bg-secondary\">Scheduled</span>",
        JobStatus.InProgress => "<span class=\"badge bg-primary\">In Progress</span>",
        _ => $"<span class=\"badge bg-light\">{status}</span>"
    };

    private async Task SuggestAssignmentsWithAI()
    {
        try
        {
            string context = "Current scheduled jobs: " + string.Join(", ", jobs.Take(5).Select(j => j.Title + " (" + j.Status + ")"));
            context += ". Available employees: " + availableEmployees.Count + ". Assets: " + availableAssets.Count + ".";
            var suggestion = await AiAssistantService.AskCopilotAsync("Suggest the best employee and asset assignments for the upcoming jobs to minimize variance and optimize utilization, considering past performance if possible.", context);
            if (!string.IsNullOrWhiteSpace(suggestion))
            {
                ToastService.ShowSuccess("AI Suggestion: " + suggestion.Substring(0, Math.Min(200, suggestion.Length)) + "... (full in Copilot)");
            }
            else
            {
                ToastService.ShowInfo("AI suggestion not available (configure AI).");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("AI suggest failed: " + ex.Message);
        }
    }

    private async Task ProcessRecurringAsync()
    {
        var spawned = await RecurringJobService.ProcessDueAsync();
        if (spawned > 0)
        {
            ToastService.ShowSuccess($"Spawned {spawned} recurring job(s).");
            await LoadBoardAsync();
        }
        else
            ToastService.ShowInfo("No recurring schedules are due today.");
    }

    private async Task ExportScheduleCsvAsync()
    {
        if (!jobs.Any()) return;
        var csv = TabularExportHelper.BuildCsv(
            "JobNumber,Title,Customer,ScheduledStart,Status,LeadEmployee",
            jobs.OrderBy(j => j.ScheduledStart ?? DateTime.MaxValue).Select(j => new[]
            {
                j.JobNumber,
                j.Title,
                j.Customer?.Name,
                j.ScheduledStart?.ToString("yyyy-MM-dd") ?? "",
                j.Status.ToString(),
                j.AssignedEmployee != null ? $"{j.AssignedEmployee.FirstName} {j.AssignedEmployee.LastName}" : ""
            }));
        try
        {
            await JS.InvokeVoidAsync("meterpUi.downloadText", "schedule.csv", csv, "text/csv;charset=utf-8");
        }
        catch
        {
            /* download helper may be blocked in headless browsers */
        }

        ToastService.ShowSuccess("Schedule CSV downloaded.");
    }

    private async Task RunLowStockRiskForScheduled()
    {
        try
        {
            string context = "Scheduled / in-progress jobs: " + string.Join(", ", jobs.Where(j => j.Status == JobStatus.Scheduled || j.Status == JobStatus.InProgress).Take(5).Select(j => j.Title + " on " + (j.ScheduledStart?.ToString("yyyy-MM-dd") ?? "TBD")));
            var result = await AiAssistantService.AskCopilotAsync("Identify low-stock items and any scheduled/in-progress jobs that could be delayed by material shortages. Include realistic travel or expediting cost impact in R and suggest 2-3 mitigation actions.", context);
            if (!string.IsNullOrWhiteSpace(result))
            {
                ToastService.ShowSuccess("AI Low-Stock Risk: " + result.Substring(0, Math.Min(180, result.Length)) + "... (full analysis + actions in Copilot)");
            }
            else
            {
                ToastService.ShowInfo("AI risk analysis not available (configure AI).");
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowError("AI risk analysis failed: " + ex.Message);
        }
    }
}