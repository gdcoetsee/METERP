@page "/"

@using METERP.Application.Models
@using METERP.Application.Services
@using METERP.Application.Interfaces
@using METERP.Domain
@using METERP.Common
@inject ICustomerService CustomerService
@inject IQuoteService QuoteService
@inject IJobService JobService
@inject IInvoiceService InvoiceService
@inject IUserService UserService
@inject IInventoryService InventoryService
@inject IAssetService AssetService
@inject ISupplierService SupplierService
@inject ICurrentUserService CurrentUserService
@inject ITenantService TenantService
@inject IBillingPortalService BillingPortalService
@inject IAiAssistantService AiAssistantService
@inject IExecutiveDashboardService ExecutiveDashboard
@inject IAccountabilityReportService AccountabilityReports
@inject IScheduledReportService ScheduledReports
@inject IJSRuntime JS
@inject ToastService Toast
@inject NavigationManager Nav

<PageTitle>METERP</PageTitle>

@if (_initialized)
{
    <span data-testid="home-ready" class="visually-hidden">ready</span>
}

<h1 class="mb-4">METERP Dashboard @if (AiAssistantService.IsConfigured) { <span class="badge bg-primary align-middle" style="font-size:0.6rem;">AI Enabled</span> }</h1>

@if (currentTenant != null)
{
    <div class="card mb-4 border-info" data-testid="home-quota-usage-card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>Monthly usage — <strong>@currentTenant.Name</strong> <span class="badge bg-dark">@currentTenant.Tier</span></span>
            <div class="d-flex flex-wrap gap-2">
                @if (!string.IsNullOrWhiteSpace(billingPortalUrl))
                {
                    <button type="button" class="btn btn-sm btn-outline-info" data-testid="home-manage-billing-button" @onclick="OpenBillingPortal">Manage billing</button>
                }
                <a href="/tenants" class="btn btn-sm btn-outline-secondary">Manage tenants</a>
            </div>
        </div>
        <div class="card-body d-flex flex-wrap gap-2">
            <QuotaUsageBadgeGroup Tenant="currentTenant" TestIdPrefix="home" />
        </div>
        @if (!currentTenant.HasFeature("ai"))
        {
            <div class="card-footer small text-warning">AI Copilot is disabled for this tenant (feature flag). Upgrade tier or enable <code>ai</code> in tenant settings.</div>
        }
        <QuotaExceededBanner Tenant="currentTenant"
                             TestIdPrefix="home"
                             ShowBlockedActionsHint="true"
                             ShowUpgradeAction="true"
                             BillingPortalUrl="billingPortalUrl"
                             OnUpgradeClick="OpenBillingPortal" />
    </div>

    @if (currentTenant.SubscriptionStatus is "past_due" or "unpaid")
    {
        <div class="alert alert-warning mb-4" data-testid="home-billing-past-due-banner" role="alert">
            <strong>Subscription payment issue.</strong> Your <code>@currentTenant.SubscriptionStatus</code> status may limit premium features.
            @if (!string.IsNullOrWhiteSpace(billingPortalUrl))
            {
                <button type="button" class="btn btn-sm btn-warning ms-2" data-testid="home-billing-past-due-manage-button" @onclick="OpenBillingPortal">Update billing</button>
            }
            else
            {
                <span> Contact support to restore service.</span>
            }
        </div>
    }
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3 class="text-primary">@customerCount</h3>
                <div class="text-muted">Customers</div>
                <a href="customers" class="btn btn-sm btn-outline-primary mt-2">Manage</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3 class="text-info">@quoteCount</h3>
                <div class="text-muted">Quotes</div>
                <a href="quotes" class="btn btn-sm btn-outline-info mt-2">View Quotes</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3 class="text-warning">@jobCount</h3>
                <div class="text-muted">Jobs</div>
                <a href="jobs" class="btn btn-sm btn-outline-warning mt-2">Track Jobs</a>
            </div>
        </div>
    </div>
    @if (_readyToInvoiceCount > 0)
    {
        <div class="col-md-3">
            <div class="card text-center border-success" data-testid="home-ready-to-invoice-card">
                <div class="card-body">
                    <h3 class="text-success">@_readyToInvoiceCount</h3>
                    <div class="text-muted">Ready to invoice</div>
                    <div class="small text-success">R @_readyToInvoiceValue.ToString("N0") quoted value</div>
                    <a href="jobs" class="btn btn-sm btn-success mt-2">Invoice now</a>
                </div>
            </div>
        </div>
    }
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3 class="text-success">@invoiceCount</h3>
                <div class="text-muted">Invoices</div>
                <a href="invoices" class="btn btn-sm btn-outline-success mt-2">Invoicing</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3 class="text-secondary">@inventoryCount</h3>
                <div class="text-muted">Inventory Items</div>
                <a href="inventory" class="btn btn-sm btn-outline-secondary mt-2">Manage Stock</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3 class="text-info">@assetCount</h3>
                <div class="text-muted">Assets</div>
                <a href="assets" class="btn btn-sm btn-outline-info mt-2">Manage Assets</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3 class="text-dark">@_supplierCount</h3>
                <div class="text-muted">Suppliers</div>
                <a href="suppliers" class="btn btn-sm btn-outline-dark mt-2">Purchasing</a>
            </div>
        </div>
    </div>
</div>

<!-- Commercial usage visibility (from tracked counters on Tenant) -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center border-dark">
            <div class="card-body">
                <h3 class="text-dark">@(currentTenant?.TotalJobsCreated ?? 0)</h3>
                <div class="text-muted small">Jobs (tenant)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-dark">
            <div class="card-body">
                <h3 class="text-dark">@(currentTenant?.TotalAiCalls ?? 0)</h3>
                <div class="text-muted small">AI Calls (tenant)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-dark">
            <div class="card-body">
                <h3 class="text-success">@(currentTenant?.TotalQuotesCreated ?? 0)</h3>
                <div class="text-muted small">Quotes (tenant)</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-dark">
            <div class="card-body">
                <h3 class="text-warning">R @(currentTenant?.TotalRevenueBilled.ToString("N0") ?? "0")</h3>
                <div class="text-muted small">Revenue Billed (tenant)</div>
            </div>
        </div>
    </div>
</div>

<p class="mt-3 small text-muted">New in complete ERP: Purchasing (Suppliers + POs with inventory receipt), Finance (CoA + Journals), HR/Employees (labor linkage). See /finance, /employees, /suppliers, /purchase-orders.</p>

@if (_showRoleDashboard)
{
    <div class="row g-3 mb-4" data-testid="home-role-dashboard">
        @if (_isTechnician)
        {
            <div class="col-md-4">
                <div class="card h-100 border-info">
                    <div class="card-body">
                        <h6 class="text-info">Field Portal</h6>
                        <p class="small text-muted mb-2">Submit hours, travel, and stock requests from site.</p>
                        <a href="/field" class="btn btn-sm btn-outline-info">Open Field Portal</a>
                    </div>
                </div>
            </div>
        }
        @if (_isProcurement)
        {
            <div class="col-md-4">
                <div class="card h-100 border-warning">
                    <div class="card-body">
                        <h6 class="text-warning">Procurement queue</h6>
                        <p class="small mb-1">@_executive?.PendingRequisitions requisition(s) awaiting action</p>
                        <a href="/purchase-orders" class="btn btn-sm btn-outline-warning me-1">POs</a>
                        <a href="/requisitions" class="btn btn-sm btn-outline-secondary">Requisitions</a>
                    </div>
                </div>
            </div>
        }
        @if (_isHr)
        {
            <div class="col-md-4">
                <div class="card h-100 border-success">
                    <div class="card-body">
                        <h6 class="text-success">HR &amp; leave</h6>
                        <p class="small mb-1">@_executive?.PendingLeave leave request(s) in queue</p>
                        <a href="/employees" class="btn btn-sm btn-outline-success me-1">Employees</a>
                        <a href="/approvals" class="btn btn-sm btn-outline-secondary">Approvals</a>
                    </div>
                </div>
            </div>
        }
        @if (_isStores)
        {
            <div class="col-md-4">
                <div class="card h-100 border-secondary">
                    <div class="card-body">
                        <h6>Stores</h6>
                        <p class="small mb-1">@lowStockCount low-stock SKU(s) · @_executive?.PendingRequisitions pending requisition(s)</p>
                        <a href="/inventory" class="btn btn-sm btn-outline-secondary me-1">Inventory</a>
                        <a href="/stock-take" class="btn btn-sm btn-outline-secondary">Stock take</a>
                    </div>
                </div>
            </div>
        }
        @if (_isFinance)
        {
            <div class="col-md-4">
                <div class="card h-100 border-danger">
                    <div class="card-body">
                        <h6 class="text-danger">Finance</h6>
                        <p class="small mb-1">R @(_executive?.AgedDebtorsTotal.ToString("N0") ?? "0") outstanding · @_readyToInvoiceCount ready to invoice</p>
                        <a href="/invoices" class="btn btn-sm btn-outline-danger me-1">Invoices</a>
                        <a href="/finance" class="btn btn-sm btn-outline-secondary">Finance</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (_showExecutiveView && _executive != null)
{
    <div class="card mb-4 border-primary" data-testid="home-executive-dashboard">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <span>Executive accountability</span>
            <div>
                <button type="button" class="btn btn-sm btn-light me-1" @onclick="EmailExecutiveSummaryAsync" data-testid="home-email-executive-report">Email summary</button>
                <a href="/approvals" class="btn btn-sm btn-light">Approvals hub</a>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3 text-center">
                <div class="col-md-2">
                    <div class="fs-4 fw-bold text-warning">@_executive.PendingApprovals</div>
                    <div class="small text-muted">Pending approvals</div>
                </div>
                <div class="col-md-2">
                    <div class="fs-4 fw-bold text-danger" data-testid="home-overdue-sla-count">@_overdueApprovals.Count</div>
                    <div class="small text-muted">Overdue (SLA)</div>
                </div>
                <div class="col-md-2">
                    <div class="fs-4 fw-bold text-danger">@_executive.UnreadNotifications</div>
                    <div class="small text-muted"><a href="/notifications">Unread alerts</a></div>
                </div>
                <div class="col-md-2">
                    <div class="fs-4 fw-bold text-success">@_executive.ReadyToInvoiceJobs</div>
                    <div class="small text-muted">Ready to invoice</div>
                </div>
                <div class="col-md-3">
                    <div class="fs-5 fw-bold">R @_executive.ReadyToInvoiceValue.ToString("N0")</div>
                    <div class="small text-muted">Quoted value awaiting invoice</div>
                </div>
                <div class="col-md-3">
                    <div class="fs-5 fw-bold text-danger">R @_executive.AgedDebtorsTotal.ToString("N0")</div>
                    <div class="small text-muted">Outstanding receivables</div>
                </div>
            </div>
            <p class="small text-muted mb-0 mt-2">
                Queues: @_executive.PendingQuotes quotes · @_executive.PendingRequisitions stock · @_executive.PendingLeave leave · @_executive.PendingFieldReports field reports
                @if (_executive.LowStockItems > 0)
                {
                    <span> · <strong>@_executive.LowStockItems</strong> low-stock SKUs</span>
                }
            </p>
        </div>
    </div>
}

@if (_showExecutiveView && _userActivity.Count > 0)
{
    <div class="card mb-4" data-testid="home-user-activity">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>User activity (30 days)</span>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportUserActivityAsync">Export CSV</button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th class="text-end">Actions</th>
                            <th class="text-end">Approvals</th>
                            <th class="text-end">Last active</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _userActivity.Take(8))
                        {
                            <tr>
                                <td>@row.UserEmail</td>
                                <td class="text-end">@row.TotalActions</td>
                                <td class="text-end">@row.ApprovalActions</td>
                                <td class="text-end text-muted small">@(row.LastActivityUtc?.ToString("yyyy-MM-dd HH:mm") ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (_showExecutiveView && _divisionScorecards.Count > 0)
{
    <div class="card mb-4" data-testid="home-division-scorecards">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Division scorecards</span>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ExportDivisionScorecardsAsync">Export CSV</button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Division</th>
                            <th class="text-end">Active jobs</th>
                            <th class="text-end">Avg %</th>
                            <th class="text-end">Ready to invoice</th>
                            <th class="text-end">Invoiced R</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _divisionScorecards)
                        {
                            <tr>
                                <td><strong>@row.DivisionName</strong> <span class="text-muted small">@row.DivisionCode</span></td>
                                <td class="text-end">@row.ActiveJobs</td>
                                <td class="text-end">@row.AvgProgressPercent%</td>
                                <td class="text-end">@row.ReadyToInvoiceCount <span class="text-muted small">(R @row.ReadyToInvoiceValue.ToString("N0"))</span></td>
                                <td class="text-end">R @row.InvoicedRevenue.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (lowStockCount > 0 || Math.Abs(activeJobVariance) > 0)
{
    <div class="alert alert-@(lowStockCount > 0 ? "warning" : "info") py-2 mb-3">
        @if (lowStockCount > 0)
        {
            <span><strong>@lowStockCount</strong> items below reorder level. </span>
        }
        @if (Math.Abs(activeJobVariance) > 0)
        {
            <span>Active jobs variance (incl. labor & travel): <strong class="@(activeJobVariance > 0 ? "text-danger" : "text-success")">R @activeJobVariance.ToString("N2")</strong>.</span>
        }
    </div>
}

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Quick Links</div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li class="mb-2">• <a href="customers">Customers &amp; Contacts</a> — manage your client base</li>
                    <li class="mb-2">• <a href="quotes">Quotes</a> — create detailed estimates with line items + VAT</li>
                    <li class="mb-2">• <a href="jobs">Jobs</a> — convert quotes, track actual costs &amp; variance</li>
                    <li class="mb-2">• <a href="invoices">Invoices</a> — bill customers from completed jobs</li>
                    <li class="mb-2">• <a href="inventory">Inventory</a> — stock items, adjustments &amp; job usage tracking</li>
                    <li class="mb-2">• <a href="assets">Assets</a> — transformers, switchgear &amp; customer equipment</li>
                    <li class="mb-2">• <a href="users">Users</a> — manage team members &amp; roles per tenant</li>
                    <li>• <a href="tenants">Tenants</a> — platform tenant administration</li>
                    <li class="mt-2"><strong>✨ New:</strong> <a href="ai-copilot">AI Copilot</a> — ask natural language questions, get quote suggestions, variance analysis, and contractor-specific recommendations powered by your live data. Actionable: create real Quotes/Jobs from responses.</li>
                    <li class="mt-1">• <a href="ai-copilot">🔮 Low-stock + travel risk predictor</a> for scheduled jobs — also directly available from the Reports AI card and Inventory screen.</li>
                </ul>
                <div class="mt-2">
                    <button class="btn btn-sm btn-outline-primary" @onclick="GenerateHomeAiInsight">✨ Get AI Insight</button>
                    @if (!string.IsNullOrWhiteSpace(homeAiInsight))
                    {
                        <div class="small mt-1 p-2 bg-light border">@homeAiInsight</div>
                    }
                </div>

                <!-- Onboarding wizard stub for new users (sellable polish) -->
                @if (!onboarded)
                {
                    <div class="alert alert-primary mt-2 small">
                        Welcome! <button class="btn btn-sm btn-link p-0" @onclick="StartOnboarding">Start quick onboarding tour</button> (3 steps: AI Copilot, Jobs with travel, Reports).
                        <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="() => onboarded = true">Skip</button>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">Getting Started (Demo)</div>
            <div class="card-body">
                <p class="mb-2">Login: <code>admin@acme.demo</code> / <code>Demo123!</code></p>
                <p class="small text-muted mb-2">
                    A full Quote → Job → Invoice demo dataset is seeded automatically on first run.
                    Explore the flow end-to-end.
                </p>
                <div>
                    <a href="quotes" class="btn btn-primary btn-sm">Start with Quotes</a>
                </div>
            </div>
        </div>
    </div>
</div>

<p class="mt-4 text-muted small">
    METERP — Clean Architecture • .NET 9 • Blazor Server • PostgreSQL • Multi-tenant from day one • Claim-based permissions.
    <br />Full flow demo: Quote (inventory-backed lines) → Job (labor + materials + asset) → Invoice.
</p>

@code {
    private int customerCount;
    private int quoteCount;
    private int jobCount;
    private int invoiceCount;
    private string homeAiInsight = "";
    private bool onboarded = true; // set false for new users in real (from localStorage or user profile)
    private int inventoryCount;
    private int lowStockCount;
    private int assetCount;
    private decimal activeJobVariance;
    private int _readyToInvoiceCount;
    private decimal _readyToInvoiceValue;
    private ExecutiveDashboardSummary? _executive;
    private List<DivisionScorecardRow> _divisionScorecards = new();
    private List<UserActivityRow> _userActivity = new();
    private List<OverdueApprovalRow> _overdueApprovals = new();
    private bool _showExecutiveView;
    private bool _showRoleDashboard;
    private bool _isTechnician;
    private bool _isProcurement;
    private bool _isHr;
    private bool _isStores;
    private bool _isFinance;
    private int _supplierCount;
    private Tenant? currentTenant;
    private string? billingPortalUrl;
    private bool _initialized;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _showExecutiveView = CurrentUserService.Permissions.Contains(Permissions.AuditView)
                || CurrentUserService.Permissions.Contains(Permissions.QuotesManage);

            if (CurrentUserService.UserId is { } userId)
            {
                var roles = await UserService.GetUserRolesAsync(userId);
                _isTechnician = roles.Contains("Technician");
                _isProcurement = roles.Contains("Procurement");
                _isHr = roles.Contains("HrManager");
                _isStores = roles.Contains("Stores");
                _isFinance = roles.Contains("Finance");
                _showRoleDashboard = _isTechnician || _isProcurement || _isHr || _isStores || _isFinance;
            }

            customerCount = (await CustomerService.GetAllAsync()).Count;
            quoteCount = (await QuoteService.GetAllAsync()).Count;
            jobCount = (await JobService.GetAllAsync()).Count;
            invoiceCount = (await InvoiceService.GetAllAsync()).Count;
            inventoryCount = (await InventoryService.GetAllItemsAsync()).Count;
            lowStockCount = (await InventoryService.GetAllItemsAsync(lowStockOnly: true)).Count;
            assetCount = (await AssetService.GetAllAsync()).Count;
            _supplierCount = (await SupplierService.GetAllAsync()).Count;

            var activeJobs = (await JobService.GetAllAsync(pageSize: 200)).ToList();
            activeJobVariance = activeJobs
                .Where(j => j.Status == JobStatus.InProgress || j.Status == JobStatus.Scheduled)
                .Sum(j => (j.ActualCost + (j.Labors?.Sum(l => l.TotalCost) ?? 0)) - j.QuotedTotal);

            _executive = await ExecutiveDashboard.GetSummaryAsync();
            _readyToInvoiceCount = _executive.ReadyToInvoiceJobs;
            _readyToInvoiceValue = _executive.ReadyToInvoiceValue;
            _divisionScorecards = (await AccountabilityReports.GetDivisionScorecardsAsync()).ToList();
            _userActivity = (await AccountabilityReports.GetUserActivityAsync()).ToList();
            _overdueApprovals = (await AccountabilityReports.GetOverdueApprovalsAsync()).ToList();

            // Load current tenant commercial usage (for demo visibility)
            var tid = CurrentUserService.TenantId;
            if (tid != Guid.Empty)
            {
                currentTenant = await TenantService.GetByIdAsync(tid);
                if (currentTenant != null)
                    billingPortalUrl = await BillingPortalService.ResolveCustomerPortalUrlAsync(currentTenant);
            }
        }
        catch
        {
            // ignore on initial load if DB not ready
        }
        finally
        {
            _initialized = true;
        }
    }

    private async Task GenerateHomeAiInsight()
    {
        try
        {
            string context = $"Customers: {customerCount}, Quotes: {quoteCount}, Jobs: {jobCount}, Invoices: {invoiceCount}. Recent variance and low stock alerts in system.";
            homeAiInsight = await AiAssistantService.AskCopilotAsync("Give one key actionable insight for this contracting business today, focusing on margin or efficiency.", context) ?? "AI insight unavailable.";
        }
        catch
        {
            homeAiInsight = "AI temporarily unavailable (configure key).";
        }
    }

    private void StartOnboarding()
    {
        Toast.ShowSuccess("Onboarding started - see AI Copilot for your first quote!");
        Nav.NavigateTo("/ai-copilot");
        onboarded = true;
    }

    private async Task EmailExecutiveSummaryAsync()
    {
        var sent = await ScheduledReports.SendExecutiveSummaryEmailAsync();
        if (sent)
            Toast.ShowSuccess("Executive summary emailed (check Mailpit at :8025 in docker demo).");
        else
            Toast.ShowInfo("Email not sent — configure SMTP (Mailpit in docker-compose) or sign in with an email address.");
    }

    private async Task ExportUserActivityAsync()
    {
        var csv = await AccountabilityReports.ExportUserActivityCsvAsync();
        await JS.InvokeVoidAsync("meterpUi.downloadText", "user-activity.csv", csv, "text/csv;charset=utf-8");
        Toast.ShowSuccess("User activity exported.");
    }

    private async Task ExportDivisionScorecardsAsync()
    {
        var csv = await AccountabilityReports.ExportDivisionScorecardsCsvAsync();
        await JS.InvokeVoidAsync("meterpUi.downloadText", "division-scorecards.csv", csv, "text/csv;charset=utf-8");
        Toast.ShowSuccess("Division scorecards exported.");
    }

    private async Task OpenBillingPortal()
    {
        if (currentTenant == null)
            return;

        var url = billingPortalUrl ?? await BillingPortalService.ResolveCustomerPortalUrlAsync(currentTenant);
        if (string.IsNullOrWhiteSpace(url))
        {
            Toast.ShowInfo("Billing portal is not available for this tenant.");
            return;
        }

        billingPortalUrl = url;
        await JS.InvokeVoidAsync("open", url, "_blank");
    }
}
