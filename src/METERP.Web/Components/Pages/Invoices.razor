@page "/invoices"
@using METERP.Application.Models
@using METERP.Application.Services
@using METERP.Application.Interfaces
@using METERP.Domain
@using METERP.Common
@using METERP.Web.Reports
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@attribute [Authorize(Policy = "Invoices.View")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IInvoiceService InvoiceService
@inject IJobService JobService
@inject ITenantService TenantService
@inject ICurrentUserService CurrentUserService
@inject IJSRuntime JS
@inject ToastService ToastService

<PageTitle>Invoices</PageTitle>

@if (!_loading)
{
    <span data-testid="invoices-ready" class="visually-hidden">ready</span>
}

@if (_agedDebtors.Count > 0)
{
    <div class="card mb-3 border-warning" data-testid="aged-debtors-summary">
        <div class="card-body py-2">
            <strong>Aged debtors:</strong>
            <span class="ms-2">@_agedDebtors.Count open invoice(s)</span>
            <span class="ms-2 text-danger">R @_agedDebtors.Sum(d => d.BalanceDue).ToString("N2") outstanding</span>
            <span class="ms-2 small text-muted">Buckets: @string.Join(", ", _agedDebtors.GroupBy(d => d.AgingBucket).Select(g => $"{g.Key} ({g.Count()})"))</span>
        </div>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h1>Invoices</h1>
    <div class="d-flex gap-2 align-items-center">
        <ExportToolbar TestId="invoices-export" OnExportCsv="ExportInvoicesCsvAsync" OnExportExcel="ExportInvoicesExcelAsync" OnExportPdf="ExportInvoicesPdfAsync" Disabled="@_loading" />
        @if (UserCanManage)
        {
            <button class="btn btn-primary" @onclick="ShowCreateForm" data-testid="new-invoice-button">+ New Invoice</button>
        }
    </div>
</div>

<div class="mb-3" style="max-width: 420px;">
    <div class="input-group">
        <input type="search" class="form-control" data-testid="invoices-search" placeholder="Search invoice #, customer or job..."
               @bind="searchTerm" @bind:event="oninput" @bind:after="OnSearchChangedAsync" />
        @if (!string.IsNullOrEmpty(searchTerm))
        {
            <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch" title="Clear search">Clear</button>
        }
    </div>
</div>

@if (_loading)
{
    <p><em>Loading invoices...</em></p>
}
else if (invoices == null || !invoices.Any())
{
    @if (!string.IsNullOrEmpty(searchTerm))
    {
        <div class="alert alert-warning">No invoices match your search. <button class="btn btn-sm btn-link p-0" @onclick="ClearSearch">Clear search</button></div>
    }
    else
    {
        <div class="alert alert-info">No invoices yet. Create one manually or convert from a completed job.</div>
    }
}
else
{
    <div class="table-responsive">
        <table class="table table-hover" data-testid="invoices-table">
            <thead>
                <tr>
                    <th>Invoice #</th>
                    <th>Customer / Job</th>
                    <th>Date / Due</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th class="text-end">Total</th>
                    <th class="text-end">Balance</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var inv in invoices)
                {
                    <tr>
                        <td><strong>@inv.InvoiceNumber</strong></td>
                        <td>
                            @(inv.Customer?.Name ?? "—")<br />
                            <small class="text-muted">@(inv.Job?.JobNumber ?? "")</small>
                        </td>
                        <td>@inv.InvoiceDate.ToString("yyyy-MM-dd")<br /><small class="text-muted">Due @inv.DueDate.ToString("yyyy-MM-dd")</small></td>
                        <td>@((MarkupString)GetDocumentTypeBadge(inv.DocumentType))</td>
                        <td>@((MarkupString)GetStatusBadge(inv.Status))</td>
                        <td class="text-end">R @inv.Total.ToString("N2")</td>
                        <td class="text-end">R @inv.BalanceDue.ToString("N2")</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ViewInvoice(inv)" data-testid="view-invoice">View</button>
                            @if (UserCanManage)
                            {
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditInvoice(inv)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteInvoice(inv)">Delete</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-2">
        <button class="btn btn-sm btn-outline-secondary" @onclick="PreviousPage" disabled="@(currentPage <= 1)">Previous</button>
        <span class="text-muted small">Page @currentPage</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="NextPage" disabled="@(invoices.Count < PageSize)">Next</button>
    </div>
}

@if (showForm)
{
    <div class="card mt-4">
        <div class="card-header">
            <h5>@(isEditing ? "Edit Invoice" : "New Invoice")</h5>
        </div>
        <div class="card-body">
            <EditForm Model="currentInvoice" OnValidSubmit="SaveInvoice" FormName="InvoiceForm">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Invoice Date</label>
                        <InputDate class="form-control" @bind-Value="currentInvoice.InvoiceDate" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Due Date</label>
                        <InputDate class="form-control" @bind-Value="currentInvoice.DueDate" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Notes</label>
                    <InputTextArea class="form-control" @bind-Value="currentInvoice.Notes" rows="2" />
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Tax Rate</label>
                        <InputNumber class="form-control" @bind-Value="currentInvoice.TaxRate" step="0.01" />
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">Save Invoice</button>
                    <button type="button" class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (selectedInvoice != null)
{
    <div class="card mt-4 border-primary">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">@selectedInvoice.InvoiceNumber — @(selectedInvoice.Customer?.Name)</h5>
            <div>
                <button class="btn btn-sm btn-light me-2" @onclick="CloseInvoiceView" data-testid="close-invoice-view">Close</button>
                @if (UserCanManage)
                {
                    <button class="btn btn-sm btn-success" @onclick="CreateFromJobIfPossible" data-testid="create-invoice-from-job">Create from Job (demo)</button>
                }
            </div>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <strong>Type:</strong> @((MarkupString)GetDocumentTypeBadge(selectedInvoice.DocumentType))<br />
                    <strong>Status:</strong> @((MarkupString)GetStatusBadge(selectedInvoice.Status))<br />
                    <strong>Due:</strong> @selectedInvoice.DueDate.ToString("yyyy-MM-dd")
                    @if (selectedInvoice.RetentionAmount > 0)
                    {
                        <br /><strong>Retention held:</strong> @($"R {selectedInvoice.RetentionAmount:N2} ({selectedInvoice.RetentionPercent:N0}%)")
                    }
                </div>
                <div class="col-md-6 text-md-end">
                    <div>Subtotal: <strong>R @selectedInvoice.Subtotal.ToString("N2")</strong></div>
                    <div>Tax: R @selectedInvoice.Tax.ToString("N2")</div>
                    <div class="fs-5">Total: <strong>R @selectedInvoice.Total.ToString("N2")</strong></div>
                    <div>Paid: R @selectedInvoice.AmountPaid.ToString("N2") · Balance: <strong>R @selectedInvoice.BalanceDue.ToString("N2")</strong></div>
                    @if (selectedInvoice.RetentionAmount > 0)
                    {
                        <div class="small text-muted">Net collectable (excl. retention): R @selectedInvoice.NetCollectable.ToString("N2")</div>
                    }
                </div>
            </div>

            @if (selectedInvoice.Job != null)
            {
                <div class="mb-2"><strong>Linked Job:</strong> @selectedInvoice.Job.JobNumber</div>
            }

            <h6 data-testid="invoice-line-items-header">Line Items (@selectedInvoice.Lines.Count(l => !l.IsDeleted))</h6>

            @if (selectedInvoice.Lines.Any(l => !l.IsDeleted))
            {
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th class="text-end">Qty</th>
                            <th>Type</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Line Total</th>
                            @if (UserCanManage) { <th></th> }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in selectedInvoice.Lines.Where(l => !l.IsDeleted))
                        {
                            <tr>
                                <td>@line.Description</td>
                                <td class="text-end">@line.Quantity @line.Unit</td>
                                <td><span class="badge bg-light text-dark">@line.LineType</span></td>
                                <td class="text-end">R @line.UnitPrice.ToString("N2")</td>
                                <td class="text-end"><strong>R @line.LineTotal.ToString("N2")</strong></td>
                                @if (UserCanManage)
                                {
                                    <td>
                                        <button class="btn btn-sm btn-outline-secondary py-0 px-1" @onclick="() => EditLine(line)">Edit</button>
                                        <button class="btn btn-sm btn-outline-danger py-0 px-1 ms-1" @onclick="() => DeleteLine(line)">Del</button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted">No line items.</p>
            }

            @if (UserCanManage)
            {
                <button class="btn btn-outline-success btn-sm" @onclick="ShowAddLineForm">+ Add Line</button>
            }

            @if (showLineForm && editingLine != null)
            {
                <div class="mt-2 p-3 border rounded bg-light">
                    <div class="row g-2">
                        <div class="col-md-5">
                            <InputText class="form-control form-control-sm" @bind-Value="editingLine.Description" placeholder="Description" />
                        </div>
                        <div class="col-md-2">
                            <InputNumber class="form-control form-control-sm" @bind-Value="editingLine.Quantity" />
                        </div>
                        <div class="col-md-2">
                            <InputText class="form-control form-control-sm" @bind-Value="editingLine.Unit" placeholder="Unit" />
                        </div>
                        <div class="col-md-2">
                            <select class="form-select form-select-sm" @bind="editingLine.LineType">
                                <option>Material</option>
                                <option>Labour</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <InputNumber class="form-control form-control-sm" @bind-Value="editingLine.UnitPrice" step="0.01" />
                        </div>
                    </div>
                    <div class="mt-2">
                        <button class="btn btn-sm btn-success" @onclick="SaveLine">Save Line</button>
                        <button class="btn btn-sm btn-secondary ms-1" @onclick="CancelLineForm">Cancel</button>
                    </div>
                </div>
            }

            @if (selectedInvoice.DocumentType != InvoiceDocumentType.Proforma && selectedInvoice.DocumentType != InvoiceDocumentType.CreditNote)
            {
                <h6 class="mt-4" data-testid="invoice-payments-header">Payments (@_payments.Count)</h6>
                @if (_payments.Any())
                {
                    <table class="table table-sm">
                        <thead><tr><th>Date</th><th>Amount</th><th>Reference</th><th>POP</th></tr></thead>
                        <tbody>
                            @foreach (var p in _payments)
                            {
                                <tr data-testid="invoice-payment-row">
                                    <td>@p.PaymentDate.ToString("yyyy-MM-dd")</td>
                                    <td>R @p.Amount.ToString("N2")</td>
                                    <td>@(p.Reference ?? "—")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(p.PopStorageKey))
                                        {
                                            <button type="button" class="btn btn-link btn-sm p-0" data-testid="invoice-pop-download"
                                                    @onclick="() => DownloadPopAsync(p)">@(p.PopFileName ?? "Download")</button>
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted small">No payments recorded yet.</p>
                }

                @if (UserCanManage && selectedInvoice.BalanceDue > 0)
                {
                    <div class="border rounded p-3 bg-light" data-testid="invoice-record-payment">
                        <div class="row g-2 align-items-end">
                            <div class="col-md-2">
                                <label class="form-label small">Amount</label>
                                <InputNumber class="form-control form-control-sm" @bind-Value="_paymentAmount" step="0.01" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small">Date</label>
                                <InputDate class="form-control form-control-sm" @bind-Value="_paymentDate" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Reference</label>
                                <InputText class="form-control form-control-sm" @bind-Value="_paymentReference" placeholder="EFT ref" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">POP attachment</label>
                                <InputFile class="form-control form-control-sm" OnChange="OnPopSelected" accept=".pdf,.png,.jpg,.jpeg" data-testid="invoice-pop-upload" />
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-sm btn-success w-100" @onclick="RecordPaymentAsync" data-testid="invoice-record-payment-btn">Record payment</button>
                            </div>
                        </div>
                    </div>
                }
            }

            @if (UserCanManage)
            {
                <div class="mt-3 d-flex gap-2 flex-wrap">
                    @if (selectedInvoice.DocumentType != InvoiceDocumentType.CreditNote && selectedInvoice.DocumentType != InvoiceDocumentType.Proforma)
                    {
                        <button type="button" class="btn btn-sm btn-outline-warning" @onclick="CreateCreditNoteAsync" data-testid="invoice-create-credit-note">Create credit note</button>
                    }
                </div>
                <div class="mt-4">
                    <strong>Update Status:</strong>
                    <div class="btn-group mt-1" role="group">
                        @foreach (var s in Enum.GetValues<InvoiceStatus>())
                        {
                            <button class="btn btn-sm @(selectedInvoice.Status == s ? "btn-primary" : "btn-outline-primary")"
                                    @onclick="() => UpdateStatus(s)">
                                @s
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<Invoice> invoices = new();
    private List<AgedDebtorRow> _agedDebtors = new();
    private List<InvoicePayment> _payments = new();
    private decimal _paymentAmount;
    private DateTime _paymentDate = DateTime.UtcNow.Date;
    private string _paymentReference = "";
    private IBrowserFile? _popFile;
    private Invoice currentInvoice = new();
    private Invoice? selectedInvoice;
    private bool showForm;
    private bool isEditing;
    private string searchTerm = string.Empty;
    private int currentPage = 1;
    private const int PageSize = 10;
    private bool _loading = true;
    private TenantBranding _branding = TenantBranding.Default;

    private bool showLineForm;
    private InvoiceLine? editingLine;

    private bool UserCanManage => CurrentUserService.Permissions.Contains(Permissions.InvoicesManage);

    [SupplyParameterFromQuery(Name = "open")]
    public Guid? OpenInvoiceId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            if (CurrentUserService.TenantId != Guid.Empty)
            {
                var tenant = await TenantService.GetByIdAsync(CurrentUserService.TenantId);
                _branding = TenantBranding.From(tenant);
            }

            await LoadInvoices();
            _agedDebtors = (await InvoiceService.GetAgedDebtorsAsync()).ToList();

            if (OpenInvoiceId is { } openId && openId != Guid.Empty)
            {
                var opened = await InvoiceService.GetByIdAsync(openId);
                if (opened != null)
                    await ViewInvoice(opened);
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadInvoices()
    {
        var term = string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm.Trim();
        invoices = (await InvoiceService.GetAllAsync(term, currentPage, PageSize)).ToList();
        _agedDebtors = (await InvoiceService.GetAgedDebtorsAsync()).ToList();
    }

    private async Task OnSearchChangedAsync()
    {
        currentPage = 1;
        await LoadInvoices();
    }

    private async Task ClearSearch()
    {
        searchTerm = string.Empty;
        currentPage = 1;
        await LoadInvoices();
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadInvoices();
        }
    }

    private async Task NextPage()
    {
        currentPage++;
        await LoadInvoices();
    }

    private void ShowCreateForm()
    {
        currentInvoice = new Invoice
        {
            InvoiceDate = DateTime.UtcNow,
            DueDate = DateTime.UtcNow.AddDays(30),
            TaxRate = 0.15m
        };
        isEditing = false;
        showForm = true;
        selectedInvoice = null;
    }

    private void EditInvoice(Invoice inv)
    {
        currentInvoice = new Invoice
        {
            Id = inv.Id,
            InvoiceNumber = inv.InvoiceNumber,
            InvoiceDate = inv.InvoiceDate,
            DueDate = inv.DueDate,
            Status = inv.Status,
            Notes = inv.Notes,
            TaxRate = inv.TaxRate
        };
        isEditing = true;
        showForm = true;
        selectedInvoice = null;
    }

    private async Task SaveInvoice()
    {
        try
        {
            if (isEditing)
            {
                await InvoiceService.UpdateAsync(currentInvoice);
            }
            else
            {
                await InvoiceService.CreateAsync(currentInvoice);
            }

            showForm = false;
            ToastService.ShowSuccess("Invoice saved successfully.");
            await LoadInvoices();
            currentInvoice = new();
        }
        catch (QuotaExceededException ex)
        {
            ToastService.ShowError(ex.Message);
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Save failed: {ex.Message}");
        }
    }

    private void CancelForm()
    {
        showForm = false;
        currentInvoice = new();
    }

    private async Task ViewInvoice(Invoice inv)
    {
        selectedInvoice = await InvoiceService.GetByIdAsync(inv.Id);
        _payments = selectedInvoice != null
            ? (await InvoiceService.GetPaymentsAsync(selectedInvoice.Id)).ToList()
            : new();
        _paymentAmount = selectedInvoice?.BalanceDue ?? 0;
        _paymentDate = DateTime.UtcNow.Date;
        _paymentReference = "";
        _popFile = null;
        showForm = false;
        showLineForm = false;
        editingLine = null;
    }

    private void CloseInvoiceView()
    {
        selectedInvoice = null;
        showLineForm = false;
        editingLine = null;
    }

    private async Task CreateFromJobIfPossible()
    {
        // Demo helper: find a job without invoice and create one
        var jobs = await JobService.GetAllAsync();
        var job = jobs.FirstOrDefault(j =>
            (j.Status == JobStatus.Completed || j.Status == JobStatus.InProgress)
            && j.SignOffStatus == JobSignOffStatus.SignedOff);
        if (job != null)
        {
            try
            {
                var inv = await InvoiceService.CreateFromJobAsync(job.Id);
                await InvoiceService.UpdateStatusAsync(inv.Id, InvoiceStatus.Sent);
                selectedInvoice = await InvoiceService.GetByIdAsync(inv.Id);
                ToastService.ShowSuccess("Invoice created from job (demo).");
                await LoadInvoices();
            }
            catch (Exception ex)
            {
                ToastService.ShowError($"Failed to create invoice from job: {ex.Message}");
            }
        }
    }

    private void ShowAddLineForm()
    {
        if (selectedInvoice == null) return;
        editingLine = new InvoiceLine { InvoiceId = selectedInvoice.Id, Quantity = 1, LineType = "Material" };
        showLineForm = true;
    }

    private void EditLine(InvoiceLine line)
    {
        editingLine = new InvoiceLine
        {
            Id = line.Id,
            InvoiceId = line.InvoiceId,
            Description = line.Description,
            Quantity = line.Quantity,
            Unit = line.Unit,
            LineType = line.LineType,
            UnitPrice = line.UnitPrice
            // LineTotal is computed from Quantity * UnitPrice
        };
        showLineForm = true;
    }

    private async Task SaveLine()
    {
        if (editingLine == null || selectedInvoice == null) return;

        if (editingLine.Id == Guid.Empty)
        {
            await InvoiceService.AddLineAsync(editingLine);
        }
        else
        {
            await InvoiceService.UpdateLineAsync(editingLine);
        }

        showLineForm = false;
        editingLine = null;
        selectedInvoice = await InvoiceService.GetByIdAsync(selectedInvoice.Id);
        await LoadInvoices();
    }

    private void CancelLineForm()
    {
        showLineForm = false;
        editingLine = null;
    }

    private async Task DeleteLine(InvoiceLine line)
    {
        if (!await ConfirmDelete($"Delete line?")) return;
        await InvoiceService.DeleteLineAsync(line.Id);
        selectedInvoice = await InvoiceService.GetByIdAsync(selectedInvoice!.Id);
        await LoadInvoices();
    }

    private async Task DeleteInvoice(Invoice inv)
    {
        if (!await ConfirmDelete($"Delete invoice {inv.InvoiceNumber}?")) return;
        await InvoiceService.DeleteAsync(inv.Id);
        if (selectedInvoice?.Id == inv.Id) selectedInvoice = null;
        ToastService.ShowSuccess("Invoice deleted.");
        await LoadInvoices();
    }

    private async Task UpdateStatus(InvoiceStatus status)
    {
        if (selectedInvoice == null) return;
        await InvoiceService.UpdateStatusAsync(selectedInvoice.Id, status);
        selectedInvoice = await InvoiceService.GetByIdAsync(selectedInvoice.Id);
        ToastService.ShowSuccess($"Status updated to {status}.");
        await LoadInvoices();
    }

    private async Task<bool> ConfirmDelete(string message)
    {
        try { return await JS.InvokeAsync<bool>("confirm", message); }
        catch { return false; }
    }

    private void OnPopSelected(InputFileChangeEventArgs e) => _popFile = e.File;

    private async Task DownloadPopAsync(InvoicePayment payment)
    {
        try
        {
            var pop = await InvoiceService.OpenPaymentPopAsync(payment.Id);
            if (pop == null)
            {
                ToastService.ShowError("POP file not available.");
                return;
            }

            await using var stream = pop.Value.Content;
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());
            await JS.InvokeVoidAsync("meterpUi.downloadBytes", pop.Value.FileName, base64, pop.Value.ContentType);
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

    private async Task RecordPaymentAsync()
    {
        if (selectedInvoice == null || _paymentAmount <= 0) return;
        try
        {
            if (_popFile != null)
            {
                await using var stream = _popFile.OpenReadStream(5 * 1024 * 1024);
                await InvoiceService.RecordPaymentWithPopAsync(
                    selectedInvoice.Id,
                    _paymentAmount,
                    _paymentDate.ToUniversalTime(),
                    string.IsNullOrWhiteSpace(_paymentReference) ? null : _paymentReference,
                    _popFile.Name,
                    stream,
                    _popFile.ContentType,
                    CurrentUserService.UserId,
                    null);
            }
            else
            {
                await InvoiceService.RecordPaymentAsync(
                    selectedInvoice.Id,
                    _paymentAmount,
                    _paymentDate.ToUniversalTime(),
                    string.IsNullOrWhiteSpace(_paymentReference) ? null : _paymentReference,
                    CurrentUserService.UserId,
                    null);
            }

            ToastService.ShowSuccess("Payment recorded.");
            await ViewInvoice(selectedInvoice);
            await LoadInvoices();
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

    private async Task CreateCreditNoteAsync()
    {
        if (selectedInvoice == null) return;
        try
        {
            var cn = await InvoiceService.CreateCreditNoteAsync(selectedInvoice.Id, "Credit note via Invoices UI");
            ToastService.ShowSuccess($"Credit note {cn.InvoiceNumber} created.");
            await LoadInvoices();
            await ViewInvoice(cn);
        }
        catch (Exception ex)
        {
            ToastService.ShowError(ex.Message);
        }
    }

    private static string GetDocumentTypeBadge(InvoiceDocumentType type) => type switch
    {
        InvoiceDocumentType.Proforma => "<span class=\"badge bg-info\">Proforma</span>",
        InvoiceDocumentType.Deposit => "<span class=\"badge bg-primary\">Deposit</span>",
        InvoiceDocumentType.Partial => "<span class=\"badge bg-warning text-dark\">Partial</span>",
        InvoiceDocumentType.Final => "<span class=\"badge bg-success\">Final</span>",
        InvoiceDocumentType.CreditNote => "<span class=\"badge bg-danger\">Credit note</span>",
        _ => "<span class=\"badge bg-light text-dark\">Standard</span>"
    };

    private static string GetStatusBadge(InvoiceStatus status)
    {
        return status switch
        {
            InvoiceStatus.Draft => "<span class=\"badge bg-secondary\">Draft</span>",
            InvoiceStatus.Sent => "<span class=\"badge bg-info\">Sent</span>",
            InvoiceStatus.PartiallyPaid => "<span class=\"badge bg-warning text-dark\">Partially Paid</span>",
            InvoiceStatus.Paid => "<span class=\"badge bg-success\">Paid</span>",
            InvoiceStatus.Overdue => "<span class=\"badge bg-danger\">Overdue</span>",
            InvoiceStatus.Cancelled => "<span class=\"badge bg-dark\">Cancelled</span>",
            _ => status.ToString()
        };
    }

    private IEnumerable<string[]> BuildInvoiceExportRows()
    {
        foreach (var inv in invoices)
        {
            yield return new[]
            {
                inv.InvoiceNumber,
                inv.Customer?.Name ?? "",
                inv.Job?.JobNumber ?? "",
                inv.InvoiceDate.ToString("yyyy-MM-dd"),
                inv.DueDate.ToString("yyyy-MM-dd"),
                inv.DocumentType.ToString(),
                inv.Status.ToString(),
                TabularExportHelper.FormatDecimal(inv.Total),
                TabularExportHelper.FormatDecimal(inv.BalanceDue)
            };
        }
    }

    private async Task ExportInvoicesCsvAsync()
    {
        if (!invoices.Any()) return;
        var csv = TabularExportHelper.BuildCsv(
            "InvoiceNumber,Customer,Job,InvoiceDate,DueDate,Type,Status,Total,BalanceDue",
            BuildInvoiceExportRows().Select(r => r.AsEnumerable()));
        await JS.InvokeVoidAsync("meterpUi.downloadText", "invoices.csv", csv, "text/csv;charset=utf-8");
        ToastService.ShowSuccess("Invoices CSV downloaded.");
    }

    private async Task ExportInvoicesExcelAsync()
    {
        if (!invoices.Any()) return;
        var tsv = TabularExportHelper.BuildExcelTsv(
            "InvoiceNumber\tCustomer\tJob\tInvoiceDate\tDueDate\tType\tStatus\tTotal\tBalanceDue",
            BuildInvoiceExportRows().Select(r => r.AsEnumerable()));
        await JS.InvokeVoidAsync("meterpUi.downloadText", "invoices.xls", tsv, "application/vnd.ms-excel");
        ToastService.ShowSuccess("Invoices Excel file downloaded.");
    }

    private async Task ExportInvoicesPdfAsync()
    {
        if (!invoices.Any()) return;
        var pdf = TabularPdfGenerator.Generate(
            "Invoices Export",
            new[] { "Invoice #", "Customer", "Job", "Date", "Due", "Type", "Status", "Total", "Balance" },
            BuildInvoiceExportRows(),
            _branding);
        await JS.InvokeVoidAsync("meterpUi.downloadBytes", "invoices.pdf", Convert.ToBase64String(pdf), "application/pdf");
        ToastService.ShowSuccess("Invoices PDF downloaded.");
    }
}
