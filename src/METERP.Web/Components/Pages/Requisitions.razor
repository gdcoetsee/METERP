@page "/requisitions"
@using METERP.Application.Interfaces
@using METERP.Application.Services
@using METERP.Common
@using METERP.Domain
@attribute [Authorize(Policy = "Requisitions.View")]
@rendermode InteractiveServer
@inject IStockRequisitionService RequisitionService
@inject IPurchaseOrderService PurchaseOrderService
@inject IProcurementQuoteService QuoteService
@inject ISupplierService SupplierService
@inject ICurrentUserService CurrentUser
@inject ToastService Toast
@inject IJSRuntime JS

<PageTitle>Stock Requisitions</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="h4 mb-1">Stock Requisitions</h1>
        <p class="text-muted small mb-0">Manager → executive approval, reserved stock, RFQ / PO → GRV → issue to job.</p>
    </div>
    <ExportToolbar ShowPdf="false" ShowExcel="false" TestId="requisitions-export" OnExportCsv="ExportCsvAsync" />
</div>

<div data-testid="requisitions-ready">
@if (_loading)
{
    <ListSkeleton Rows="5" TestId="requisitions-skeleton" />
}
else if (_requisitions.Count == 0)
{
    <EmptyState Title="No requisitions"
                Description="Technicians submit material requests from the Field Portal. Approved items can be issued here."
                Icon="📦"
                TestId="requisitions-empty" />
}
else
{
    <div class="table-responsive" data-testid="requisitions-table">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>REQ #</th>
                    <th>Job</th>
                    <th>Status</th>
                    <th>Lines</th>
                    <th>PPE</th>
                    <th>PO</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var req in _requisitions)
                {
                    <tr data-testid="requisition-row">
                        <td><strong>@req.RequisitionNumber</strong></td>
                        <td>@(req.Job?.JobNumber ?? "—")</td>
                        <td>@((MarkupString)GetStatusBadge(req.Status))</td>
                        <td>@req.Lines.Count</td>
                        <td>@(req.IsPpe ? "Yes" : "—")</td>
                        <td>
                            @if (req.PurchaseOrderId.HasValue)
                            {
                                <a href="purchase-orders" class="small">View PO</a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-end text-nowrap">
                            @if (CanManage && req.Status == RequisitionStatus.AwaitingProcurement && !req.PurchaseOrderId.HasValue)
                            {
                                <button type="button" class="btn btn-sm btn-outline-primary me-1" data-testid="requisition-rfq-btn"
                                        @onclick="() => OpenRfqAsync(req)">RFQ</button>
                                <button type="button" class="btn btn-sm btn-warning" data-testid="requisition-create-po-btn"
                                        @onclick="() => ShowCreatePo(req)">Create PO</button>
                            }
                            @if (CanIssue && CanIssueRequisition(req))
                            {
                                <button type="button" class="btn btn-sm btn-success" data-testid="requisition-issue-btn"
                                        @onclick="() => IssueAsync(req)">Issue to job</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
</div>

@if (_showPoModal && _poRequisition != null)
{
    <FormModal IsOpen="true"
               Title="@($"Create PO — {_poRequisition.RequisitionNumber}")"
               TestId="requisition-po-modal"
               OnClose="ClosePoModal">
        <div class="mb-3">
            <label class="form-label">Supplier *</label>
            <select class="form-select" @bind="_selectedSupplierId" data-testid="requisition-po-supplier">
                <option value="">— Select supplier —</option>
                @foreach (var s in _suppliers)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            </select>
            <p class="text-muted small mt-2 mb-0">Creates a draft PO for shortfall quantities not already reserved in stock. Prefer RFQ when comparing multiple suppliers.</p>
        </div>
        <div class="d-flex gap-2 justify-content-end">
            <button type="button" class="btn btn-secondary" @onclick="ClosePoModal">Cancel</button>
            <button type="button" class="btn btn-primary" data-testid="requisition-po-confirm"
                    disabled="@(_selectedSupplierId == Guid.Empty)"
                    @onclick="CreatePoAsync">Create PO</button>
        </div>
    </FormModal>
}

@if (_showRfqModal && _rfqRequisition != null)
{
    <FormModal IsOpen="true"
               Title="@($"Supplier quotes — {_rfqRequisition.RequisitionNumber}")"
               TestId="requisition-rfq-modal"
               OnClose="CloseRfqModal">
        <p class="text-muted small">Add quotes from multiple suppliers, select the winner, then create the PO from the selected quote.</p>

        @if (_rfqQuotes.Count > 0)
        {
            <div class="table-responsive mb-3" data-testid="requisition-rfq-table">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Supplier</th>
                            <th class="text-end">Quoted total</th>
                            <th>Notes</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var q in _rfqQuotes)
                        {
                            <tr class="@(q.IsSelected ? "table-success" : null)" data-testid="requisition-rfq-row">
                                <td>@(q.Supplier?.Name ?? "—")</td>
                                <td class="text-end">R @q.QuotedTotal.ToString("N2")</td>
                                <td class="small">@(q.Notes ?? "—")</td>
                                <td class="text-end">
                                    @if (q.IsSelected)
                                    {
                                        <span class="badge bg-success">Selected</span>
                                    }
                                    else if (CanManage)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-success"
                                                data-testid="requisition-rfq-select"
                                                @onclick="() => SelectQuoteAsync(q)">Select</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted small" data-testid="requisition-rfq-empty">No supplier quotes yet.</p>
        }

        @if (CanManage)
        {
            <div class="border rounded p-3 bg-light mb-3">
                <h6 class="mb-2">Add quote</h6>
                <div class="row g-2">
                    <div class="col-md-5">
                        <select class="form-select form-select-sm" @bind="_rfqSupplierId" data-testid="requisition-rfq-supplier">
                            <option value="@Guid.Empty">— Supplier —</option>
                            @foreach (var s in _suppliers)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <input type="number" step="0.01" min="0" class="form-control form-control-sm"
                               @bind="_rfqTotal" placeholder="Total" data-testid="requisition-rfq-total" />
                    </div>
                    <div class="col-md-4">
                        <input class="form-control form-control-sm" @bind="_rfqNotes" placeholder="Notes (optional)"
                               data-testid="requisition-rfq-notes" />
                    </div>
                </div>
                <button type="button" class="btn btn-sm btn-primary mt-2" data-testid="requisition-rfq-add"
                        @onclick="AddQuoteAsync">Add quote</button>
            </div>
        }

        <div class="d-flex gap-2 justify-content-end">
            <button type="button" class="btn btn-secondary" @onclick="CloseRfqModal">Close</button>
            @if (CanManage && _rfqQuotes.Any(q => q.IsSelected) && !_rfqRequisition.PurchaseOrderId.HasValue)
            {
                <button type="button" class="btn btn-warning" data-testid="requisition-rfq-create-po"
                        @onclick="CreatePoFromSelectedAsync">Create PO from selected</button>
            }
        </div>
    </FormModal>
}

<ConfirmDialogHost />

@code {
    private List<StockRequisition> _requisitions = new();
    private List<Supplier> _suppliers = new();
    private bool _loading = true;
    private bool _showPoModal;
    private StockRequisition? _poRequisition;
    private Guid _selectedSupplierId;

    private bool _showRfqModal;
    private StockRequisition? _rfqRequisition;
    private List<ProcurementSupplierQuote> _rfqQuotes = new();
    private Guid _rfqSupplierId;
    private decimal _rfqTotal;
    private string _rfqNotes = "";

    [Inject] private ConfirmService Confirm { get; set; } = default!;

    private bool CanIssue => CurrentUser.Permissions.Contains(Permissions.RequisitionsManage);
    private bool CanManage => CurrentUser.Permissions.Contains(Permissions.PurchaseOrdersManage)
        || CurrentUser.Permissions.Contains(Permissions.RequisitionsManage);

    protected override async Task OnInitializedAsync()
    {
        _suppliers = (await SupplierService.GetAllAsync()).ToList();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _requisitions = (await RequisitionService.GetAllAsync(pageSize: 50)).ToList();
        }
        finally
        {
            _loading = false;
        }
    }

    private void ShowCreatePo(StockRequisition req)
    {
        _poRequisition = req;
        _selectedSupplierId = _suppliers.FirstOrDefault()?.Id ?? Guid.Empty;
        _showPoModal = true;
    }

    private void ClosePoModal()
    {
        _showPoModal = false;
        _poRequisition = null;
        _selectedSupplierId = Guid.Empty;
    }

    private async Task CreatePoAsync()
    {
        if (_poRequisition == null || _selectedSupplierId == Guid.Empty) return;

        try
        {
            await PurchaseOrderService.CreateFromRequisitionAsync(_poRequisition.Id, _selectedSupplierId);
            Toast.ShowSuccess($"PO created for {_poRequisition.RequisitionNumber} — mark sent then receive via GRV.");
            ClosePoModal();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private async Task OpenRfqAsync(StockRequisition req)
    {
        _rfqRequisition = req;
        _rfqSupplierId = _suppliers.FirstOrDefault()?.Id ?? Guid.Empty;
        _rfqTotal = 0;
        _rfqNotes = "";
        _showRfqModal = true;
        await ReloadRfqQuotesAsync();
    }

    private void CloseRfqModal()
    {
        _showRfqModal = false;
        _rfqRequisition = null;
        _rfqQuotes = new();
    }

    private async Task ReloadRfqQuotesAsync()
    {
        if (_rfqRequisition == null) return;
        _rfqQuotes = (await QuoteService.GetForRequisitionAsync(_rfqRequisition.Id)).ToList();
    }

    private async Task AddQuoteAsync()
    {
        if (_rfqRequisition == null || _rfqSupplierId == Guid.Empty)
        {
            Toast.ShowError("Select a supplier.");
            return;
        }

        try
        {
            await QuoteService.AddQuoteAsync(
                _rfqRequisition.Id,
                _rfqSupplierId,
                _rfqTotal,
                string.IsNullOrWhiteSpace(_rfqNotes) ? null : _rfqNotes.Trim());
            Toast.ShowSuccess("Supplier quote added.");
            _rfqTotal = 0;
            _rfqNotes = "";
            await ReloadRfqQuotesAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private async Task SelectQuoteAsync(ProcurementSupplierQuote quote)
    {
        if (CurrentUser.UserId is not { } userId)
        {
            Toast.ShowError("User session required.");
            return;
        }

        try
        {
            await QuoteService.SelectQuoteAsync(quote.Id, userId);
            Toast.ShowSuccess("Quote selected.");
            await ReloadRfqQuotesAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private async Task CreatePoFromSelectedAsync()
    {
        if (_rfqRequisition == null) return;

        try
        {
            await QuoteService.CreatePoFromSelectedQuoteAsync(_rfqRequisition.Id);
            Toast.ShowSuccess($"PO created from selected quote for {_rfqRequisition.RequisitionNumber}.");
            CloseRfqModal();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private async Task IssueAsync(StockRequisition req)
    {
        if (CurrentUser.UserId is not { } userId) return;

        var ok = await Confirm.ConfirmAsync(
            $"Issue reserved stock for {req.RequisitionNumber} to job {req.Job?.JobNumber}?",
            "Issue stock",
            confirmLabel: "Issue",
            confirmVariant: "success");
        if (!ok) return;

        try
        {
            if (!await RequisitionService.IssueAsync(req.Id, userId))
            {
                Toast.ShowError("Nothing to issue or requisition is not approved.");
                return;
            }

            Toast.ShowSuccess($"{req.RequisitionNumber} issued — stock moved to job.");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private async Task ExportCsvAsync()
    {
        if (_requisitions.Count == 0) return;

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("RequisitionNumber,Job,Status,Lines,IsPpe");
        foreach (var r in _requisitions)
        {
            sb.AppendLine($"{r.RequisitionNumber},{r.Job?.JobNumber},{r.Status},{r.Lines.Count},{r.IsPpe}");
        }

        await JS.InvokeVoidAsync("meterpUi.downloadText", "requisitions.csv", sb.ToString(), "text/csv;charset=utf-8");
        Toast.ShowSuccess("Requisitions CSV downloaded.");
    }

    private static bool CanIssueRequisition(StockRequisition req) =>
        req.Status is RequisitionStatus.Approved
            or RequisitionStatus.AwaitingProcurement
            or RequisitionStatus.ProcurementOrdered
        && req.Lines.Any(l => !l.IsDeleted && l.QuantityReserved > l.QuantityIssued);

    private static string GetStatusBadge(RequisitionStatus status) => status switch
    {
        RequisitionStatus.PendingManager => "<span class=\"badge bg-secondary\">Manager</span>",
        RequisitionStatus.PendingExecutive => "<span class=\"badge bg-warning text-dark\">Executive</span>",
        RequisitionStatus.Approved => "<span class=\"badge bg-success\">Approved</span>",
        RequisitionStatus.Issued => "<span class=\"badge bg-primary\">Issued</span>",
        RequisitionStatus.AwaitingProcurement => "<span class=\"badge bg-danger\">Procure</span>",
        RequisitionStatus.ProcurementOrdered => "<span class=\"badge bg-info text-dark\">PO Ordered</span>",
        RequisitionStatus.Rejected => "<span class=\"badge bg-dark\">Rejected</span>",
        _ => $"<span class=\"badge bg-light text-dark\">{status}</span>"
    };
}
