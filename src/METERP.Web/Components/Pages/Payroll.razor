@page "/payroll"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject ToastService ToastService

<PageTitle>Payroll & HR</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Payroll & HR <span class="badge bg-secondary">Employee Management</span></h1>
        <p class="text-muted mb-0">Employee records, labor-linked payslips, leave. Full integration with JobLabor for accurate costing.</p>
    </div>
    <button class="btn btn-primary" @onclick="GeneratePayslips">Generate Monthly Payslips (Stub)</button>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Employee</th>
                <th>Role / Rate</th>
                <th>Hours This Month</th>
                <th>Gross Pay</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var e in employees)
            {
                <tr>
                    <td><strong>@e.Name</strong></td>
                    <td>@e.Role<br /><small>R @e.HourlyRate/hr</small></td>
                    <td>@e.Hours</td>
                    <td>R @e.Gross.ToString("N0")</td>
                    <td><span class="badge bg-success">Active</span></td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewPayslip(e)">View Payslip</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (selectedEmp != null)
{
    <div class="card mt-4 border-primary">
        <div class="card-header bg-primary text-white">Payslip for @selectedEmp.Name - @DateTime.Now.ToString("MMMM yyyy")</div>
        <div class="card-body">
            <p>Hours: @selectedEmp.Hours * R @selectedEmp.HourlyRate = R @(selectedEmp.Hours * selectedEmp.HourlyRate).ToString("N0")</p>
            <p>Deductions (stub): R 1,200 (UIF, etc.)</p>
            <p class="fs-5"><strong>Net Pay: R @(selectedEmp.Gross - 1200).ToString("N0")</strong></p>
            <button class="btn btn-success btn-sm" @onclick="DownloadPayslip">Download PDF Payslip (Stub - uses AI PDF generator pattern)</button>
            <small class="text-muted d-block mt-2">Linked to actual JobLabor for accurate costing. Full SARS-compliant in production.</small>
        </div>
    </div>
}

@code {
    private List<EmployeePay> employees = new()
    {
        new EmployeePay { Name = "Thabo Molefe", Role = "Artisan Electrician", HourlyRate = 185, Hours = 168, Gross = 31080 },
        new EmployeePay { Name = "Johan van der Berg", Role = "Site Supervisor", HourlyRate = 250, Hours = 160, Gross = 40000 }
    };
    private EmployeePay? selectedEmp;

    private void ViewPayslip(EmployeePay e) => selectedEmp = e;

    private void GeneratePayslips()
    {
        ToastService.ShowSuccess("Payslips generated for all active employees. Linked to JobLabor records.");
    }

    private void DownloadPayslip()
    {
        ToastService.ShowInfo("Payslip PDF generated using professional template (similar to Job closeout PDF). Full integration in production.");
    }

    private class EmployeePay
    {
        public string Name { get; set; } = "";
        public string Role { get; set; } = "";
        public decimal HourlyRate { get; set; }
        public int Hours { get; set; }
        public decimal Gross { get; set; }
    }
}
