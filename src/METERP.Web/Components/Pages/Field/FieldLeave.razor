@page "/field/leave"
@layout Layout.FieldLayout
@using METERP.Application.Interfaces
@using METERP.Application.Services
@using METERP.Domain
@attribute [Authorize(Policy = "Field.View")]
@rendermode InteractiveServer
@inject ILeaveService LeaveService
@inject ICurrentUserService CurrentUser
@inject ToastService Toast

<PageTitle>Request Leave — Field</PageTitle>

<h1 class="h5 mb-3">Request Leave</h1>

@if (_loading)
{
    <ListSkeleton Rows="3" TestId="field-leave-skeleton" />
}
else if (_employee == null)
{
    <EmptyState Title="No employee profile linked"
                Description="Ask HR to link your login to an employee record before requesting leave."
                Icon="🗓️"
                TestId="field-leave-no-employee" />
}
else
{
    <div class="card mb-3" data-testid="field-leave-balance">
        <div class="card-body py-3">
            <div class="small text-muted">Available leave</div>
            <div class="fs-4 fw-semibold">@_availableDays.ToString("N1") days</div>
            <div class="small text-muted">@_employee.FirstName @_employee.LastName</div>
        </div>
    </div>

    <button type="button" class="btn btn-primary w-100 mb-3" data-testid="field-leave-request-btn" @onclick="OpenForm">
        Request leave
    </button>

    @if (_requests.Count > 0)
    {
        <h2 class="h6 text-muted">Recent requests</h2>
        <div class="list-group" data-testid="field-leave-list">
            @foreach (var req in _requests.Take(5))
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between">
                        <span>@req.StartDate.ToString("dd MMM") – @req.EndDate.ToString("dd MMM yyyy")</span>
                        <span class="badge bg-secondary">@req.Status</span>
                    </div>
                    <div class="small text-muted">@req.DaysRequested.ToString("N1") day(s)</div>
                </div>
            }
        </div>
    }
}

<FormModal IsOpen="_open"
           Title="Leave request"
           TestId="field-leave-modal"
           OnClose="CloseForm">
    <ChildContent>
        <div class="mb-3">
            <label class="form-label" for="leave-from">From</label>
            <input id="leave-from" type="date" class="form-control form-control-lg" @bind="_startDate" data-testid="field-leave-from" />
        </div>
        <div class="mb-3">
            <label class="form-label" for="leave-to">To</label>
            <input id="leave-to" type="date" class="form-control form-control-lg" @bind="_endDate" data-testid="field-leave-to" />
        </div>
        <div class="mb-3">
            <label class="form-label" for="leave-reason">Reason</label>
            <textarea id="leave-reason" class="form-control" rows="2" @bind="_reason" data-testid="field-leave-reason"></textarea>
        </div>
    </ChildContent>
    <Footer>
        <button type="button" class="btn btn-outline-secondary" @onclick="CloseForm">Cancel</button>
        <button type="button" class="btn btn-primary" data-testid="field-leave-submit" @onclick="SubmitAsync">Submit</button>
    </Footer>
</FormModal>

@code {
    private Employee? _employee;
    private decimal _availableDays;
    private List<LeaveRequest> _requests = new();
    private bool _loading = true;
    private bool _open;
    private DateTime _startDate = DateTime.Today.AddDays(7);
    private DateTime _endDate = DateTime.Today.AddDays(9);
    private string _reason = "";

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            if (CurrentUser.UserId is { } userId)
            {
                _employee = await LeaveService.GetEmployeeForUserAsync(userId);
                if (_employee != null)
                {
                    _availableDays = await LeaveService.GetAvailableLeaveDaysAsync(_employee.Id);
                    _requests = (await LeaveService.GetRequestsForEmployeeAsync(_employee.Id)).ToList();
                }
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenForm() => _open = true;
    private void CloseForm() => _open = false;

    private async Task SubmitAsync()
    {
        if (_employee == null) return;

        if (_endDate < _startDate)
        {
            Toast.ShowInfo("End date must be on or after start date.");
            return;
        }

        try
        {
            await LeaveService.SubmitRequestAsync(new LeaveRequest
            {
                EmployeeId = _employee.Id,
                StartDate = _startDate,
                EndDate = _endDate,
                Reason = _reason,
                IsPaid = true
            });

            Toast.ShowSuccess("Leave submitted — awaiting division manager approval.");
            CloseForm();
            _availableDays = await LeaveService.GetAvailableLeaveDaysAsync(_employee.Id);
            _requests = (await LeaveService.GetRequestsForEmployeeAsync(_employee.Id)).ToList();
        }
        catch (InvalidOperationException ex)
        {
            Toast.ShowInfo(ex.Message);
        }
    }
}