@page "/field/stock"
@layout Layout.FieldLayout
@using METERP.Application.Interfaces
@using METERP.Application.Services
@using METERP.Domain
@attribute [Authorize(Policy = "Field.View")]
@rendermode InteractiveServer
@inject IStockRequisitionService RequisitionService
@inject IInventoryService InventoryService
@inject IJobService JobService
@inject ICurrentUserService CurrentUser
@inject ToastService Toast

<PageTitle>Request Stock — Field</PageTitle>

<div>
<h1 class="h5 mb-3">Request Stock</h1>

@if (_loading)
{
    <ListSkeleton Rows="3" TestId="field-stock-skeleton" />
}
else
{
    <div data-testid="field-stock-ready">
    <button type="button" class="btn btn-primary w-100 mb-3" data-testid="field-stock-request-btn" @onclick="OpenForm">
        New requisition
    </button>

    @if (_recent.Count > 0)
    {
        <h2 class="h6 text-muted">Recent requests</h2>
        <div class="list-group" data-testid="field-stock-list">
            @foreach (var req in _recent.Take(5))
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between">
                        <strong>@req.RequisitionNumber</strong>
                        <span class="badge bg-secondary">@req.Status</span>
                    </div>
                    <div class="small text-muted">@(req.Job?.JobNumber ?? "—") · @req.Lines.Count line(s)</div>
                </div>
            }
        </div>
    }
    </div>
}
</div>

@if (_open)
{
    <FormModal IsOpen="true"
               Title="Stock requisition"
               TestId="field-stock-modal"
               OnClose="CloseForm">
        <div class="mb-3">
            <label class="form-label" for="field-stock-job">Job</label>
            <select id="field-stock-job" class="form-select form-control-lg" @bind="_jobId" data-testid="field-stock-job">
                <option value="@Guid.Empty">Select job…</option>
                @foreach (var job in _jobs)
                {
                    <option value="@job.Id">@job.JobNumber — @job.Title</option>
                }
            </select>
        </div>

        <div class="border rounded p-2 mb-3" data-testid="field-stock-lines">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <strong class="small">Lines (@_lines.Count)</strong>
            </div>
            @if (_lines.Count == 0)
            {
                <p class="text-muted small mb-2">Add one or more stock items below.</p>
            }
            else
            {
                <ul class="list-group list-group-flush mb-2">
                    @foreach (var line in _lines)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-1" data-testid="field-stock-line">
                            <span class="small">@line.Label × @line.Quantity.ToString("N2")</span>
                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveLine(line)">Remove</button>
                        </li>
                    }
                </ul>
            }

            <div class="mb-2">
                <label class="form-label small" for="field-stock-search">Add item</label>
                <input id="field-stock-search" class="form-control" placeholder="Search SKU or name…"
                       value="@_search" @oninput="OnSearchInput" data-testid="field-stock-search" />
                @if (_items.Count > 0)
                {
                    <select class="form-select mt-2" @bind="_itemId" data-testid="field-stock-item">
                        @foreach (var item in _items)
                        {
                            <option value="@item.Id">@item.Sku — @item.Name (avail: @item.QuantityAvailable.ToString("N0"))</option>
                        }
                    </select>
                }
            </div>
            <div class="row g-2 align-items-end">
                <div class="col-6">
                    <label class="form-label small" for="field-stock-qty">Qty</label>
                    <input id="field-stock-qty" type="number" min="0.01" step="0.01" class="form-control"
                           @bind="_quantity" data-testid="field-stock-qty" />
                </div>
                <div class="col-6">
                    <button type="button" class="btn btn-outline-primary w-100" data-testid="field-stock-add-line" @onclick="AddLine">
                        + Add stocked line
                    </button>
                </div>
            </div>

            <hr class="my-2" />
            <p class="small text-muted mb-1">Need something <strong>not in the stock list</strong>?</p>
            <div class="mb-2">
                <input class="form-control" placeholder="Describe item (e.g. 50mm galvanised conduit special)"
                       @bind="_freeTextDescription" data-testid="field-stock-free-description" />
            </div>
            <div class="row g-2 align-items-end">
                <div class="col-4">
                    <input type="number" min="0.01" step="0.01" class="form-control" placeholder="Qty"
                           @bind="_freeTextQty" data-testid="field-stock-free-qty" />
                </div>
                <div class="col-4">
                    <input type="number" min="0" step="0.01" class="form-control" placeholder="Est. unit R"
                           @bind="_freeTextCost" data-testid="field-stock-free-cost" />
                </div>
                <div class="col-4">
                    <button type="button" class="btn btn-outline-warning w-100" data-testid="field-stock-add-free-line" @onclick="AddFreeTextLine">
                        + Non-catalog
                    </button>
                </div>
            </div>
        </div>

        <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" id="field-stock-ppe" @bind="_isPpe" data-testid="field-stock-ppe" />
            <label class="form-check-label" for="field-stock-ppe">PPE / safety equipment</label>
        </div>
        <div class="mb-3">
            <label class="form-label" for="field-stock-notes">Notes</label>
            <textarea id="field-stock-notes" class="form-control" rows="2" @bind="_notes" data-testid="field-stock-notes"></textarea>
        </div>
        <div class="d-flex gap-2 justify-content-end">
            <button type="button" class="btn btn-outline-secondary" @onclick="CloseForm">Cancel</button>
            <button type="button" class="btn btn-primary" data-testid="field-stock-submit" @onclick="SubmitAsync">Submit for approval</button>
        </div>
    </FormModal>
}

@code {
    private sealed class DraftLine
    {
        public Guid? InventoryItemId { get; init; }
        public string Label { get; init; } = "";
        public decimal Quantity { get; init; }
        public decimal EstimatedUnitCost { get; init; }
        public bool IsNonCatalog => !InventoryItemId.HasValue;
    }

    private bool _loading = true;
    private bool _open;
    private List<Job> _jobs = new();
    private List<InventoryItem> _items = new();
    private List<StockRequisition> _recent = new();
    private List<DraftLine> _lines = new();
    private Guid _jobId;
    private Guid _itemId;
    private string _search = "";
    private decimal _quantity = 1;
    private bool _isPpe;
    private string _notes = "";
    private string _freeTextDescription = "";
    private decimal _freeTextQty = 1;
    private decimal _freeTextCost;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _jobs = (await JobService.GetAllAsync(pageSize: 50)).Where(j => j.IsOpenForOperations()).ToList();
            _recent = (await RequisitionService.GetAllAsync(pageSize: 10)).ToList();
            await LoadItemsAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadItemsAsync()
    {
        _items = (await InventoryService.GetAllItemsAsync(
            string.IsNullOrWhiteSpace(_search) ? null : _search,
            pageSize: 20)).ToList();
        if (_items.Count > 0 && !_items.Any(i => i.Id == _itemId))
            _itemId = _items[0].Id;
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? "";
        await LoadItemsAsync();
    }

    private async Task OpenForm()
    {
        _jobId = _jobs.FirstOrDefault()?.Id ?? Guid.Empty;
        _quantity = 1;
        _isPpe = false;
        _notes = "";
        _freeTextDescription = "";
        _freeTextQty = 1;
        _freeTextCost = 0;
        _lines = new();
        _open = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task CloseForm()
    {
        _open = false;
        await InvokeAsync(StateHasChanged);
    }

    private void AddLine()
    {
        if (_itemId == Guid.Empty || _quantity <= 0)
        {
            Toast.ShowError("Select an item and quantity.");
            return;
        }

        var item = _items.FirstOrDefault(i => i.Id == _itemId);
        var label = item != null ? $"{item.Sku} — {item.Name}" : _itemId.ToString("N")[..8];
        var existing = _lines.FirstOrDefault(l => l.InventoryItemId == _itemId);
        if (existing != null)
        {
            _lines.Remove(existing);
            _lines.Add(new DraftLine
            {
                InventoryItemId = _itemId,
                Label = label,
                Quantity = existing.Quantity + _quantity
            });
        }
        else
        {
            _lines.Add(new DraftLine
            {
                InventoryItemId = _itemId,
                Label = label,
                Quantity = _quantity
            });
        }

        _quantity = 1;
    }

    private void AddFreeTextLine()
    {
        if (string.IsNullOrWhiteSpace(_freeTextDescription) || _freeTextQty <= 0)
        {
            Toast.ShowError("Enter a description and quantity for non-catalog items.");
            return;
        }

        var desc = _freeTextDescription.Trim();
        _lines.Add(new DraftLine
        {
            InventoryItemId = null,
            Label = $"[Non-catalog] {desc}",
            Quantity = _freeTextQty,
            EstimatedUnitCost = _freeTextCost
        });
        _freeTextDescription = "";
        _freeTextQty = 1;
        _freeTextCost = 0;
    }

    private void RemoveLine(DraftLine line) => _lines.Remove(line);

    private async Task SubmitAsync()
    {
        if (CurrentUser.UserId is not { } userId)
        {
            Toast.ShowError("Not signed in.");
            return;
        }

        if (_jobId == Guid.Empty)
        {
            Toast.ShowError("Select a job.");
            return;
        }

        if (_lines.Count == 0)
        {
            Toast.ShowError("Add at least one stock line.");
            return;
        }

        try
        {
            var req = new StockRequisition
            {
                JobId = _jobId,
                RequestedByUserId = userId,
                IsPpe = _isPpe,
                Notes = _notes,
                Lines = _lines.Select(l => new StockRequisitionLine
                {
                    InventoryItemId = l.InventoryItemId,
                    Description = l.IsNonCatalog ? l.Label.Replace("[Non-catalog] ", "", StringComparison.Ordinal) : l.Label,
                    QuantityRequested = l.Quantity,
                    EstimatedUnitCost = l.EstimatedUnitCost
                }).ToList()
            };

            await RequisitionService.SubmitAsync(req);
            Toast.ShowSuccess($"Requisition submitted ({_lines.Count} line(s)) — manager then executive approval.");
            _recent = (await RequisitionService.GetAllAsync(pageSize: 10)).ToList();
            await CloseForm();
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }
}
