@page "/field/jobs"
@layout Layout.FieldLayout
@using METERP.Application.Interfaces
@using METERP.Application.Services
@using METERP.Domain
@attribute [Authorize(Policy = "Field.View")]
@rendermode InteractiveServer
@inject IJobService JobService
@inject IFieldReportService FieldReportService
@inject ICurrentUserService CurrentUser
@inject ToastService Toast

<PageTitle>My Jobs — Field</PageTitle>

<div>
<h1 class="h5 mb-3">My Jobs</h1>

@if (_loading)
{
    <ListSkeleton Rows="4" TestId="field-jobs-skeleton" />
}
else if (_jobs.Count == 0)
{
    <div data-testid="field-jobs-ready">
        <EmptyState Title="No jobs assigned"
                    Description="When you are assigned to jobs, they will appear here for field reporting."
                    Icon="🔧"
                    TestId="field-jobs-empty" />
    </div>
}
else
{
    <div data-testid="field-jobs-ready">
        <div class="list-group" data-testid="field-jobs-list">
            @foreach (var job in _jobs)
            {
                <div class="list-group-item" data-testid="field-job-row">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <strong>@job.JobNumber</strong>
                            <div class="small">@job.Title</div>
                            <div class="small text-muted">@(job.Customer?.Name ?? "—")</div>
                        </div>
                        <span class="badge bg-secondary">@job.Status</span>
                    </div>
                    <button type="button" class="btn btn-primary btn-sm mt-2 w-100"
                            data-testid="field-submit-report"
                            @onclick="() => ShowReportForm(job.Id)">
                        Submit field report
                    </button>
                </div>
            }
        </div>
    </div>
}
</div>

@if (_showModal && _reportJob != null)
{
    <FormModal IsOpen="true"
               Title="Field report"
               TestId="field-report-modal"
               OnClose="CloseModal">
        <p class="small text-muted mb-3">Job: <strong>@_reportJob.JobNumber</strong> — @_reportJob.Title</p>
        <div class="mb-3">
            <label class="form-label">Work date</label>
            <input type="date" class="form-control" @bind="_workDate" data-testid="field-report-work-date" />
        </div>
        <div class="mb-3">
            <label class="form-label">Hours worked</label>
            <input type="number" step="0.5" class="form-control" @bind="_hoursWorked" data-testid="field-report-hours" />
        </div>
        <div class="mb-3">
            <label class="form-label">Travel cost (R)</label>
            <input type="number" step="0.01" class="form-control" @bind="_travelCost" data-testid="field-report-travel" />
        </div>
        <div class="mb-3">
            <label class="form-label">Materials used</label>
            <textarea class="form-control" rows="2" @bind="_materialsUsed" data-testid="field-report-materials"></textarea>
        </div>
        <div class="mb-0">
            <label class="form-label">Comments</label>
            <textarea class="form-control" rows="2" @bind="_comments" data-testid="field-report-comments"></textarea>
        </div>
        <div class="d-flex gap-2 justify-content-end mt-3">
            <button type="button" class="btn btn-outline-secondary" @onclick="CloseModal">Cancel</button>
            <button type="button" class="btn btn-success" data-testid="field-report-modal-save" @onclick="SubmitReportAsync">Submit</button>
        </div>
    </FormModal>
}

@code {
    private List<Job> _jobs = new();
    private bool _loading = true;
    private bool _showModal;
    private Job? _reportJob;
    private DateTime _workDate = DateTime.UtcNow.Date;
    private decimal _hoursWorked = 8m;
    private decimal _travelCost;
    private string? _materialsUsed;
    private string? _comments;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            var all = await JobService.GetAllAsync(page: 1, pageSize: 50);
            _jobs = all
                .Where(j => j.Status is JobStatus.Scheduled or JobStatus.InProgress or JobStatus.OnHold)
                .OrderBy(j => j.ScheduledStart ?? DateTime.MaxValue)
                .ToList();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ShowReportForm(Guid jobId)
    {
        _reportJob = _jobs.FirstOrDefault(j => j.Id == jobId);
        if (_reportJob == null)
            return;

        _workDate = DateTime.UtcNow.Date;
        _hoursWorked = 8m;
        _travelCost = 0m;
        _materialsUsed = null;
        _comments = null;
        _showModal = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task CloseModal()
    {
        _showModal = false;
        _reportJob = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SubmitReportAsync()
    {
        if (_reportJob == null || CurrentUser.UserId is not { } userId) return;

        try
        {
            await FieldReportService.SubmitAsync(new FieldReport
            {
                JobId = _reportJob.Id,
                SubmittedByUserId = userId,
                WorkDate = _workDate,
                HoursWorked = _hoursWorked,
                TravelCost = _travelCost,
                MaterialsUsed = _materialsUsed,
                Comments = _comments
            });

            Toast.ShowSuccess($"Field report submitted for {_reportJob.JobNumber} — awaiting manager approval.");
            CloseModal();
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }
}