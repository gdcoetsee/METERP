@page "/sales-orders"
@using METERP.Application.Services
@using METERP.Application.Interfaces
@using METERP.Domain
@using METERP.Common
@using METERP.Infrastructure.Seeding
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.JSInterop
@attribute [Authorize(Policy = "SalesOrders.View")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ISalesOrderService SalesOrderService
@inject IQuoteService QuoteService
@inject ICurrentUserService CurrentUserService
@inject IJSRuntime JS
@inject ToastService ToastService

<PageTitle>Sales Orders</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h1 class="mb-0">Sales Orders</h1>
    <ExportToolbar ShowPdf="false" ShowExcel="false" TestId="sales-orders-export" OnExportCsv="ExportCsvAsync" Disabled="@_loading" />
</div>

<div class="mb-3" style="max-width: 420px;">
    <div class="input-group">
        <input type="search" class="form-control" placeholder="Search SO # or customer..."
               value="@searchTerm" @oninput="OnSearchInput" data-testid="sales-orders-search" />
        @if (!string.IsNullOrEmpty(searchTerm))
        {
            <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch" title="Clear search">Clear</button>
        }
    </div>
</div>

@if (_loading)
{
    <p data-testid="sales-orders-loading"><em>Loading sales orders...</em></p>
}
else if (sos == null || !sos.Any())
{
    <div class="alert alert-info" data-testid="sales-orders-empty">No sales orders yet. Convert quotes to create them as the fulfillment step before jobs.</div>
}
else
{
    <div class="table-responsive" data-testid="sales-orders-ready">
        <table class="table table-hover" data-testid="sales-orders-table">
            <thead>
                <tr>
                    <th>SO #</th>
                    <th>Customer / Quote</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th class="text-end">Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var so in sos)
                {
                    <tr data-testid="@GetSalesOrderRowTestId(so)">
                        <td><strong>@so.SoNumber</strong></td>
                        <td>@(so.Customer?.Name ?? "—")<br /><small>@(so.Quote?.QuoteNumber ?? "")</small></td>
                        <td>@so.SoDate.ToString("yyyy-MM-dd")</td>
                        <td>@GetStatusBadge(so.Status)</td>
                        <td class="text-end">R @so.Total.ToString("N2")</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1" data-testid="sales-order-view" @onclick="() => ViewSO(so)">View</button>
                            @if (UserCanManage && so.Status == SalesOrderStatus.Draft)
                            {
                                <button class="btn btn-sm btn-success" data-testid="sales-order-convert-to-job" @onclick="() => ConvertToJob(so)">Convert to Job</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-2">
        <button class="btn btn-sm btn-outline-secondary" @onclick="PreviousPage" disabled="@(currentPage <= 1)">Previous</button>
        <span class="text-muted small">Page @currentPage</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="NextPage" disabled="@(sos.Count < PageSize)">Next</button>
    </div>
}

@if (selectedSO != null)
{
    <div class="card mt-4 border-primary" data-testid="sales-order-detail">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">@selectedSO.SoNumber — @(selectedSO.Customer?.Name)</h5>
            <button class="btn btn-sm btn-light" @onclick="CloseSOView">Close</button>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <strong>Status:</strong> @GetStatusBadge(selectedSO.Status)<br />
                    <strong>Delivery:</strong> @(selectedSO.DeliveryDate?.ToString("yyyy-MM-dd") ?? "—")
                </div>
                <div class="col-md-6 text-md-end">
                    <div>Subtotal: <strong>R @selectedSO.Subtotal.ToString("N2")</strong></div>
                    <div>Tax: R @selectedSO.Tax.ToString("N2")</div>
                    <div class="fs-5">Total: <strong>R @selectedSO.Total.ToString("N2")</strong></div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(selectedSO.Notes))
            {
                <div class="mb-3"><strong>Notes:</strong> @selectedSO.Notes</div>
            }

            <h6>Lines (@selectedSO.Lines.Count(l => !l.IsDeleted))</h6>

            @if (selectedSO.Lines.Any(l => !l.IsDeleted))
            {
                <table class="table table-sm">
                    <thead>
                        <tr><th>Description</th><th class="text-end">Qty</th><th class="text-end">Line Total</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var l in selectedSO.Lines.Where(x => !x.IsDeleted))
                        {
                            <tr>
                                <td>@l.Description</td>
                                <td class="text-end">@l.Quantity @l.Unit</td>
                                <td class="text-end">R @l.LineTotal.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            @if (UserCanManage && (selectedSO.Status == SalesOrderStatus.Draft || selectedSO.Status == SalesOrderStatus.Confirmed))
            {
                <button class="btn btn-success btn-sm" data-testid="sales-order-convert-to-job" @onclick="() => ConvertToJob(selectedSO)">Convert to Job</button>
            }
        </div>
    </div>
}

@code {
    private List<SalesOrder> sos = new();
    private SalesOrder? selectedSO;
    private string searchTerm = string.Empty;
    private int currentPage = 1;
    private const int PageSize = 10;
    private bool _loading = true;
    private int _sosLoadGeneration;
    private readonly ComponentAsyncGate _dataGate = new();

    private bool UserCanManage => CurrentUserService.Permissions.Contains(Permissions.SalesOrdersManage);

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            await LoadSOs();
        }
        finally
        {
            _loading = false;
        }
    }

    private Task LoadSOs() => _dataGate.RunAsync(async () =>
    {
        var generation = ++_sosLoadGeneration;
        var term = string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm.Trim();
        var loaded = (await SalesOrderService.GetAllAsync(term, currentPage, PageSize)).ToList();
        if (generation != _sosLoadGeneration)
            return;
        sos = loaded;
    });

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        currentPage = 1;
        await LoadSOs();
    }

    private async Task ClearSearch()
    {
        searchTerm = string.Empty;
        currentPage = 1;
        await LoadSOs();
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadSOs();
        }
    }

    private async Task NextPage()
    {
        currentPage++;
        await LoadSOs();
    }

    private Task ViewSO(SalesOrder so) => _dataGate.RunAsync(async () =>
    {
        selectedSO = null;
        selectedSO = await SalesOrderService.GetByIdAsync(so.Id);
        await InvokeAsync(StateHasChanged);
    });

    private void CloseSOView()
    {
        selectedSO = null;
    }

    private Task ConvertToJob(SalesOrder so) => _dataGate.RunAsync(async () =>
    {
        if (!await ConfirmDelete("Convert this Sales Order to a Job?")) return;

        try
        {
            var job = await SalesOrderService.ConvertToJobAsync(so.Id);
            ToastService.ShowSuccess($"Sales Order converted to Job {job.JobNumber}.");
            selectedSO = await SalesOrderService.GetByIdAsync(so.Id);
            await LoadSOs();
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Conversion failed: {ex.Message}");
        }
    });

    private async Task<bool> ConfirmDelete(string message)
    {
        try { return await JS.InvokeAsync<bool>("confirm", message); }
        catch { return false; }
    }

    private static string GetSalesOrderRowTestId(SalesOrder so)
    {
        if (so.Notes != null
            && so.Notes.Contains(E2EConvertibleSalesOrderSeeder.DemoNotesMarker, StringComparison.OrdinalIgnoreCase)
            && so.Status == SalesOrderStatus.Confirmed)
            return "sales-order-row-e2e-convertible";

        return "sales-order-row";
    }

    private static string GetStatusBadge(SalesOrderStatus status)
    {
        return status switch
        {
            SalesOrderStatus.Draft => "<span class=\"badge bg-secondary\">Draft</span>",
            SalesOrderStatus.Confirmed => "<span class=\"badge bg-info\">Confirmed</span>",
            SalesOrderStatus.InProgress => "<span class=\"badge bg-primary\">In Progress</span>",
            SalesOrderStatus.Completed => "<span class=\"badge bg-success\">Completed</span>",
            SalesOrderStatus.Cancelled => "<span class=\"badge bg-dark\">Cancelled</span>",
            _ => status.ToString()
        };
    }

    private async Task ExportCsvAsync()
    {
        if (sos == null || !sos.Any()) return;

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("SoNumber,Customer,Quote,Status,SoDate,Total");
        foreach (var so in sos)
        {
            sb.AppendLine($"{so.SoNumber},{so.Customer?.Name},{so.Quote?.QuoteNumber},{so.Status},{so.SoDate:yyyy-MM-dd},{so.Total}");
        }

        await JS.InvokeVoidAsync("meterpUi.downloadText", "sales-orders.csv", sb.ToString(), "text/csv;charset=utf-8");
        ToastService.ShowSuccess("Sales orders CSV downloaded.");
    }
}
