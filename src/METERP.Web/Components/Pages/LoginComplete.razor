@page "/login-complete"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using METERP.Infrastructure.Identity
@using METERP.Infrastructure.Persistence
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IServiceScopeFactory ScopeFactory
@inject METERP.Application.Interfaces.ITenantProvider TenantProvider
@inject METERP.Application.Services.IPendingTwoFactorChallengeStore ChallengeStore
@inject NavigationManager Navigation
@inject IWebHostEnvironment Environment

<PageTitle>Signing in...</PageTitle>

<div class="d-flex align-items-center justify-content-center" style="min-height: 60vh;">
    <div class="text-center">
        <div class="spinner-border text-primary mb-3" role="status"></div>
        <h4>Signing you in...</h4>
        <p class="text-muted">Please wait while we complete authentication.</p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    [SupplyParameterFromQuery]
    public string? Twofa { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Passwordless dev/E2E shortcut — never expose in production.
        if (!Environment.IsDevelopment()
            && !string.Equals(Environment.EnvironmentName, "Testing", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        ApplicationUser? user = null;

        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

        if (!string.IsNullOrWhiteSpace(Twofa))
        {
            var userId = ChallengeStore.ConsumeChallenge(Twofa);
            if (userId == null)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            user = await db.Users.IgnoreQueryFilters().FirstOrDefaultAsync(u => u.Id == userId);
        }
        else if (!string.IsNullOrWhiteSpace(Email))
        {
            var normalized = UserManager.NormalizeEmail(Email);
            user = await db.Users
                .IgnoreQueryFilters()
                .FirstOrDefaultAsync(u => u.NormalizedEmail == normalized);

            if (user == null)
            {
                TenantProvider.SetTenantId(Guid.Empty);
                user = await UserManager.FindByEmailAsync(Email);
            }
        }

        if (user == null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        // Now safe to sign in — this request is a fresh top-level navigation from forceLoad.
        await SignInManager.SignInAsync(user, isPersistent: false);

        // Full reload to bootstrap the new authenticated circuit cleanly.
        Navigation.NavigateTo("/", forceLoad: true);
    }
}
