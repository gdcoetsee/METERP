<div class="meterp-empty-state text-center py-5" data-testid="@TestId">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <div class="meterp-empty-icon mb-3" aria-hidden="true">@Icon</div>
    }
    <h5 class="mb-2">@Title</h5>
    @if (!string.IsNullOrEmpty(Description))
    {
        <p class="text-muted mb-3">@Description</p>
    }
    @if (!string.IsNullOrEmpty(CtaText) && OnCta.HasDelegate)
    {
        <button type="button" class="btn btn-primary" data-testid="@($"{TestId}-cta")" @onclick="OnCta">@CtaText</button>
    }
    @if (ChildContent != null)
    {
        <div class="mt-3">@ChildContent</div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "Nothing here yet";
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? Icon { get; set; } = "📋";
    [Parameter] public string? CtaText { get; set; }
    [Parameter] public EventCallback OnCta { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string TestId { get; set; } = "empty-state";
}