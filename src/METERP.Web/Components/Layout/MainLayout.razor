@inherits LayoutComponentBase
@using Microsoft.JSInterop
@inject IJSRuntime JS

@code {
    private bool isDarkMode;

    protected override async Task OnInitializedAsync()
    {
        // Load dark mode preference from localStorage for UX
        try
        {
            var saved = await JS.InvokeAsync<string>("localStorage.getItem", "darkMode");
            isDarkMode = saved == "true";
            if (isDarkMode)
            {
                await JS.InvokeVoidAsync("document.body.classList.add", "dark");
            }
        }
        catch { }
    }

    private async Task ToggleDarkMode()
    {
        isDarkMode = !isDarkMode;
        if (isDarkMode)
        {
            await JS.InvokeVoidAsync("document.body.classList.add", "dark");
        }
        else
        {
            await JS.InvokeVoidAsync("document.body.classList.remove", "dark");
        }
        await JS.InvokeVoidAsync("localStorage.setItem", "darkMode", isDarkMode.ToString().ToLower());
    }
}

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <a href="https://github.com/gdcoetsee/METERP" target="_blank">About METERP</a>
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-sm btn-outline-secondary py-0 px-2" @onclick="ToggleDarkMode" title="Toggle dark mode">🌓</button>
                <AuthorizeView>
                    <Authorized>
                        <div class="d-flex align-items-center gap-2 small">
                            <span class="text-muted">Signed in as <strong>@context.User.Identity?.Name</strong></span>
                            <a href="/logout" class="btn btn-sm btn-outline-secondary py-0 px-2">Logout</a>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="btn btn-sm btn-outline-primary py-0 px-2">Login</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<!-- Floating AI Copilot launcher for that "next level" feel -->
<AuthorizeView>
    <Authorized>
        <a href="/ai-copilot" class="btn btn-primary position-fixed rounded-circle shadow ai-fab" 
           title="Open AI Copilot" data-testid="ai-copilot-launcher">
            <span style="font-size: 1.4rem;">✨</span>
        </a>
    </Authorized>
</AuthorizeView>

<METERP.Web.Components.Shared.ToastContainer />

<div id="blazor-error-ui" role="alert" aria-live="assertive">
    An unhandled error has occurred. Please try refreshing or contact support.
    <a href="" class="reload">Reload</a>
    <a class="dismiss" aria-label="Dismiss error">🗙</a>
</div>
