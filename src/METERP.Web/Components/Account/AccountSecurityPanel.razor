@using System.Security.Claims
@using METERP.Application.Interfaces
@using METERP.Application.Services
@using METERP.Common
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.DependencyInjection
@inject ICurrentUserService CurrentUserService
@inject IServiceScopeFactory ScopeFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ToastService ToastService

<div data-testid="account-security-ready">
@if (_loading)
{
    <p data-testid="account-security-loading"><em>Loading security...</em></p>
}
else
{
        <div class="card mb-4" data-testid="account-security-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Two-Factor Authentication (2FA)</strong>
                @if (_twoFactorEnabled)
                {
                    <span class="badge bg-success" data-testid="2fa-status-enabled">Enabled</span>
                }
                else
                {
                    <span class="badge bg-secondary" data-testid="2fa-status-disabled">Disabled</span>
                }
            </div>
            <div class="card-body">
                @if (_twoFactorEnabled)
                {
                    <p class="mb-3">Your account requires an authenticator code at login.</p>
                    <button class="btn btn-outline-danger" @onclick="DisableTwoFactor" disabled="@_busy" data-testid="2fa-disable-button">
                        Disable 2FA
                    </button>
                }
                else if (_setupInfo != null)
                {
                    <div data-testid="2fa-setup-panel">
                    <p class="mb-2">Scan this key in your authenticator app, or enter it manually:</p>
                    <div class="p-2 bg-light border rounded font-monospace mb-2 user-select-all" data-testid="2fa-shared-key">@_setupInfo.SharedKey</div>
                    <p class="small text-muted mb-2">Setup URI (advanced):</p>
                    <div class="p-2 bg-light border rounded small text-break mb-3" data-testid="2fa-setup-uri">@_setupInfo.AuthenticatorUri</div>

                    <div class="mb-3" style="max-width: 220px;">
                        <label class="form-label">Verification code</label>
                        <input class="form-control" maxlength="6" value="@_confirmCode" @oninput="OnConfirmCodeInput" placeholder="6-digit code" data-testid="2fa-confirm-code" inputmode="numeric" />
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-success" @onclick="ConfirmSetup" disabled="@_busy" data-testid="2fa-confirm-button">Confirm &amp; Enable</button>
                        <button class="btn btn-secondary" @onclick="CancelSetup" disabled="@_busy">Cancel</button>
                    </div>
                    </div>
                }
                else
                {
                    <p class="mb-3">Add a second layer of security beyond your password.</p>
                    <button class="btn btn-primary" @onclick="BeginSetup" disabled="@_busy" data-testid="2fa-enable-button">
                        Enable Authenticator 2FA
                    </button>
                }
            </div>
        </div>
}
</div>

@code {
    private bool _loading = true;
    private bool _busy;
    private bool _twoFactorEnabled;
    private TwoFactorSetupInfo? _setupInfo;
    private string _confirmCode = string.Empty;
    private int _loadGeneration;
    private readonly ComponentAsyncGate _loadGate = new();

    protected override async Task OnInitializedAsync() => await _loadGate.RunAsync(async () =>
    {
        _loading = true;
        try
        {
            await RefreshStatusAsync();
        }
        finally
        {
            _loading = false;
        }
    });

    private void OnConfirmCodeInput(ChangeEventArgs e) => _confirmCode = e.Value?.ToString() ?? string.Empty;

    private async Task RefreshStatusAsync()
    {
        var generation = ++_loadGeneration;
        var userId = await ResolveUserIdAsync();
        if (userId == null) return;

        await using var scope = await CreateUserScopeAsync();
        var twoFactor = scope.ServiceProvider.GetRequiredService<ITwoFactorAuthService>();
        var enabled = await twoFactor.IsEnabledAsync(userId.Value);
        if (generation != _loadGeneration)
            return;
        _twoFactorEnabled = enabled;
    }

    private async Task BeginSetup()
    {
        var userId = await ResolveUserIdAsync();
        if (userId == null) return;

        _busy = true;
        try
        {
            await using var scope = await CreateUserScopeAsync();
            var twoFactor = scope.ServiceProvider.GetRequiredService<ITwoFactorAuthService>();
            _setupInfo = await twoFactor.BeginSetupAsync(userId.Value);
            if (_setupInfo == null)
                ToastService.ShowError("Could not start 2FA setup.");
        }
        finally
        {
            _busy = false;
        }
    }

    private void CancelSetup()
    {
        _setupInfo = null;
        _confirmCode = string.Empty;
    }

    private async Task ConfirmSetup()
    {
        var userId = await ResolveUserIdAsync();
        if (userId == null || string.IsNullOrWhiteSpace(_confirmCode)) return;

        _busy = true;
        try
        {
            await using var scope = await CreateUserScopeAsync();
            var twoFactor = scope.ServiceProvider.GetRequiredService<ITwoFactorAuthService>();
            var (ok, errors) = await twoFactor.ConfirmSetupAsync(userId.Value, _confirmCode.Trim());
            if (ok)
            {
                _setupInfo = null;
                _confirmCode = string.Empty;
                await RefreshStatusAsync();
                ToastService.ShowSuccess("Two-factor authentication enabled. You will need your authenticator app at next login.");
            }
            else
            {
                ToastService.ShowError(string.Join("; ", errors));
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DisableTwoFactor()
    {
        var userId = await ResolveUserIdAsync();
        if (userId == null) return;

        _busy = true;
        try
        {
            await using var scope = await CreateUserScopeAsync();
            var twoFactor = scope.ServiceProvider.GetRequiredService<ITwoFactorAuthService>();
            var (ok, errors) = await twoFactor.DisableAsync(userId.Value);
            if (ok)
            {
                _setupInfo = null;
                _confirmCode = string.Empty;
                await RefreshStatusAsync();
                ToastService.ShowSuccess("Two-factor authentication disabled.");
            }
            else
            {
                ToastService.ShowError(string.Join("; ", errors));
            }
        }
        finally
        {
            _busy = false;
        }
    }

    /// <summary>
    /// HttpContext is often unavailable on Blazor Server circuit events; fall back to AuthenticationState.
    /// </summary>
    private async Task<Guid?> ResolveUserIdAsync()
    {
        if (CurrentUserService.UserId is { } fromHttp)
            return fromHttp;

        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var idClaim = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        return Guid.TryParse(idClaim, out var id) ? id : null;
    }

    private async Task<AsyncServiceScope> CreateUserScopeAsync()
    {
        var scope = ScopeFactory.CreateAsyncScope();
        var tenantProvider = scope.ServiceProvider.GetRequiredService<ITenantProvider>();
        var tenantId = CurrentUserService.TenantId;
        if (tenantId == Guid.Empty)
        {
            var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var tenantClaim = auth.User.FindFirst("TenantId")?.Value;
            if (Guid.TryParse(tenantClaim, out var parsed))
                tenantId = parsed;
        }

        if (tenantId != Guid.Empty)
            tenantProvider.SetTenantId(tenantId);
        return scope;
    }
}