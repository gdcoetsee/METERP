# METERP environment variables (copy to .env for docker-compose or set in your host/CI)
# ASP.NET Core uses double-underscore for nested config keys.

# --- Database (required) ---
ConnectionStrings__DefaultConnection=Host=postgres;Database=METERP;Username=postgres;Password=postgres;Port=5432

# --- ASP.NET ---
# Required for local Postgres when using --no-launch-profile (otherwise Production + CHANGE_ME fails).
ASPNETCORE_ENVIRONMENT=Development
# ASPNETCORE_URLS=http://+:8080

# --- Seeding (optional — destructive full reset) ---
# METERP_SEED_RESET=true
# Seed__ForceResetOnStart=true
# METERP_SEED_LARGE=true
# Seed__LargeDataset=true

# --- AI Copilot (optional) ---
# ApiKey + BaseUrl + Model must match the provider. METERP uses OpenAI-compatible /chat/completions.
Ai__Enabled=true
# Google AI Studio (FREE tier) — recommended for testing:
# Ai__ApiKey=AIzaSy-your-key-from-aistudio.google.com
# Ai__BaseUrl=https://generativelanguage.googleapis.com/v1beta/openai
# Ai__Model=gemini-flash-latest
# Groq (free tier):
# Ai__ApiKey=gsk_...
# Ai__BaseUrl=https://api.groq.com/openai/v1
# Ai__Model=llama-3.3-70b-versatile
# OpenAI:
# Ai__ApiKey=sk-your-key-here
# Ai__BaseUrl=https://api.openai.com/v1
# Ai__Model=gpt-4o-mini
Ai__BaseUrl=https://generativelanguage.googleapis.com/v1beta/openai
Ai__Model=gemini-flash-latest
Ai__TimeoutSeconds=60

# --- Structured logging (optional — docker-compose includes seq service on port 5341) ---
# Seq__ServerUrl=http://seq:5341

# --- OpenTelemetry (optional — console export in Development; set OTLP for production collectors) ---
# OpenTelemetry__ServiceName=METERP
# OpenTelemetry__OtlpEndpoint=http://otel-collector:4317
# OpenTelemetry__EnableConsoleExporter=false
# OpenTelemetry__OtlpProtocol=Grpc
# With docker-compose observability profile:
#   docker compose --profile observability up --build
#   OpenTelemetry__OtlpEndpoint=http://otel-collector:4317
#   OpenTelemetry__EnableConsoleExporter=false

# --- SMTP notifications (optional — invoice alerts, operational email) ---
# Email__SmtpHost=smtp.example.com
# Email__SmtpPort=587
# Email__UseSsl=true
# Email__Username=
# Email__Password=
# Email__FromAddress=noreply@yourdomain.com
# Email__FromName=METERP
# Email__DefaultNotificationTo=ops@yourdomain.com

# --- Billing / Stripe (optional — SaaS subscription sync + customer portal) ---
# Billing__WebhookSecret=whsec_...
# Billing__StripeSecretKey=sk_test_...
# Billing__CustomerPortalBaseUrl=https://billing.stripe.com/p/login/demo_meterp
# Billing__CustomerPortalReturnUrl=http://localhost:8080/tenants
# Billing__WebhookEventRetentionDays=90

# --- E2E tests (local override) ---
# METERP_BASE_URL=http://localhost:8080